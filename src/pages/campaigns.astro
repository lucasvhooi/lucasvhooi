---
import Layout from '../layouts/Layout.astro';
import headerImg from '../../Images/Headers/CampaignsPageHeader.png';
---
<Layout title="Campaigns — Essolis" activePage="campaigns">
  <style is:inline>
    /* ── Hero ───────────────────────────────────────────────────── */
    .hero {
      position: relative;
      padding: 52px 40px 40px;
      text-align: center;
      flex-shrink: 0;
      background-size: cover;
      background-position: center 35%;
    }

    .hero-title {
      font-family: var(--title);
      font-size: clamp(1rem, 4vw, 2.6rem);
      color: #ffffff;
      letter-spacing: 0.06em;
      margin: 0 0 14px;
      text-shadow: 0 2px 24px rgba(0,0,0,0.7), 0 4px 60px rgba(200,164,92,0.18);
    }

    .hero-ornament {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-bottom: 12px;
    }

    .hero-ornament-line {
      width: 160px;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(200,164,92,0.9));
    }

    .hero-ornament-line.right {
      background: linear-gradient(to left, transparent, rgba(200,164,92,0.9));
    }

    .hero-sub {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.747);
      margin: 0;
      text-shadow: 0 1px 12px rgba(0,0,0,0.6);
    }

    /* ── Main ───────────────────────────────────────────────────── */
    .main {
      flex: 1;
      padding: 32px 36px 60px;
    }

    /* ── Invite section ─────────────────────────────────────────── */
    .invite-section {
      background: linear-gradient(135deg, rgba(100,180,120,0.06), rgba(100,180,120,0.03));
      border: 1px solid rgba(100,180,120,0.18);
      border-radius: 10px;
      padding: 16px 18px;
      margin-bottom: 28px;
    }

    .invite-section-title {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #70b890;
      margin-bottom: 10px;
    }

    .invite-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(100,180,120,0.14);
      border-radius: 8px;
      padding: 10px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .invite-card + .invite-card { margin-top: 8px; }
    .invite-info { min-width: 0; }

    .invite-campaign-name {
      font-family: var(--title);
      font-size: 14px;
      color: var(--accent);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .invite-from { font-size: 12px; color: #666660; margin-top: 2px; }
    .invite-actions { display: flex; gap: 8px; flex-shrink: 0; }

    .btn-accept {
      background: rgba(100,180,120,0.12);
      border: 1px solid rgba(100,180,120,0.32);
      border-radius: 6px;
      color: #70b890;
      font-size: 12px;
      padding: 5px 12px;
      cursor: pointer;
      font-family: var(--font);
      transition: background 0.2s;
    }
    .btn-accept:hover { background: rgba(100,180,120,0.22); }
    .btn-accept:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-decline {
      background: rgba(200,50,50,0.07);
      border: 1px solid rgba(200,50,50,0.18);
      border-radius: 6px;
      color: #a06060;
      font-size: 12px;
      padding: 5px 12px;
      cursor: pointer;
      font-family: var(--font);
      transition: background 0.2s;
    }
    .btn-decline:hover { background: rgba(200,50,50,0.15); }

    /* ── Toolbar ────────────────────────────────────────────────── */
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 22px;
      gap: 12px;
    }

    .toolbar-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .toolbar-label {
      font-family: var(--title);
      font-size: 1.5rem;
      color: var(--text);
      letter-spacing: 0.03em;
    }

    .toolbar-count {
      background: rgba(200,164,92,0.1);
      border: 1px solid rgba(200,164,92,0.22);
      border-radius: 20px;
      font-size: 11px;
      color: var(--accent);
      padding: 2px 9px;
      font-family: var(--font);
    }

    .toolbar-actions { display: flex; gap: 10px; align-items: center; }

    .btn-join {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(200,164,92,0.15);
      border-radius: 8px;
      color: var(--muted);
      font-family: var(--font);
      font-size: 13px;
      padding: 9px 16px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .btn-join:hover { background: rgba(255,255,255,0.07); color: var(--text); border-color: rgba(200,164,92,0.35); }

    .btn-add {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, #8a6010 0%, #c8922a 40%, #e0b040 60%, #b07820 100%);
      border: 1px solid rgba(220,170,60,0.6);
      border-radius: 8px;
      color: #1a1000;
      font-family: var(--title);
      font-size: 15px;
      letter-spacing: 0.06em;
      padding: 11px 22px;
      cursor: pointer;
      transition: filter 0.22s, box-shadow 0.25s, transform 0.2s;
      white-space: nowrap;
      text-shadow: none;
    }
    .btn-add:hover {
      filter: brightness(1.1);
      box-shadow: 0 0 15px rgba(221, 88, 26, 0.35), 0 4px 16px rgba(0,0,0,0.4);
      transform: translateY(-1px);
    }
    .btn-add:active { transform: translateY(0) scale(0.98); }
    .btn-add:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; filter: none; }

    /* ── Campaign grid ───────────────────────────────────────────── */
    .campaign-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    /* ── Campaign card (horizontal) ─────────────────────────────── */
    .campaign-card {
      background: linear-gradient(135deg, #1c1c1a 0%, #181817 100%);
      border: 1px solid rgba(200,164,92,0.1);
      border-radius: 12px;
      display: flex;
      cursor: pointer;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
      position: relative;
      overflow: hidden;
      height: 300px;
    }

    .campaign-card::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 12px;
      background: radial-gradient(
        circle at var(--shine-x, 50%) var(--shine-y, 50%),
        rgba(200,164,92,0.07) 0%,
        transparent 60%
      );
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .campaign-card:hover {
      border-color: rgba(200,164,92,0.25);
      box-shadow: 0 8px 36px rgba(0,0,0,0.5);
      transform: translateY(-2px);
    }
    .campaign-card:hover::after { opacity: 1; }

    /* Left image column */
    .campaign-card-img {
      width: 220px;
      flex-shrink: 0;
      background-color: #131312;
      background-size: cover;
      background-position: center;
      border-right: 1px solid rgba(200,164,92,0.08);
      border-radius: 12px 0 0 12px;
      position: relative;
      overflow: hidden;
    }

    /* Placeholder gradient when no image */
    .campaign-card-img.no-image {
      background-image:
        radial-gradient(ellipse at 50% 25%, rgba(200,164,92,0.07) 0%, transparent 60%),
        linear-gradient(160deg, #1e1e1c 0%, #181817 50%, #131312 100%);
    }

    /* Subtle overlay on top of user images */
    .campaign-card-img::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 55%);
      z-index: 1;
    }

    /* Right content column */
    .campaign-card-body {
      flex: 1;
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 7px;
      min-width: 0;
    }

    .campaign-card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px;
    }

    .campaign-name {
      font-family: var(--title);
      font-size: 1.05rem;
      color: var(--accent);
      letter-spacing: 0.03em;
      line-height: 1.25;
    }

    .campaign-role-badge {
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 3px 8px;
      border-radius: 20px;
      white-space: nowrap;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .badge-dm     { background: rgba(200,164,92,0.12); border: 1px solid rgba(200,164,92,0.32); color: var(--accent); }
    .badge-player { background: rgba(100,180,120,0.1);  border: 1px solid rgba(100,180,120,0.28); color: #70b890; }

    .campaign-world {
      font-size: 11px;
      color: var(--muted);
      font-style: italic;
    }

    .campaign-desc {
      font-size: 12px;
      color: #888880;
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .campaign-meta {
      display: flex;
      align-items: center;
      gap: 14px;
      font-size: 11px;
      color: #6a6a66;
      padding-top: 8px;
      border-top: 1px solid rgba(200,164,92,0.07);
      margin-top: auto;
    }

    .campaign-meta-item {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .campaign-card-actions {
      display: flex;
      gap: 6px;
      margin-top: 2px;
    }

    .card-action-btn {
    background: rgba(200, 164, 92, 0.664);
    border: 1px solid rgba(231, 213, 176, 0.712);
    border-radius: 7px;
    color: rgba(231, 213, 176, 0.712);
      padding: 7px 9px;
      cursor: pointer;
      font-size: 13px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .card-action-btn:hover { background: rgba(200,164,92,0.12); color: var(--accent); border-color: rgba(200,164,92,0.32); }

    .card-action-btn.danger {
      background: rgba(200, 50, 50, 0.568);
      border-color: rgba(200, 50, 50, 0.623);
      color: #c28a8a;
    }
    .card-action-btn.danger:hover { background: rgba(200,50,50,0.12); color: #e07070; border-color: rgba(200,50,50,0.32); }

    /* ── States ─────────────────────────────────────────────────── */
    #state-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 80px 0;
      gap: 14px;
      color: #3a2a18;
      font-size: 13px;
    }

    .loading-spinner {
      width: 32px; height: 32px;
      border: 2px solid #2a1a08;
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.9s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    #state-empty {
      display: none;
      text-align: center;
      padding: 80px 20px;
    }

    .empty-icon { font-size: 3rem; margin-bottom: 18px; opacity: 0.28; }
    .empty-title { font-family: var(--title); font-size: 1.3rem; color: var(--muted); margin-bottom: 8px; }
    .empty-sub { font-size: 13px; color: #555550; line-height: 1.7; max-width: 320px; margin: 0 auto 24px; }

    #state-campaigns { display: none; }

    /* ── Modals ─────────────────────────────────────────────────── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.8);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 16px;
      backdrop-filter: blur(4px);
    }
    .modal-overlay.open { display: flex; animation: fadeIn 0.2s ease both; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .modal-box {
      background: linear-gradient(160deg, #1c1c1a 0%, #161615 100%);
      border: 1px solid rgba(200,164,92,0.12);
      border-radius: 16px;
      padding: 32px 28px 28px;
      width: 100%;
      max-width: 440px;
      box-shadow: 0 8px 48px rgba(0,0,0,0.9);
      animation: modalIn 0.4s cubic-bezier(0.16,1,0.3,1) both;
    }
    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.93) translateY(20px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
    .modal-title { font-family: var(--title); font-size: 1.25rem; color: var(--accent); letter-spacing: 0.04em; }
    .modal-close {
      background: none; border: none; color: #4a3828; font-size: 18px;
      cursor: pointer; padding: 2px 6px; border-radius: 4px; line-height: 1;
      transition: color 0.2s, background 0.2s;
    }
    .modal-close:hover { color: var(--text); background: rgba(255,255,255,0.06); }

    .modal-field { margin-bottom: 16px; }
    .modal-label { display: block; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #888880; margin-bottom: 6px; }

    .modal-input, .modal-textarea {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(200,164,92,0.1);
      border-radius: 8px;
      padding: 11px 14px;
      color: var(--text);
      font-size: 14px;
      font-family: var(--font);
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .modal-input:focus, .modal-textarea:focus { border-color: rgba(200,164,92,0.5); }
    .modal-textarea { resize: vertical; min-height: 80px; }

    .modal-error {
      background: rgba(200,50,50,0.1);
      border: 1px solid rgba(200,50,50,0.26);
      border-radius: 6px;
      color: #e07070;
      font-size: 13px;
      padding: 9px 12px;
      margin-bottom: 14px;
      display: none;
    }
    .modal-error.show { display: block; }

    .modal-footer { display: flex; gap: 10px; margin-top: 20px; }
    .modal-footer .btn-add { flex: 1; justify-content: center; }

    .btn-cancel {
      flex: 1;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(200,164,92,0.1);
      border-radius: 8px;
      color: #7a6a58;
      font-family: var(--font);
      font-size: 14px;
      padding: 11px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }
    .btn-cancel:hover { background: rgba(255,255,255,0.08); color: var(--text); }

    .modal-tabs {
      display: flex; gap: 4px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(200,164,92,0.1);
      border-radius: 8px; padding: 4px;
      margin-bottom: 18px;
    }
    .modal-tab {
      flex: 1; background: none; border: none; border-radius: 6px;
      color: var(--muted); font-family: var(--font); font-size: 13px;
      padding: 7px 10px; cursor: pointer; transition: background 0.2s, color 0.2s;
    }
    .modal-tab:hover { color: var(--text); }
    .modal-tab.active { background: rgba(200,164,92,0.1); color: var(--accent); border: 1px solid rgba(200,164,92,0.2); }
    .modal-tab-content { display: none; }
    .modal-tab-content.active { display: block; }

    .invite-row { display: flex; gap: 8px; }
    .invite-row .modal-input { flex: 1; }
    .invite-row .btn-send {
      background: linear-gradient(135deg, #4a2c0a, #6b3e10);
      border: 1px solid var(--accent);
      border-radius: 8px;
      color: var(--accent);
      font-family: var(--font);
      font-size: 14px;
      padding: 11px 16px;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s;
    }
    .invite-row .btn-send:hover { background: linear-gradient(135deg, #5a380f, #7a4a18); }
    .invite-row .btn-send:disabled { opacity: 0.5; cursor: not-allowed; }
    .invite-feedback { font-size: 13px; margin-top: 10px; min-height: 18px; }

    .code-hint { font-size: 13px; color: #888880; margin-bottom: 14px; line-height: 1.5; }
    .code-block {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(200,164,92,0.1);
      border-radius: 8px;
      padding: 14px 18px;
      display: flex; align-items: center; justify-content: space-between; gap: 10px;
      margin-bottom: 10px;
    }
    .code-text { font-family: 'Courier New', monospace; font-size: 1.3rem; color: var(--accent); letter-spacing: 0.18em; }
    .btn-copy {
      background: rgba(200,164,92,0.1); border: 1px solid rgba(200,164,92,0.28);
      border-radius: 6px; color: var(--accent); font-size: 12px; padding: 5px 12px;
      cursor: pointer; font-family: var(--font); flex-shrink: 0; transition: background 0.2s;
    }
    .btn-copy:hover { background: rgba(200,164,92,0.18); }
    .btn-regen {
      background: none; border: 1px solid rgba(200,164,92,0.1); border-radius: 6px;
      color: var(--muted); font-size: 12px; padding: 7px 14px; cursor: pointer;
      font-family: var(--font); transition: color 0.2s, border-color 0.2s;
    }
    .btn-regen:hover { color: var(--text); border-color: #4a2e14; }
    .btn-gen-code {
      width: 100%;
      background: linear-gradient(135deg, #4a2c0a, #6b3e10);
      border: 1px solid var(--accent);
      border-radius: 8px;
      color: var(--accent);
      font-family: var(--title);
      font-size: 15px;
      letter-spacing: 0.06em;
      padding: 13px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-gen-code:hover { background: linear-gradient(135deg, #5a380f, #7a4a18); }

    .btn-modal-danger {
      flex: 1;
      background: rgba(200, 50, 50, 0.568)
      border: 1px solid rgba(200, 50, 50, 0.623);
      border-radius: 8px;
      color: #c28a8a;
      font-family: var(--title);
      font-size: 15px;
      letter-spacing: 0.04em;
      padding: 12px 20px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-modal-danger:hover { background: rgba(200,50,50,0.2); }
    .btn-modal-danger:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── Create new row ─────────────────────────────────────────── */
    .create-new-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      margin-top: 14px;
      padding: 28px 22px;
      border: 1px dashed rgba(200,164,92,0.18);
      border-radius: 12px;
      cursor: pointer;
      background: transparent;
      width: 100%;
      text-align: center;
      transition: border-color 0.22s, background 0.22s;
      font-family: var(--font);
    }
    .create-new-row:hover {
      border-color: rgba(200,164,92,0.38);
      background: rgba(200,164,92,0.03);
    }

    .create-new-icon {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid rgba(200,164,92,0.28);
      background: rgba(200,164,92,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(200,164,92,0.65);
      font-size: 20px;
      flex-shrink: 0;
      transition: background 0.22s, border-color 0.22s, color 0.22s;
    }
    .create-new-row:hover .create-new-icon {
      background: rgba(200,164,92,0.14);
      border-color: rgba(200,164,92,0.5);
      color: var(--accent);
    }

    .create-new-text { display: flex; flex-direction: column; gap: 5px; align-items: center; }
    .create-new-title { font-size: 15px; color: rgba(220,185,110,0.85); letter-spacing: 0.03em; font-family: var(--title); }
    .create-new-sub   { font-size: 13px; color: #6a6a64; }

    /* ── Image upload label ──────────────────────────────────────── */
    .img-upload-label {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.03);
      border: 1px dashed rgba(200,164,92,0.2);
      border-radius: 8px;
      padding: 12px 16px;
      cursor: pointer;
      font-size: 13px;
      color: var(--muted);
      transition: border-color 0.2s, background 0.2s;
      overflow: hidden;
    }
    .img-upload-label:hover { border-color: rgba(200,164,92,0.4); background: rgba(200,164,92,0.04); color: var(--text); }
    .img-upload-label.has-image { border-style: solid; border-color: rgba(200,164,92,0.3); }
    .img-upload-label span { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* ── Campaign settings toggles ──────────────────────────────── */
    .settings-group { display: flex; flex-direction: column; gap: 8px; }
    .setting-toggle {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 11px 14px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(200,164,92,0.1);
      border-radius: 8px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .setting-toggle:hover { border-color: rgba(200,164,92,0.25); background: rgba(200,164,92,0.03); }
    .setting-toggle input { position: absolute; opacity: 0; width: 0; height: 0; pointer-events: none; }
    .setting-switch {
      flex-shrink: 0;
      width: 38px; height: 22px;
      border-radius: 999px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.12);
      position: relative;
      transition: background 0.2s, border-color 0.2s;
      margin-top: 1px;
    }
    .setting-switch::after {
      content: '';
      position: absolute;
      top: 2px; left: 2px;
      width: 16px; height: 16px;
      border-radius: 50%;
      background: #b8b0a0;
      transition: transform 0.2s, background 0.2s;
    }
    .setting-toggle input:checked + .setting-switch {
      background: rgba(200,164,92,0.3);
      border-color: rgba(200,164,92,0.5);
