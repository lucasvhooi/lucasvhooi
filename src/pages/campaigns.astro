      .campaign-card-body {
        position: relative;
        z-index: 2;
        justify-content: flex-end;
      }
      .campaign-name { text-shadow: 0 1px 8px rgba(0,0,0,0.9); }
      .campaign-desc { color: #cfcabf; padding-bottom: 2px; }

      /* Toolbar: let the label sit on its own line and the two actions
         share a full-width row so neither button runs off-screen */
      .toolbar { flex-wrap: wrap; }
      .toolbar-actions { width: 100%; }
      .toolbar-actions .btn-join,
      .toolbar-actions .btn-add { flex: 1; justify-content: center; }
      .btn-add { font-size: 14px; padding: 11px 16px; }
