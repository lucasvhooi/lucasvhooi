---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Campaigns — Essolis">
  <style is:inline>
    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .hero {
      text-align: center;
      padding: 56px 20px 40px;
      border-bottom: 1px solid #1e1208;
      background: radial-gradient(ellipse at 50% 0%, rgba(200,164,92,0.06) 0%, transparent 70%);
    }
    .hero-title {
      font-family: var(--title);
      font-size: clamp(2rem, 5vw, 3rem);
      color: var(--accent);
      letter-spacing: 0.05em;
      margin-bottom: 8px;
      text-shadow: 0 2px 32px rgba(200,164,92,0.2);
    }
    .hero-sub {
      font-size: 14px;
      color: var(--muted);
      font-style: italic;
    }

    .main {
      flex: 1;
      max-width: 1100px;
      width: 100%;
      margin: 0 auto;
      padding: 40px 24px 80px;
    }

    .invite-section {
      background: linear-gradient(135deg, rgba(100,180,120,0.06) 0%, rgba(100,180,120,0.03) 100%);
      border: 1px solid rgba(100,180,120,0.25);
      border-radius: 12px;
      padding: 18px 20px;
      margin-bottom: 28px;
    }
    .invite-section-title {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #70b890;
      margin-bottom: 12px;
    }
    .invite-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(100,180,120,0.18);
      border-radius: 8px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .invite-card + .invite-card { margin-top: 8px; }
    .invite-info { min-width: 0; }
    .invite-campaign-name {
      font-family: var(--title);
      font-size: 14px;
      color: var(--accent);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .invite-from {
      font-size: 12px;
      color: #665540;
      margin-top: 2px;
    }
    .invite-actions {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }
    .btn-accept {
      background: rgba(100,180,120,0.15);
      border: 1px solid rgba(100,180,120,0.4);
      border-radius: 6px;
      color: #70b890;
      font-size: 12px;
      padding: 5px 12px;
      cursor: pointer;
      font-family: var(--font);
      transition: background 0.2s;
    }
    .btn-accept:hover { background: rgba(100,180,120,0.25); }
    .btn-accept:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-decline {
      background: rgba(200,50,50,0.08);
      border: 1px solid rgba(200,50,50,0.22);
      border-radius: 6px;
      color: #a06060;
      font-size: 12px;
      padding: 5px 12px;
      cursor: pointer;
      font-family: var(--font);
      transition: background 0.2s;
    }
    .btn-decline:hover { background: rgba(200,50,50,0.16); }

    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
      gap: 12px;
      flex-wrap: wrap;
    }
    .toolbar-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      flex: 1;
    }
    .toolbar-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .btn-add {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, #4a2c0a 0%, #6b3e10 100%);
      border: 1px solid var(--accent);
      border-radius: 8px;
      color: var(--accent);
      font-family: var(--title);
      font-size: 15px;
      letter-spacing: 0.06em;
      padding: 10px 20px;
      cursor: pointer;
      transition: background 0.25s, box-shadow 0.25s, transform 0.2s;
      white-space: nowrap;
    }
    .btn-add:hover {
      background: linear-gradient(135deg, #5a380f 0%, #7a4a18 100%);
      box-shadow: 0 0 20px rgba(200,164,92,0.25);
      transform: translateY(-1px);
    }
    .btn-add:active { transform: translateY(0) scale(0.98); }
    .btn-add:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

    .btn-join {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--muted);
      font-family: var(--font);
      font-size: 14px;
      padding: 10px 16px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .btn-join:hover { background: rgba(255,255,255,0.07); color: var(--text); border-color: #5a3510; }

    .campaign-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
    }

    .campaign-card {
      background: linear-gradient(160deg, #1e1108 0%, #180e06 100%);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      cursor: pointer;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
      position: relative;
      overflow: hidden;
    }
    .campaign-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 14px;
      background: radial-gradient(
        circle at var(--shine-x, 50%) var(--shine-y, 50%),
        rgba(200,164,92,0.06) 0%,
        transparent 65%
      );
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .campaign-card:hover { border-color: #6a4520; box-shadow: 0 6px 32px rgba(0,0,0,0.6); transform: translateY(-2px); }
    .campaign-card:hover::before { opacity: 1; }

    .campaign-card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
    }
    .campaign-name {
      font-family: var(--title);
      font-size: 1.2rem;
      color: var(--accent);
      letter-spacing: 0.03em;
      line-height: 1.25;
    }
    .campaign-role-badge {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 3px 9px;
      border-radius: 20px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .badge-dm     { background: rgba(200,164,92,0.15); border: 1px solid rgba(200,164,92,0.4); color: var(--accent); }
    .badge-player { background: rgba(100,180,120,0.12); border: 1px solid rgba(100,180,120,0.35); color: #70b890; }

    .campaign-world {
      font-size: 12px;
      color: var(--muted);
      font-style: italic;
    }

    .campaign-desc {
      font-size: 13px;
      color: #8a7060;
      line-height: 1.6;
      flex: 1;
    }

    .campaign-meta {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 12px;
      color: var(--muted);
      padding-top: 10px;
      border-top: 1px solid #231510;
    }
    .campaign-meta-item {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .campaign-card-actions {
      display: flex;
      gap: 8px;
    }

    .btn-invite-card {
      background: rgba(200,164,92,0.06);
      border: 1px solid rgba(200,164,92,0.2);
      border-radius: 8px;
      color: var(--muted);
      padding: 10px 13px;
      cursor: pointer;
      font-size: 15px;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .btn-invite-card:hover { background: rgba(200,164,92,0.12); color: var(--accent); border-color: rgba(200,164,92,0.4); }

    #state-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 80px 0;
      gap: 14px;
      color: #444;
      font-size: 13px;
    }
    .loading-spinner {
      width: 36px; height: 36px;
      border: 2px solid #2a1a08;
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.9s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    #state-empty {
      display: none;
      text-align: center;
      padding: 80px 20px;
    }
    .empty-icon {
      font-size: 3.5rem;
      margin-bottom: 20px;
      opacity: 0.35;
    }
    .empty-title {
      font-family: var(--title);
      font-size: 1.4rem;
      color: #5a4530;
      margin-bottom: 8px;
    }
    .empty-sub {
      font-size: 13px;
      color: #443525;
      line-height: 1.7;
      max-width: 320px;
      margin: 0 auto 28px;
    }

    #state-campaigns { display: none; }

    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.75);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 16px;
      backdrop-filter: blur(4px);
    }
    .modal-overlay.open { display: flex; }

    .modal-box {
      background: linear-gradient(160deg, #1e1108 0%, #150d05 100%);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px 28px 28px;
      width: 100%;
      max-width: 440px;
      box-shadow: 0 8px 48px rgba(0,0,0,0.9);
      animation: modalIn 0.35s cubic-bezier(0.16,1,0.3,1) both;
    }
    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.93) translateY(20px); }
      to   { opacity: 1; transform: scale(1)    translateY(0); }
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 22px;
    }
    .modal-title {
      font-family: var(--title);
      font-size: 1.3rem;
      color: var(--accent);
      letter-spacing: 0.04em;
    }
    .modal-close {
      background: none;
      border: none;
      color: #555;
      font-size: 20px;
      cursor: pointer;
      padding: 2px 6px;
      border-radius: 4px;
      transition: color 0.2s, background 0.2s;
      line-height: 1;
    }
    .modal-close:hover { color: var(--text); background: rgba(255,255,255,0.06); }

    .modal-field { margin-bottom: 16px; }
    .modal-label {
      display: block;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 6px;
    }
    .modal-input, .modal-textarea {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 11px 14px;
      color: var(--text);
      font-size: 15px;
      font-family: var(--font);
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .modal-input:focus, .modal-textarea:focus { border-color: var(--accent); }
    .modal-textarea { resize: vertical; min-height: 80px; }

    .modal-error {
      background: rgba(200,50,50,0.12);
      border: 1px solid rgba(200,50,50,0.3);
      border-radius: 6px;
      color: #e07070;
      font-size: 13px;
      padding: 9px 12px;
      margin-bottom: 14px;
      display: none;
    }
    .modal-error.show { display: block; }

    .modal-footer {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }
    .modal-footer .btn-add { flex: 1; justify-content: center; margin: 0; }
    .btn-cancel {
      flex: 1;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: #888;
      font-family: var(--font);
      font-size: 15px;
      padding: 11px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }
    .btn-cancel:hover { background: rgba(255,255,255,0.08); color: var(--text); }

    .modal-tabs {
      display: flex;
      gap: 4px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 4px;
      margin-bottom: 20px;
    }
    .modal-tab {
      flex: 1;
      background: none;
      border: none;
      border-radius: 6px;
      color: var(--muted);
      font-family: var(--font);
      font-size: 13px;
      padding: 7px 10px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }
    .modal-tab:hover { color: var(--text); }
    .modal-tab.active {
      background: rgba(200,164,92,0.12);
      color: var(--accent);
      border: 1px solid rgba(200,164,92,0.25);
    }
    .modal-tab-content { display: none; }
    .modal-tab-content.active { display: block; }

    .invite-row {
      display: flex;
      gap: 8px;
    }
    .invite-row .modal-input { flex: 1; }
    .invite-row .btn-send {
      background: linear-gradient(135deg, #4a2c0a 0%, #6b3e10 100%);
      border: 1px solid var(--accent);
      border-radius: 8px;
      color: var(--accent);
      font-family: var(--font);
      font-size: 14px;
      padding: 11px 16px;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s;
    }
    .invite-row .btn-send:hover { background: linear-gradient(135deg, #5a380f 0%, #7a4a18 100%); }
    .invite-row .btn-send:disabled { opacity: 0.5; cursor: not-allowed; }
    .invite-feedback {
      font-size: 13px;
      margin-top: 10px;
      min-height: 18px;
    }

    .code-hint {
      font-size: 13px;
      color: #665540;
      margin-bottom: 14px;
      line-height: 1.5;
    }
    .code-block {
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 10px;
    }
    .code-text {
      font-family: 'Courier New', monospace;
      font-size: 1.35rem;
      color: var(--accent);
      letter-spacing: 0.18em;
    }
    .btn-copy {
      background: rgba(200,164,92,0.1);
      border: 1px solid rgba(200,164,92,0.3);
      border-radius: 6px;
      color: var(--accent);
      font-size: 12px;
      padding: 5px 12px;
      cursor: pointer;
      font-family: var(--font);
      flex-shrink: 0;
      transition: background 0.2s;
    }
    .btn-copy:hover { background: rgba(200,164,92,0.18); }
    .btn-regen {
      background: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--muted);
      font-size: 12px;
      padding: 7px 14px;
      cursor: pointer;
      font-family: var(--font);
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-regen:hover { color: var(--text); border-color: #5a3510; }
    .btn-gen-code {
      width: 100%;
      background: linear-gradient(135deg, #4a2c0a 0%, #6b3e10 100%);
      border: 1px solid var(--accent);
      border-radius: 8px;
      color: var(--accent);
      font-family: var(--title);
      font-size: 15px;
      letter-spacing: 0.06em;
      padding: 13px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-gen-code:hover { background: linear-gradient(135deg, #5a380f 0%, #7a4a18 100%); }

    .btn-edit-card {
      background: rgba(200,164,92,0.06);
      border: 1px solid rgba(200,164,92,0.2);
      border-radius: 8px;
      color: var(--muted);
      padding: 10px 13px;
      cursor: pointer;
      font-size: 15px;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .btn-edit-card:hover { background: rgba(200,164,92,0.12); color: var(--accent); border-color: rgba(200,164,92,0.4); }

    .btn-delete-card {
      background: rgba(200,50,50,0.06);
      border: 1px solid rgba(200,50,50,0.2);
      border-radius: 8px;
      color: #7a5050;
      padding: 10px 13px;
      cursor: pointer;
      font-size: 15px;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .btn-delete-card:hover { background: rgba(200,50,50,0.14); color: #e07070; border-color: rgba(200,50,50,0.4); }

    .btn-modal-danger {
      flex: 1;
      background: rgba(200,50,50,0.12);
      border: 1px solid rgba(200,50,50,0.35);
      border-radius: 8px;
      color: #e07070;
      font-family: var(--title);
      font-size: 15px;
      letter-spacing: 0.04em;
      padding: 12px 20px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-modal-danger:hover { background: rgba(200,50,50,0.22); }
    .btn-modal-danger:disabled { opacity: 0.5; cursor: not-allowed; }

    @media (max-width: 600px) {
      .main { padding: 28px 16px 60px; }
      .hero { padding: 36px 16px 28px; }
      .campaign-grid { grid-template-columns: 1fr; }
      .toolbar { flex-direction: column; align-items: stretch; }
      .toolbar-actions { justify-content: flex-end; }
    }
  </style>

  <div class="hero">
    <h1 class="hero-title">Choose Your Campaign</h1>
    <p class="hero-sub">Select a realm to enter, or forge a new one</p>
  </div>

  <main class="main">
    <div class="invite-section" id="invite-section" style="display:none">
      <div class="invite-section-title">Pending Invites</div>
      <div id="invite-list"></div>
    </div>

    <div class="toolbar">
      <span class="toolbar-label" id="toolbar-label"></span>
      <div class="toolbar-actions">
        <button class="btn-join" id="btn-join-code">
          <iconify-icon icon="lucide:key-round"></iconify-icon>
          Join by Code
        </button>
        <button class="btn-add" id="btn-add-campaign">
          <iconify-icon icon="lucide:plus"></iconify-icon>
          Add Campaign
        </button>
      </div>
    </div>

    <div id="state-loading">
      <div class="loading-spinner"></div>
      <span>Loading campaigns…</span>
    </div>

    <div id="state-empty">
      <div class="empty-icon">📜</div>
      <h2 class="empty-title">No campaigns yet</h2>
      <p class="empty-sub">You haven't joined or created any campaigns. Press "Add Campaign" to start your first adventure, or ask your DM for an invite code.</p>
      <button class="btn-add" id="btn-add-empty">
        <iconify-icon icon="lucide:plus"></iconify-icon>
        Add Campaign
      </button>
    </div>

    <div id="state-campaigns">
      <div class="campaign-grid" id="campaign-grid"></div>
    </div>
  </main>

  <!-- Add Campaign modal -->
  <div class="modal-overlay" id="modal-add">
    <div class="modal-box">
      <div class="modal-header">
        <h2 class="modal-title">New Campaign</h2>
        <button class="modal-close" id="modal-close">✕</button>
      </div>
      <div class="modal-error" id="modal-error"></div>
      <div class="modal-field">
        <label class="modal-label" for="c-name">Campaign Name <span style="color:#e07070">*</span></label>
        <input class="modal-input" id="c-name" type="text" placeholder="The Lost Mines of Phandelver" maxlength="60" autocomplete="off" />
      </div>
      <div class="modal-field">
        <label class="modal-label" for="c-world">World / Setting</label>
        <input class="modal-input" id="c-world" type="text" placeholder="Faerûn, Eberron, homebrew…" maxlength="60" autocomplete="off" />
      </div>
      <div class="modal-field">
        <label class="modal-label" for="c-desc">Description</label>
        <textarea class="modal-textarea" id="c-desc" placeholder="A short description of the campaign…" maxlength="300"></textarea>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="btn-cancel">Cancel</button>
        <button class="btn-add" id="btn-create-campaign">
          <iconify-icon icon="lucide:plus"></iconify-icon>
          Create
        </button>
      </div>
    </div>
  </div>

  <!-- Invite Players modal -->
  <div class="modal-overlay" id="modal-invite">
    <div class="modal-box">
      <div class="modal-header">
        <h2 class="modal-title">Invite Players</h2>
        <button class="modal-close" id="invite-modal-close">✕</button>
      </div>
      <div class="modal-tabs">
        <button class="modal-tab active" data-tab="username">By Username</button>
        <button class="modal-tab" data-tab="code">Invite Code</button>
      </div>
      <div class="modal-tab-content active" id="tab-username">
        <div class="modal-field">
          <label class="modal-label">Player Username</label>
          <div class="invite-row">
            <input class="modal-input" id="invite-username" type="text" placeholder="adventurer_of_doom" autocomplete="off" />
            <button class="btn-send" id="btn-send-invite">Send</button>
          </div>
        </div>
        <div class="invite-feedback" id="invite-feedback"></div>
      </div>
      <div class="modal-tab-content" id="tab-code">
        <div id="code-display-area"></div>
      </div>
    </div>
  </div>

  <!-- Join by Code modal -->
  <div class="modal-overlay" id="modal-join">
    <div class="modal-box" style="max-width:380px">
      <div class="modal-header">
        <h2 class="modal-title">Join Campaign</h2>
        <button class="modal-close" id="join-modal-close">✕</button>
      </div>
      <div class="modal-error" id="join-error"></div>
      <div class="modal-field">
        <label class="modal-label">Invite Code</label>
        <input class="modal-input" id="join-code-input" type="text" placeholder="XXXX-XXXX" autocomplete="off" style="text-transform:uppercase;letter-spacing:0.1em" />
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="join-cancel">Cancel</button>
        <button class="btn-add" id="btn-join-submit" style="justify-content:center;flex:1">
          <iconify-icon icon="lucide:log-in"></iconify-icon>
          Join
        </button>
      </div>
    </div>
  </div>

  <!-- Edit Campaign modal -->
  <div class="modal-overlay" id="modal-edit">
    <div class="modal-box">
      <div class="modal-header">
        <h2 class="modal-title">Edit Campaign</h2>
        <button class="modal-close" id="edit-modal-close">✕</button>
      </div>
      <div class="modal-error" id="edit-modal-error"></div>
      <div class="modal-field">
        <label class="modal-label" for="e-name">Campaign Name <span style="color:#e07070">*</span></label>
        <input class="modal-input" id="e-name" type="text" maxlength="60" autocomplete="off" />
      </div>
      <div class="modal-field">
        <label class="modal-label" for="e-world">World / Setting</label>
        <input class="modal-input" id="e-world" type="text" placeholder="Faerûn, Eberron, homebrew…" maxlength="60" autocomplete="off" />
      </div>
      <div class="modal-field">
        <label class="modal-label" for="e-desc">Description</label>
        <textarea class="modal-textarea" id="e-desc" maxlength="300"></textarea>
      </div>
      <div class="modal-footer">
        <button class="btn-cancel" id="edit-cancel">Cancel</button>
        <button class="btn-add" id="btn-save-edit" style="justify-content:center;flex:1">
          <iconify-icon icon="lucide:save"></iconify-icon>
          Save
        </button>
      </div>
    </div>
  </div>

  <!-- Delete Campaign confirm modal -->
  <div class="modal-overlay" id="modal-delete">
    <div class="modal-box" style="max-width:400px">
      <div class="modal-header">
        <h2 class="modal-title" style="color:#e07070">Delete Campaign</h2>
        <button class="modal-close" id="delete-modal-close">✕</button>
      </div>
      <p style="font-size:14px;color:#8a7060;line-height:1.65;margin-bottom:22px">
        This will permanently delete <strong id="delete-campaign-name" style="color:var(--accent)"></strong> and all its data. This action cannot be undone.
      </p>
      <div class="modal-footer">
        <button class="btn-cancel" id="delete-cancel">Cancel</button>
        <button class="btn-modal-danger" id="btn-confirm-delete">Delete Campaign</button>
      </div>
    </div>
  </div>

  <script is:inline type="module">
    import { db, auth }                                              from "/assets/js/firebase.js";
    import { ref, get, set, push, remove, update, query,
             orderByChild, equalTo, onValue }                        from "https://www.gstatic.com/firebasejs/10.14.1/firebase-database.js";
    import { onAuthStateChanged }                                    from "https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js";
    import { getSession, clearSession }                              from "/assets/js/auth.js";

    const session = getSession();
    if (!session) { window.location.href = "login"; }

    const stateLoading   = document.getElementById('state-loading');
    const stateEmpty     = document.getElementById('state-empty');
    const stateCampaigns = document.getElementById('state-campaigns');
    const grid           = document.getElementById('campaign-grid');
    const toolbarLabel   = document.getElementById('toolbar-label');

    async function loadCampaigns() {
      try {
        const snap = await get(ref(db, 'campaigns'));
        const all  = snap.val() || {};

        // Silently delete campaigns with 0 members that are older than 24 hours
        const dayMs = 24 * 60 * 60 * 1000;
        const now   = Date.now();
        Object.entries(all).forEach(([id, c]) => {
          const memberCount = Object.keys(c.members || {}).length;
          if (memberCount === 0 && c.createdAt && (now - c.createdAt) > dayMs) {
            remove(ref(db, `campaigns/${id}`)).catch(() => {});
          }
        });

        const mine = Object.entries(all).filter(([, c]) =>
          c.members && c.members[session.id]
        );

        stateLoading.style.display = 'none';

        if (mine.length === 0) {
          stateEmpty.style.display = 'block';
          return;
        }

        toolbarLabel.textContent = mine.length + ' campaign' + (mine.length !== 1 ? 's' : '');
        stateCampaigns.style.display = 'block';
        mine.forEach(([id, c]) => grid.appendChild(buildCard(id, c)));
        bindShimmer();
      } catch (e) {
        stateLoading.style.display = 'none';
        stateEmpty.style.display = 'block';
      }
    }

    function buildCard(id, c) {
      const initialRole  = c.members?.[session.id] || 'player';
      const initialCount = Object.keys(c.members || {}).length;
      const initialIsDM  = initialRole === 'dm' || session.role === 'admin';

      const card = document.createElement('div');
      card.className = 'campaign-card';
      card.dataset.campaignId    = id;
      card.dataset.campaignName  = c.name  || '';
      card.dataset.campaignWorld = c.world || '';
      card.dataset.campaignDesc  = c.description || '';
      card.innerHTML = `
        <div class="campaign-card-header">
          <span class="campaign-name">${escHtml(c.name || 'Untitled Campaign')}</span>
          <span class="campaign-role-badge ${initialIsDM ? 'badge-dm' : 'badge-player'}">${initialIsDM ? 'DM' : 'Player'}</span>
        </div>
        <span class="campaign-world" style="display:${c.world ? 'inline' : 'none'}">${c.world ? escHtml(c.world) : ''}</span>
        <p class="campaign-desc" style="display:${c.description ? 'block' : 'none'}">${c.description ? escHtml(c.description) : ''}</p>
        <div class="campaign-meta">
          <span class="campaign-meta-item member-count-item">
            <iconify-icon icon="lucide:users" style="font-size:13px"></iconify-icon>
            <span class="member-count-text">${initialCount} member${initialCount !== 1 ? 's' : ''}</span>
          </span>
          ${c.createdAt ? `<span class="campaign-meta-item">
            <iconify-icon icon="lucide:calendar" style="font-size:13px"></iconify-icon>
            ${new Date(c.createdAt).toLocaleDateString()}
          </span>` : ''}
        </div>
        <div class="campaign-card-actions">
          <button class="btn-invite-card" title="Invite Players" style="display:${initialIsDM ? 'flex' : 'none'}"><iconify-icon icon="lucide:user-plus"></iconify-icon></button>
          <button class="btn-edit-card"   title="Edit Campaign"   style="display:${initialIsDM ? 'flex' : 'none'}"><iconify-icon icon="lucide:pencil"></iconify-icon></button>
          <button class="btn-delete-card" title="Delete Campaign"  style="display:${initialIsDM ? 'flex' : 'none'}"><iconify-icon icon="lucide:trash-2"></iconify-icon></button>
        </div>
      `;

      card.addEventListener('click', () => enterCampaign(id, c));

      card.querySelector('.btn-invite-card').addEventListener('click', e => {
        e.stopPropagation();
        openInviteModal(id, c.name || 'Untitled Campaign');
      });
      card.querySelector('.btn-edit-card').addEventListener('click', e => {
        e.stopPropagation();
        openEditModal(id, card);
      });
      card.querySelector('.btn-delete-card').addEventListener('click', e => {
        e.stopPropagation();
        openDeleteConfirm(id, card);
      });

      // Live listener: keeps member count and role badge in sync with DB
      onValue(ref(db, `campaigns/${id}/members`), snap => {
        const members = snap.val() || {};
        const count   = Object.keys(members).length;
        const role    = members[session.id] || 'player';
        const isDM    = role === 'dm' || session.role === 'admin';

        const countEl = card.querySelector('.member-count-text');
        if (countEl) countEl.textContent = count + ' member' + (count !== 1 ? 's' : '');

        const badge = card.querySelector('.campaign-role-badge');
        if (badge) {
          badge.textContent  = isDM ? 'DM' : 'Player';
          badge.className    = 'campaign-role-badge ' + (isDM ? 'badge-dm' : 'badge-player');
        }

        const inviteBtn = card.querySelector('.btn-invite-card');
        if (inviteBtn) inviteBtn.style.display = isDM ? 'flex' : 'none';

        const editBtn = card.querySelector('.btn-edit-card');
        if (editBtn) editBtn.style.display = isDM ? 'flex' : 'none';

        const deleteBtn = card.querySelector('.btn-delete-card');
        if (deleteBtn) deleteBtn.style.display = isDM ? 'flex' : 'none';
      });

      return card;
    }

    function enterCampaign(id, c) {
      const s = getSession();
      if (s) {
        s.campaignId   = id;
        s.campaignName = c.name || 'Campaign';
        localStorage.setItem('playerSession', JSON.stringify(s));
      }
      window.location.href = 'inventory';
    }

    function updateCount() {
      const count = grid.children.length;
      toolbarLabel.textContent = count + ' campaign' + (count !== 1 ? 's' : '');
    }

    const modalOverlay = document.getElementById('modal-add');
    const modalError   = document.getElementById('modal-error');

    function openAddModal() {
      document.getElementById('c-name').value  = '';
      document.getElementById('c-world').value = '';
      document.getElementById('c-desc').value  = '';
      modalError.classList.remove('show');
      modalOverlay.classList.add('open');
      setTimeout(() => document.getElementById('c-name').focus(), 80);
    }
    function closeAddModal() { modalOverlay.classList.remove('open'); }

    document.getElementById('btn-add-campaign').addEventListener('click', openAddModal);
    document.getElementById('btn-add-empty').addEventListener('click', openAddModal);
    document.getElementById('modal-close').addEventListener('click', closeAddModal);
    document.getElementById('btn-cancel').addEventListener('click', closeAddModal);
    modalOverlay.addEventListener('click', e => { if (e.target === modalOverlay) closeAddModal(); });

    document.getElementById('btn-create-campaign').addEventListener('click', async () => {
      const name  = document.getElementById('c-name').value.trim();
      const world = document.getElementById('c-world').value.trim();
      const desc  = document.getElementById('c-desc').value.trim();

      if (!name) {
        modalError.textContent = 'Campaign name is required.';
        modalError.classList.add('show');
        return;
      }

      const btn = document.getElementById('btn-create-campaign');
      btn.disabled = true;
      btn.innerHTML = '<iconify-icon icon="lucide:loader-2"></iconify-icon> Creating…';

      try {
        const newRef = push(ref(db, 'campaigns'));
        const data = {
          name,
          createdBy: session.id,
          createdAt: Date.now(),
          members: { [session.id]: 'dm' }
        };
        if (world) data.world = world;
        if (desc)  data.description = desc;

        await set(newRef, data);
        closeAddModal();

        const id = newRef.key;
        stateEmpty.style.display = 'none';
        stateCampaigns.style.display = 'block';
        grid.appendChild(buildCard(id, data));
        bindShimmer();
        updateCount();
      } catch (e) {
        modalError.textContent = 'Failed to create campaign. Try again.';
        modalError.classList.add('show');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<iconify-icon icon="lucide:plus"></iconify-icon> Create';
      }
    });

    function setupInviteListener() {
      const section = document.getElementById('invite-section');
      const list    = document.getElementById('invite-list');

      onValue(ref(db, `users/${session.id}/invites`), snapshot => {
        list.innerHTML = '';
        if (!snapshot.exists()) { section.style.display = 'none'; return; }

        const entries = Object.entries(snapshot.val() || {});
        if (!entries.length) { section.style.display = 'none'; return; }

        section.style.display = 'block';
        entries.forEach(([invId, inv]) => {
          const card = document.createElement('div');
          card.className = 'invite-card';
          card.innerHTML = `
            <div class="invite-info">
              <div class="invite-campaign-name">${escHtml(inv.campaignName || 'Campaign')}</div>
              <div class="invite-from">Invited by ${escHtml(inv.invitedByName || 'a DM')}</div>
            </div>
            <div class="invite-actions">
              <button class="btn-accept">Accept</button>
              <button class="btn-decline">Decline</button>
            </div>
          `;
          card.querySelector('.btn-accept').addEventListener('click', () => acceptInvite(invId, inv, card));
          card.querySelector('.btn-decline').addEventListener('click', () => declineInvite(invId, card));
          list.appendChild(card);
        });
      });
    }

    async function acceptInvite(invId, inv, card) {
      const acceptBtn  = card.querySelector('.btn-accept');
      const declineBtn = card.querySelector('.btn-decline');
      acceptBtn.disabled  = true;
      declineBtn.disabled = true;
      acceptBtn.textContent = '…';

      try {
        await set(ref(db, `campaigns/${inv.campaignId}/members/${session.id}`), 'player');
        await remove(ref(db, `users/${session.id}/invites/${invId}`));

        const snap = await get(ref(db, `campaigns/${inv.campaignId}`));
        const c = snap.val();
        if (c) {
          stateEmpty.style.display = 'none';
          stateCampaigns.style.display = 'block';
          grid.appendChild(buildCard(inv.campaignId, c));
          bindShimmer();
          updateCount();
        }

        // onValue listener handles list update automatically
      } catch (e) {
        acceptBtn.disabled  = false;
        declineBtn.disabled = false;
        acceptBtn.textContent = 'Accept';
      }
    }

    async function declineInvite(invId, card) {
      try {
        await remove(ref(db, `users/${session.id}/invites/${invId}`));
        // onValue listener handles list update automatically
      } catch (e) { /* ignore */ }
    }

    let activeCampaignId   = null;
    let activeCampaignName = null;

    function openInviteModal(campaignId, campaignName) {
      activeCampaignId   = campaignId;
      activeCampaignName = campaignName;

      document.querySelectorAll('#modal-invite .modal-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('#modal-invite .modal-tab-content').forEach(c => c.classList.remove('active'));
      document.querySelector('#modal-invite .modal-tab[data-tab="username"]').classList.add('active');
      document.getElementById('tab-username').classList.add('active');

      document.getElementById('invite-username').value = '';
      document.getElementById('invite-feedback').textContent = '';
      document.getElementById('invite-feedback').style.color = '';

      document.getElementById('modal-invite').classList.add('open');
      setTimeout(() => document.getElementById('invite-username').focus(), 80);
    }

    function closeInviteModal() {
      document.getElementById('modal-invite').classList.remove('open');
    }

    document.getElementById('invite-modal-close').addEventListener('click', closeInviteModal);
    document.getElementById('modal-invite').addEventListener('click', e => {
      if (e.target === document.getElementById('modal-invite')) closeInviteModal();
    });

    document.querySelectorAll('#modal-invite .modal-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('#modal-invite .modal-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('#modal-invite .modal-tab-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        const contentId = 'tab-' + tab.dataset.tab;
        document.getElementById(contentId).classList.add('active');

        if (tab.dataset.tab === 'code') loadInviteCode(activeCampaignId);
      });
    });

    document.getElementById('btn-send-invite').addEventListener('click', sendUsernameInvite);
    document.getElementById('invite-username').addEventListener('keydown', e => {
      if (e.key === 'Enter') sendUsernameInvite();
    });

    async function sendUsernameInvite() {
      const username = document.getElementById('invite-username').value.trim();
      const feedback = document.getElementById('invite-feedback');
      const btn      = document.getElementById('btn-send-invite');

      feedback.textContent = '';
      if (!username) return;

      btn.disabled = true;

      try {
        const snap = await get(query(ref(db, 'users'), orderByChild('username'), equalTo(username)));

        if (!snap.exists()) {
          setFeedback(feedback, 'No player found with that username.', '#e07070');
          return;
        }

        const entries = Object.entries(snap.val());
        const [uid]   = entries[0];

        if (uid === session.id) {
          setFeedback(feedback, "You can't invite yourself.", '#e07070');
          return;
        }

        const memberSnap = await get(ref(db, `campaigns/${activeCampaignId}/members/${uid}`));
        if (memberSnap.exists()) {
          setFeedback(feedback, `${escHtml(username)} is already in this campaign.`, '#e07070');
          return;
        }

        const inviteRef = push(ref(db, `users/${uid}/invites`));
        await set(inviteRef, {
          campaignId:    activeCampaignId,
          campaignName:  activeCampaignName,
          invitedByName: session.username,
          createdAt:     Date.now()
        });

        setFeedback(feedback, `Invite sent to ${escHtml(username)}!`, '#70b890');
        document.getElementById('invite-username').value = '';
      } catch (e) {
        setFeedback(feedback, 'Failed to send invite. Please try again.', '#e07070');
      } finally {
        btn.disabled = false;
      }
    }

    function setFeedback(el, msg, color) {
      el.textContent = msg;
      el.style.color = color;
    }

    async function loadInviteCode(campaignId) {
      const area = document.getElementById('code-display-area');
      area.innerHTML = '<span style="color:#555;font-size:13px">Loading…</span>';
      try {
        const snap = await get(ref(db, `campaigns/${campaignId}/inviteCode`));
        renderCodeArea(area, campaignId, snap.val());
      } catch (e) {
        area.innerHTML = '<span style="color:#e07070;font-size:13px">Failed to load code.</span>';
      }
    }

    function renderCodeArea(area, campaignId, code) {
      if (code) {
        area.innerHTML = `
          <p class="code-hint">Share this code with players. They can use it on the campaign selector to join.</p>
          <div class="code-block">
            <span class="code-text" id="code-value">${escHtml(code)}</span>
            <button class="btn-copy" id="btn-copy-code">Copy</button>
          </div>
          <button class="btn-regen" id="btn-regen-code">↺ Regenerate Code</button>
        `;
        document.getElementById('btn-copy-code').addEventListener('click', () => {
          navigator.clipboard.writeText(code).then(() => {
            const copyBtn = document.getElementById('btn-copy-code');
            if (copyBtn) { copyBtn.textContent = 'Copied!'; setTimeout(() => { if (copyBtn) copyBtn.textContent = 'Copy'; }, 2000); }
          }).catch(() => {});
        });
        document.getElementById('btn-regen-code').addEventListener('click', () => generateCode(area, campaignId));
      } else {
        area.innerHTML = `
          <p class="code-hint">Generate a unique code to share with your players.</p>
          <button class="btn-gen-code" id="btn-gen-code">Generate Invite Code</button>
        `;
        document.getElementById('btn-gen-code').addEventListener('click', () => generateCode(area, campaignId));
      }
    }

    async function generateCode(area, campaignId) {
      const code = randomCode();
      try {
        await set(ref(db, `campaigns/${campaignId}/inviteCode`), code);
        renderCodeArea(area, campaignId, code);
      } catch (e) {
        area.innerHTML += '<p style="color:#e07070;font-size:13px;margin-top:8px">Failed to save code. Try again.</p>';
      }
    }

    function randomCode() {
      const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      const part  = () => Array.from({length: 4}, () => chars[Math.floor(Math.random() * chars.length)]).join('');
      return part() + '-' + part();
    }

    document.getElementById('btn-join-code').addEventListener('click', () => {
      document.getElementById('join-code-input').value = '';
      document.getElementById('join-error').classList.remove('show');
      document.getElementById('modal-join').classList.add('open');
      setTimeout(() => document.getElementById('join-code-input').focus(), 80);
    });
    document.getElementById('join-modal-close').addEventListener('click', () => closeJoinModal());
    document.getElementById('join-cancel').addEventListener('click',      () => closeJoinModal());
    document.getElementById('modal-join').addEventListener('click', e => {
      if (e.target === document.getElementById('modal-join')) closeJoinModal();
    });
    document.getElementById('join-code-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') submitJoinCode();
    });
    document.getElementById('btn-join-submit').addEventListener('click', submitJoinCode);

    function closeJoinModal() { document.getElementById('modal-join').classList.remove('open'); }

    async function submitJoinCode() {
      const code    = document.getElementById('join-code-input').value.trim().toUpperCase();
      const joinErr = document.getElementById('join-error');
      const btn     = document.getElementById('btn-join-submit');

      joinErr.classList.remove('show');
      if (!code) return;

      btn.disabled = true;
      btn.innerHTML = '<iconify-icon icon="lucide:loader-2"></iconify-icon> Joining…';

      try {
        const snap = await get(query(ref(db, 'campaigns'), orderByChild('inviteCode'), equalTo(code)));

        if (!snap.exists()) {
          joinErr.textContent = 'Invalid invite code. Check with your DM and try again.';
          joinErr.classList.add('show');
          return;
        }

        const [id, c] = Object.entries(snap.val())[0];

        if (c.members && c.members[session.id]) {
          joinErr.textContent = "You're already a member of this campaign.";
          joinErr.classList.add('show');
          return;
        }

        await set(ref(db, `campaigns/${id}/members/${session.id}`), 'player');

        const fullSnap = await get(ref(db, `campaigns/${id}`));
        const fullC    = fullSnap.val();

        closeJoinModal();
        stateEmpty.style.display = 'none';
        stateCampaigns.style.display = 'block';
        grid.appendChild(buildCard(id, fullC));
        bindShimmer();
        updateCount();
      } catch (e) {
        joinErr.textContent = 'Failed to join. Please try again.';
        joinErr.classList.add('show');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<iconify-icon icon="lucide:log-in"></iconify-icon> Join';
      }
    }

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function bindShimmer() {
      grid.querySelectorAll('.campaign-card').forEach(card => {
        if (card._shimmer) return;
        card._shimmer = true;
        card.addEventListener('mousemove', e => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--shine-x', ((e.clientX - r.left) / r.width  * 100) + '%');
          card.style.setProperty('--shine-y', ((e.clientY - r.top)  / r.height * 100) + '%');
        });
      });
    }

    // ── Edit Campaign ────────────────────────────────────────────
    let editTargetId   = null;
    let editTargetCard = null;

    function openEditModal(id, card) {
      editTargetId   = id;
      editTargetCard = card;
      document.getElementById('e-name').value  = card.dataset.campaignName  || '';
      document.getElementById('e-world').value = card.dataset.campaignWorld || '';
      document.getElementById('e-desc').value  = card.dataset.campaignDesc  || '';
      document.getElementById('edit-modal-error').classList.remove('show');
      document.getElementById('modal-edit').classList.add('open');
      setTimeout(() => document.getElementById('e-name').focus(), 80);
    }

    function closeEditModal() { document.getElementById('modal-edit').classList.remove('open'); }

    document.getElementById('edit-modal-close').addEventListener('click', closeEditModal);
    document.getElementById('edit-cancel').addEventListener('click', closeEditModal);
    document.getElementById('modal-edit').addEventListener('click', e => {
      if (e.target === document.getElementById('modal-edit')) closeEditModal();
    });

    document.getElementById('btn-save-edit').addEventListener('click', async () => {
      const name  = document.getElementById('e-name').value.trim();
      const world = document.getElementById('e-world').value.trim();
      const desc  = document.getElementById('e-desc').value.trim();
      const errEl = document.getElementById('edit-modal-error');

      if (!name) {
        errEl.textContent = 'Campaign name is required.';
        errEl.classList.add('show');
        return;
      }

      const btn = document.getElementById('btn-save-edit');
      btn.disabled = true;
      btn.innerHTML = '<iconify-icon icon="lucide:loader-2"></iconify-icon> Saving…';

      try {
        await update(ref(db, `campaigns/${editTargetId}`), {
          name,
          world:       world || null,
          description: desc  || null,
        });

        if (editTargetCard) {
          editTargetCard.querySelector('.campaign-name').textContent = name;
          editTargetCard.dataset.campaignName  = name;

          const worldEl = editTargetCard.querySelector('.campaign-world');
          if (worldEl) { worldEl.textContent = world; worldEl.style.display = world ? 'inline' : 'none'; }
          editTargetCard.dataset.campaignWorld = world;

          const descEl = editTargetCard.querySelector('.campaign-desc');
          if (descEl) { descEl.textContent = desc; descEl.style.display = desc ? 'block' : 'none'; }
          editTargetCard.dataset.campaignDesc = desc;
        }

        closeEditModal();
      } catch (e) {
        errEl.textContent = 'Failed to save. Please try again.';
        errEl.classList.add('show');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<iconify-icon icon="lucide:save"></iconify-icon> Save';
      }
    });

    // ── Delete Campaign ──────────────────────────────────────────
    let deleteTargetId   = null;
    let deleteTargetCard = null;

    function openDeleteConfirm(id, card) {
      deleteTargetId   = id;
      deleteTargetCard = card;
      document.getElementById('delete-campaign-name').textContent = card.dataset.campaignName || 'this campaign';
      document.getElementById('modal-delete').classList.add('open');
    }

    function closeDeleteModal() { document.getElementById('modal-delete').classList.remove('open'); }

    document.getElementById('delete-modal-close').addEventListener('click', closeDeleteModal);
    document.getElementById('delete-cancel').addEventListener('click', closeDeleteModal);
    document.getElementById('modal-delete').addEventListener('click', e => {
      if (e.target === document.getElementById('modal-delete')) closeDeleteModal();
    });

    document.getElementById('btn-confirm-delete').addEventListener('click', async () => {
      const btn = document.getElementById('btn-confirm-delete');
      btn.disabled = true;
      btn.textContent = 'Deleting…';

      try {
        await remove(ref(db, `campaigns/${deleteTargetId}`));
        if (deleteTargetCard) deleteTargetCard.remove();
        updateCount();
        if (grid.children.length === 0) {
          stateCampaigns.style.display = 'none';
          stateEmpty.style.display = 'block';
        }
        closeDeleteModal();
      } catch (e) {
        btn.disabled = false;
        btn.textContent = 'Delete Campaign';
      }
    });

    onAuthStateChanged(auth, user => {
      if (user) {
        loadCampaigns();
        setupInviteListener();
      } else {
        clearSession();
        window.location.href = "login";
      }
    });
  </script>
</Layout>
