    .setting-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .setting-title { font-size: 13.5px; color: var(--text); font-family: var(--font); }
    .setting-desc { font-size: 11.5px; color: #7a7468; line-height: 1.4; }

    @media (max-width: 700px) {
      .hero { padding: 26px 20px 22px; }
      .main { padding: 24px 16px 48px; }
      .campaign-grid { grid-template-columns: 1fr; }

      /* Image becomes the full card background with a dark gradient so the
         text + buttons stay readable */
      .campaign-card { height: 188px; }
      .campaign-card-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border-radius: 12px;
        border-right: none;
      }
      .campaign-card-img::before {
        background: linear-gradient(to top,
          rgba(0,0,0,0.92) 0%,
          rgba(0,0,0,0.78) 30%,
          rgba(0,0,0,0.45) 65%,
          rgba(0,0,0,0.35) 100%);
