  <script is:inline type="module">
    import { db, auth }                                              from "/assets/js/firebase.js";
    import { ref, get, set, push, remove, update, query,
             orderByChild, equalTo, onValue }                        from "https://www.gstatic.com/firebasejs/10.14.1/firebase-database.js";
    import { onAuthStateChanged }                                    from "https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js";
    import { getSession, clearSession }                              from "/assets/js/auth.js";
    import { buildDefaultClimates }                                  from "/assets/js/default-climates.js";
    import { STORAGE_LIMITS, assertCanStore,
             uploadImageToStorage, deleteStorageObject, QuotaError }  from "/assets/js/storage-quota.js";

    const session = getSession();
    if (!session) { window.location.href = "login"; }

    // ── Image helpers ────────────────────────────────────────────
    let pendingAddImage   = null;
    let pendingEditImage  = null;

    function readImageFile(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload  = e => resolve(e.target.result);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    // Compress to a JPEG Blob (covers now live in Firebase Storage, not as
    // base64 in the DB, so the metering Cloud Function can account for them).
    async function compressImageToBlob(dataUrl, maxSize = 400) {
      return new Promise(resolve => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          const scale  = Math.min(1, maxSize / Math.max(img.width, img.height));
          canvas.width  = img.width  * scale;
          canvas.height = img.height * scale;
          canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
          canvas.toBlob(b => resolve(b), 'image/jpeg', 0.78);
        };
        img.src = dataUrl;
      });
    }

    document.getElementById('c-img').addEventListener('change', async e => {
      const file = e.target.files[0];
      if (!file) return;
      const raw        = await readImageFile(file);
      pendingAddImage  = await compressImageToBlob(raw);
      const label      = document.getElementById('c-img-label');
      const hint       = document.getElementById('c-img-hint');
      label.classList.add('has-image');
      hint.textContent = file.name;
    });

    document.getElementById('e-img').addEventListener('change', async e => {
      const file = e.target.files[0];
      if (!file) return;
      const raw        = await readImageFile(file);
      pendingEditImage = await compressImageToBlob(raw);
      const label      = document.getElementById('e-img-label');
      const hint       = document.getElementById('e-img-hint');
      label.classList.add('has-image');
      hint.textContent = file.name;
    });

    const stateLoading   = document.getElementById('state-loading');
    const stateEmpty     = document.getElementById('state-empty');
    const stateCampaigns = document.getElementById('state-campaigns');
    const grid           = document.getElementById('campaign-grid');
    const countBadge     = document.getElementById('toolbar-count');

    async function loadCampaigns() {
      try {
        const snap = await get(ref(db, 'campaigns'));
        const all  = snap.val() || {};

        const dayMs = 24 * 60 * 60 * 1000;
        const now   = Date.now();
        Object.entries(all).forEach(([id, c]) => {
          const memberCount = Object.keys(c.members || {}).length;
          if (memberCount === 0 && c.createdAt && (now - c.createdAt) > dayMs) {
            remove(ref(db, `campaigns/${id}`)).catch(() => {});
          }
        });

        const mine = Object.entries(all).filter(([, c]) =>
          c.members && c.members[session.id]
        );

        stateLoading.style.display = 'none';

        if (mine.length === 0) {
          stateEmpty.style.display = 'block';
          return;
        }

        countBadge.textContent    = mine.length;
        countBadge.style.display  = '';
        stateCampaigns.style.display = 'block';
        mine.forEach(([id, c]) => grid.appendChild(buildCard(id, c)));
        bindShimmer();
      } catch (e) {
        console.error('loadCampaigns failed:', e);
        stateLoading.style.display = 'none';
        stateEmpty.style.display   = 'block';
      }
    }

    function buildCard(id, c) {
      const initialRole  = c.members?.[session.id] || 'player';
      const initialCount = Object.keys(c.members || {}).length;
      const initialIsDM  = initialRole === 'dm';

      const card = document.createElement('div');
      card.className = 'campaign-card';
      card.dataset.campaignId    = id;
      card.dataset.campaignName  = c.name        || '';
      card.dataset.campaignWorld = c.world       || '';
      card.dataset.campaignDesc  = c.description || '';
      card.dataset.campaignImage = c.imageUrl    || '';
      card.dataset.campaignStoragePath = c.imageStoragePath || '';
      card.dataset.campaignSettings = JSON.stringify(c.settings || {});

      const imgStyle = c.imageUrl
        ? `background-image:url('${escAttr(c.imageUrl)}')`
        : '';
      const imgClass = c.imageUrl ? 'campaign-card-img' : 'campaign-card-img no-image';

      card.innerHTML = `
        <div class="${imgClass}" style="${imgStyle}"></div>
        <div class="campaign-card-body">
          <div class="campaign-card-header">
            <span class="campaign-name">${escHtml(c.name || 'Untitled Campaign')}</span>
            <span class="campaign-role-badge ${initialIsDM ? 'badge-dm' : 'badge-player'}">${initialIsDM ? 'DM' : 'Player'}</span>
          </div>
          ${c.world       ? `<span class="campaign-world">${escHtml(c.world)}</span>` : ''}
          ${c.description ? `<p class="campaign-desc">${escHtml(c.description)}</p>` : ''}
          <div class="campaign-meta">
            <span class="campaign-meta-item">
              <iconify-icon icon="lucide:users" style="font-size:12px"></iconify-icon>
              <span class="member-count-text">${initialCount} member${initialCount !== 1 ? 's' : ''}</span>
            </span>
            ${c.createdAt ? `<span class="campaign-meta-item">
              <iconify-icon icon="lucide:calendar" style="font-size:12px"></iconify-icon>
              ${new Date(c.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>` : ''}
          </div>
          <div class="campaign-card-actions" style="display:${initialIsDM ? 'flex' : 'none'}">
            <button class="card-action-btn btn-invite-card" title="Invite Players"><iconify-icon icon="lucide:user-plus"></iconify-icon></button>
            <button class="card-action-btn btn-edit-card"   title="Edit Campaign"><iconify-icon icon="lucide:pencil"></iconify-icon></button>
            <button class="card-action-btn danger btn-delete-card" title="Delete Campaign"><iconify-icon icon="lucide:trash-2"></iconify-icon></button>
          </div>
        </div>
      `;

      card.addEventListener('click', () => enterCampaign(id, c));

      card.querySelector('.btn-invite-card').addEventListener('click', e => { e.stopPropagation(); openInviteModal(id, c.name || 'Untitled Campaign'); });
      card.querySelector('.btn-edit-card').addEventListener('click',   e => { e.stopPropagation(); openEditModal(id, card); });
      card.querySelector('.btn-delete-card').addEventListener('click', e => { e.stopPropagation(); openDeleteConfirm(id, card); });

      onValue(ref(db, `campaigns/${id}/members`), snap => {
        const members = snap.val() || {};
        const count   = Object.keys(members).length;
        const role    = members[session.id] || 'player';
        const isDM    = role === 'dm';

        const countEl = card.querySelector('.member-count-text');
        if (countEl) countEl.textContent = count + ' member' + (count !== 1 ? 's' : '');

        const badge = card.querySelector('.campaign-role-badge');
        if (badge) { badge.textContent = isDM ? 'DM' : 'Player'; badge.className = 'campaign-role-badge ' + (isDM ? 'badge-dm' : 'badge-player'); }

        const actions = card.querySelector('.campaign-card-actions');
        if (actions) actions.style.display = isDM ? 'flex' : 'none';
      });

      return card;
    }

    function enterCampaign(id, c) {
      const s = getSession();
      if (s) {
        s.campaignId   = id;
        s.campaignName = c.name || 'Campaign';
        // DM powers are per-campaign: a user is DM only of campaigns where their
        // membership role is 'dm' (the creator). Everyone else — global admins
        // included — enters as a plain player. Pages read session.campaignRole.
        s.campaignRole = (c.members && c.members[s.id]) || 'player';
        localStorage.setItem('playerSession', JSON.stringify(s));
      }
      window.location.href = 'inventory';
    }

    function updateCount() {
      const count = grid.children.length;
      countBadge.textContent   = count;
      countBadge.style.display = count > 0 ? '' : 'none';
    }

    // ── Add modal ────────────────────────────────────────────────
    const modalOverlay = document.getElementById('modal-add');
    const modalError   = document.getElementById('modal-error');

    function openAddModal() {
      document.getElementById('c-name').value  = '';
      document.getElementById('c-world').value = '';
      document.getElementById('c-desc').value  = '';
      document.getElementById('c-img').value   = '';
      document.getElementById('c-img-label').classList.remove('has-image');
      document.getElementById('c-img-hint').textContent = 'Click to upload an image';
      document.getElementById('c-set-attunement').checked = true;
      document.getElementById('c-set-weight').checked     = false;
      pendingAddImage = null;
      modalError.classList.remove('show');
      modalOverlay.classList.add('open');
      setTimeout(() => document.getElementById('c-name').focus(), 80);
    }
    function closeAddModal() { modalOverlay.classList.remove('open'); }

    document.getElementById('btn-add-campaign').addEventListener('click',   openAddModal);
    document.getElementById('btn-add-empty').addEventListener('click',      openAddModal);
    document.getElementById('btn-create-new-row').addEventListener('click', openAddModal);
    document.getElementById('modal-close').addEventListener('click',      closeAddModal);
    document.getElementById('btn-cancel').addEventListener('click',       closeAddModal);
    modalOverlay.addEventListener('click', e => { if (e.target === modalOverlay) closeAddModal(); });

    document.getElementById('btn-create-campaign').addEventListener('click', async () => {
      const name  = document.getElementById('c-name').value.trim();
      const world = document.getElementById('c-world').value.trim();
      const desc  = document.getElementById('c-desc').value.trim();

      if (!name) { modalError.textContent = 'Campaign name is required.'; modalError.classList.add('show'); return; }

      const btn = document.getElementById('btn-create-campaign');

      // Storage quota check before we commit anything.
      if (pendingAddImage) {
        try { await assertCanStore(session.id, pendingAddImage.size, STORAGE_LIMITS.image); }
        catch (e) {
          if (e instanceof QuotaError) { modalError.textContent = e.message; modalError.classList.add('show'); return; }
          throw e;
        }
      }

      btn.disabled = true;
      btn.innerHTML = '<iconify-icon icon="lucide:loader-2"></iconify-icon> Creating…';

      try {
        const newRef = push(ref(db, 'campaigns'));
        const id = newRef.key;
        const data = { name, createdBy: session.id, createdAt: Date.now(), members: { [session.id]: 'dm' } };
        if (world) data.world       = world;
        if (desc)  data.description = desc;
        // Upload the cover to Storage; the metering trigger counts it against
        // the owner's quota (no client accrueUsage for Storage uploads).
        if (pendingAddImage) {
          const up = await uploadImageToStorage({ blob: pendingAddImage, path: `campaigns/${id}/cover/${Date.now()}.jpg`, ownerId: session.id });
          data.imageUrl         = up.url;
          data.imageStoragePath = up.path;
        }
        data.settings = {
          useAttunement: document.getElementById('c-set-attunement').checked,
          useWeight:     document.getElementById('c-set-weight').checked,
        };
        data.climates      = buildDefaultClimates();
        data.climatesSeeded = true;

        await set(newRef, data);
        closeAddModal();
        stateEmpty.style.display     = 'none';
        stateCampaigns.style.display = 'block';
        grid.appendChild(buildCard(id, data));
        bindShimmer();
        updateCount();
      } catch (e) {
        modalError.textContent = 'Failed to create campaign. Try again.';
        modalError.classList.add('show');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<iconify-icon icon="lucide:plus"></iconify-icon> Create';
      }
    });

    // ── Invite listener ──────────────────────────────────────────
    function setupInviteListener() {
      const section = document.getElementById('invite-section');
      const list    = document.getElementById('invite-list');

      onValue(ref(db, `users/${session.id}/invites`), snapshot => {
        list.innerHTML = '';
        if (!snapshot.exists()) { section.style.display = 'none'; return; }
        const entries = Object.entries(snapshot.val() || {});
        if (!entries.length) { section.style.display = 'none'; return; }
        section.style.display = 'block';
        entries.forEach(([invId, inv]) => {
          const card = document.createElement('div');
          card.className = 'invite-card';
          card.innerHTML = `
            <div class="invite-info">
              <div class="invite-campaign-name">${escHtml(inv.campaignName || 'Campaign')}</div>
              <div class="invite-from">Invited by ${escHtml(inv.invitedByName || 'a DM')}</div>
            </div>
            <div class="invite-actions">
              <button class="btn-accept">Accept</button>
              <button class="btn-decline">Decline</button>
            </div>
          `;
          card.querySelector('.btn-accept').addEventListener('click',  () => acceptInvite(invId, inv, card));
          card.querySelector('.btn-decline').addEventListener('click', () => declineInvite(invId));
          list.appendChild(card);
        });
      });
    }

    async function acceptInvite(invId, inv, card) {
      const acceptBtn  = card.querySelector('.btn-accept');
      const declineBtn = card.querySelector('.btn-decline');
      acceptBtn.disabled = declineBtn.disabled = true;
      acceptBtn.textContent = '…';
      try {
        await set(ref(db, `campaigns/${inv.campaignId}/members/${session.id}`), 'player');
        await remove(ref(db, `users/${session.id}/invites/${invId}`));
        const snap = await get(ref(db, `campaigns/${inv.campaignId}`));
        const c = snap.val();
        if (c) {
          stateEmpty.style.display     = 'none';
          stateCampaigns.style.display = 'block';
          grid.appendChild(buildCard(inv.campaignId, c));
          bindShimmer();
          updateCount();
        }
      } catch (e) {
        acceptBtn.disabled = declineBtn.disabled = false;
        acceptBtn.textContent = 'Accept';
      }
    }

    async function declineInvite(invId) {
      try { await remove(ref(db, `users/${session.id}/invites/${invId}`)); } catch (e) {}
    }

    // ── Invite modal ─────────────────────────────────────────────
    let activeCampaignId = null, activeCampaignName = null;

    function openInviteModal(campaignId, campaignName) {
      activeCampaignId = campaignId; activeCampaignName = campaignName;
      document.querySelectorAll('#modal-invite .modal-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('#modal-invite .modal-tab-content').forEach(c => c.classList.remove('active'));
      document.querySelector('#modal-invite .modal-tab[data-tab="username"]').classList.add('active');
      document.getElementById('tab-username').classList.add('active');
      document.getElementById('invite-username').value = '';
      document.getElementById('invite-feedback').textContent = '';
      document.getElementById('invite-feedback').style.color = '';
      document.getElementById('modal-invite').classList.add('open');
      setTimeout(() => document.getElementById('invite-username').focus(), 80);
    }

    function closeInviteModal() { document.getElementById('modal-invite').classList.remove('open'); }

    document.getElementById('invite-modal-close').addEventListener('click', closeInviteModal);
    document.getElementById('modal-invite').addEventListener('click', e => { if (e.target === document.getElementById('modal-invite')) closeInviteModal(); });

    document.querySelectorAll('#modal-invite .modal-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('#modal-invite .modal-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('#modal-invite .modal-tab-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
        if (tab.dataset.tab === 'code') loadInviteCode(activeCampaignId);
      });
    });

    document.getElementById('btn-send-invite').addEventListener('click', sendUsernameInvite);
    document.getElementById('invite-username').addEventListener('keydown', e => { if (e.key === 'Enter') sendUsernameInvite(); });

    async function sendUsernameInvite() {
      const raw      = document.getElementById('invite-username').value.trim();
      const feedback = document.getElementById('invite-feedback');
      const btn      = document.getElementById('btn-send-invite');
      feedback.textContent = '';
      if (!raw) return;

      const hashIdx = raw.lastIndexOf('#');
      if (hashIdx === -1) { setFeedback(feedback, 'Include the tag — e.g. adventurer#1234', '#e07070'); return; }
      const username = raw.slice(0, hashIdx).trim();
      const tag      = raw.slice(hashIdx + 1).trim();
      if (!username || !tag) { setFeedback(feedback, 'Invalid format. Use username#tag', '#e07070'); return; }

      btn.disabled = true;
      try {
        const snap = await get(query(ref(db, 'users'), orderByChild('username'), equalTo(username)));
        if (!snap.exists()) { setFeedback(feedback, 'No player found with that username and tag.', '#e07070'); return; }
        const match = Object.entries(snap.val()).find(([, u]) => u.tag === tag);
        if (!match) { setFeedback(feedback, 'No player found with that username and tag.', '#e07070'); return; }
        const [uid] = match;
        if (uid === session.id) { setFeedback(feedback, "You can't invite yourself.", '#e07070'); return; }
        const memberSnap = await get(ref(db, `campaigns/${activeCampaignId}/members/${uid}`));
        if (memberSnap.exists()) { setFeedback(feedback, `${escHtml(username)} is already in this campaign.`, '#e07070'); return; }
        const inviteRef = push(ref(db, `users/${uid}/invites`));
        await set(inviteRef, { campaignId: activeCampaignId, campaignName: activeCampaignName, invitedByName: session.username, createdAt: Date.now() });
        setFeedback(feedback, `Invite sent to ${escHtml(username)}#${escHtml(tag)}!`, '#70b890');
        document.getElementById('invite-username').value = '';
      } catch (e) {
        setFeedback(feedback, 'Failed to send invite. Please try again.', '#e07070');
      } finally { btn.disabled = false; }
    }

    function setFeedback(el, msg, color) { el.textContent = msg; el.style.color = color; }

    async function loadInviteCode(campaignId) {
      const area = document.getElementById('code-display-area');
      area.innerHTML = '<span style="color:#555;font-size:13px">Loading…</span>';
      try {
        const snap = await get(ref(db, `campaigns/${campaignId}/inviteCode`));
        renderCodeArea(area, campaignId, snap.val());
      } catch (e) { area.innerHTML = '<span style="color:#e07070;font-size:13px">Failed to load code.</span>'; }
    }

    function renderCodeArea(area, campaignId, code) {
      if (code) {
        area.innerHTML = `
          <p class="code-hint">Share this code with players. They can use it to join.</p>
          <div class="code-block">
            <span class="code-text" id="code-value">${escHtml(code)}</span>
            <button class="btn-copy" id="btn-copy-code">Copy</button>
          </div>
          <button class="btn-regen" id="btn-regen-code">↺ Regenerate</button>
        `;
        document.getElementById('btn-copy-code').addEventListener('click', () => {
          navigator.clipboard.writeText(code).then(() => {
            const b = document.getElementById('btn-copy-code');
            if (b) { b.textContent = 'Copied!'; setTimeout(() => { if (b) b.textContent = 'Copy'; }, 2000); }
          }).catch(() => {});
        });
        document.getElementById('btn-regen-code').addEventListener('click', () => generateCode(area, campaignId));
      } else {
        area.innerHTML = `
          <p class="code-hint">Generate a unique code to share with your players.</p>
          <button class="btn-gen-code" id="btn-gen-code">Generate Invite Code</button>
        `;
        document.getElementById('btn-gen-code').addEventListener('click', () => generateCode(area, campaignId));
      }
    }

    async function generateCode(area, campaignId) {
      const code = randomCode();
      try {
        await set(ref(db, `campaigns/${campaignId}/inviteCode`), code);
        renderCodeArea(area, campaignId, code);
      } catch (e) { area.innerHTML += '<p style="color:#e07070;font-size:13px;margin-top:8px">Failed to save. Try again.</p>'; }
    }

    function randomCode() {
      const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      const part  = () => Array.from({length: 4}, () => chars[Math.floor(Math.random() * chars.length)]).join('');
      return part() + '-' + part();
    }

    // ── Join by Code ─────────────────────────────────────────────
    document.getElementById('btn-join-code').addEventListener('click', () => {
      document.getElementById('join-code-input').value = '';
      document.getElementById('join-error').classList.remove('show');
      document.getElementById('modal-join').classList.add('open');
      setTimeout(() => document.getElementById('join-code-input').focus(), 80);
    });
    document.getElementById('join-modal-close').addEventListener('click', () => closeJoinModal());
    document.getElementById('join-cancel').addEventListener('click',      () => closeJoinModal());
    document.getElementById('modal-join').addEventListener('click', e => { if (e.target === document.getElementById('modal-join')) closeJoinModal(); });
    document.getElementById('join-code-input').addEventListener('keydown', e => { if (e.key === 'Enter') submitJoinCode(); });
    document.getElementById('btn-join-submit').addEventListener('click', submitJoinCode);

    function closeJoinModal() { document.getElementById('modal-join').classList.remove('open'); }

    async function submitJoinCode() {
      const code    = document.getElementById('join-code-input').value.trim().toUpperCase();
      const joinErr = document.getElementById('join-error');
      const btn     = document.getElementById('btn-join-submit');
      joinErr.classList.remove('show');
      if (!code) return;
      btn.disabled = true;
      btn.innerHTML = '<iconify-icon icon="lucide:loader-2"></iconify-icon> Joining…';
      try {
        const snap = await get(query(ref(db, 'campaigns'), orderByChild('inviteCode'), equalTo(code)));
        if (!snap.exists()) { joinErr.textContent = 'Invalid invite code. Check with your DM and try again.'; joinErr.classList.add('show'); return; }
        const [id, c] = Object.entries(snap.val())[0];
        if (c.members && c.members[session.id]) { joinErr.textContent = "You're already a member of this campaign."; joinErr.classList.add('show'); return; }
        await set(ref(db, `campaigns/${id}/members/${session.id}`), 'player');
        const fullSnap = await get(ref(db, `campaigns/${id}`));
        closeJoinModal();
        stateEmpty.style.display     = 'none';
        stateCampaigns.style.display = 'block';
        grid.appendChild(buildCard(id, fullSnap.val()));
        bindShimmer();
        updateCount();
      } catch (e) {
        joinErr.textContent = 'Failed to join. Please try again.';
        joinErr.classList.add('show');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<iconify-icon icon="lucide:log-in"></iconify-icon> Join';
      }
    }

    // ── Edit modal ───────────────────────────────────────────────
    let editTargetId = null, editTargetCard = null;

    function openEditModal(id, card) {
      editTargetId = id; editTargetCard = card;
      document.getElementById('e-name').value  = card.dataset.campaignName  || '';
      document.getElementById('e-world').value = card.dataset.campaignWorld || '';
      document.getElementById('e-desc').value  = card.dataset.campaignDesc  || '';
      document.getElementById('e-img').value   = '';
      let st = {};
      try { st = JSON.parse(card.dataset.campaignSettings || '{}'); } catch (_) {}
      document.getElementById('e-set-attunement').checked = st.useAttunement !== false; // default on
      document.getElementById('e-set-weight').checked     = st.useWeight === true;       // default off
      pendingEditImage = null;
      const eImgLabel = document.getElementById('e-img-label');
      const eImgHint  = document.getElementById('e-img-hint');
      if (card.dataset.campaignImage) {
        eImgLabel.classList.add('has-image');
        eImgHint.textContent = 'Image set — click to replace';
      } else {
        eImgLabel.classList.remove('has-image');
        eImgHint.textContent = 'Click to upload an image';
      }
      document.getElementById('edit-modal-error').classList.remove('show');
      document.getElementById('modal-edit').classList.add('open');
      setTimeout(() => document.getElementById('e-name').focus(), 80);
    }

    function closeEditModal() { document.getElementById('modal-edit').classList.remove('open'); }

    document.getElementById('edit-modal-close').addEventListener('click', closeEditModal);
    document.getElementById('edit-cancel').addEventListener('click',      closeEditModal);
    document.getElementById('modal-edit').addEventListener('click', e => { if (e.target === document.getElementById('modal-edit')) closeEditModal(); });

    document.getElementById('btn-save-edit').addEventListener('click', async () => {
      const name  = document.getElementById('e-name').value.trim();
      const world = document.getElementById('e-world').value.trim();
      const desc  = document.getElementById('e-desc').value.trim();
      const errEl = document.getElementById('edit-modal-error');
      if (!name) { errEl.textContent = 'Campaign name is required.'; errEl.classList.add('show'); return; }

      // Quota check for a replacement cover (the old one's bytes are released
      // when we delete its Storage object below).
      if (pendingEditImage) {
        try { await assertCanStore(session.id, pendingEditImage.size, STORAGE_LIMITS.image); }
        catch (e) {
          if (e instanceof QuotaError) { errEl.textContent = e.message; errEl.classList.add('show'); return; }
          throw e;
        }
      }

      const btn = document.getElementById('btn-save-edit');
      btn.disabled = true; btn.innerHTML = '<iconify-icon icon="lucide:loader-2"></iconify-icon> Saving…';
      try {
        const updates = { name, world: world || null, description: desc || null };
        let newImg = null;
        if (pendingEditImage) {
          const oldPath = editTargetCard?.dataset.campaignStoragePath || '';
          newImg = await uploadImageToStorage({ blob: pendingEditImage, path: `campaigns/${editTargetId}/cover/${Date.now()}.jpg`, ownerId: session.id });
          updates.imageUrl         = newImg.url;
          updates.imageStoragePath = newImg.path;
          if (oldPath && oldPath !== newImg.path) deleteStorageObject(oldPath); // releases old bytes via trigger
        }
        updates.settings = {
          useAttunement: document.getElementById('e-set-attunement').checked,
          useWeight:     document.getElementById('e-set-weight').checked,
        };
        await update(ref(db, `campaigns/${editTargetId}`), updates);
        if (editTargetCard) editTargetCard.dataset.campaignSettings = JSON.stringify(updates.settings);
        if (editTargetCard) {
          editTargetCard.querySelector('.campaign-name').textContent = name;
          editTargetCard.dataset.campaignName  = name;
          const worldEl = editTargetCard.querySelector('.campaign-world');
          if (worldEl) { worldEl.textContent = world; worldEl.style.display = world ? '' : 'none'; }
          editTargetCard.dataset.campaignWorld = world;
          const descEl = editTargetCard.querySelector('.campaign-desc');
          if (descEl) { descEl.textContent = desc; descEl.style.display = desc ? '' : 'none'; }
          editTargetCard.dataset.campaignDesc = desc;
          if (newImg) {
            const imgEl = editTargetCard.querySelector('.campaign-card-img');
            if (imgEl) {
              imgEl.style.backgroundImage = `url('${escAttr(newImg.url)}')`;
              imgEl.classList.remove('no-image');
            }
            editTargetCard.dataset.campaignImage       = newImg.url;
            editTargetCard.dataset.campaignStoragePath = newImg.path;
          }
        }
        closeEditModal();
      } catch (e) {
        errEl.textContent = 'Failed to save. Please try again.'; errEl.classList.add('show');
      } finally {
        btn.disabled = false; btn.innerHTML = '<iconify-icon icon="lucide:save"></iconify-icon> Save';
      }
    });

    // ── Delete modal ─────────────────────────────────────────────
    let deleteTargetId = null, deleteTargetCard = null;

    function openDeleteConfirm(id, card) {
      deleteTargetId = id; deleteTargetCard = card;
      document.getElementById('delete-campaign-name').textContent = card.dataset.campaignName || 'this campaign';
      document.getElementById('modal-delete').classList.add('open');
    }

    function closeDeleteModal() { document.getElementById('modal-delete').classList.remove('open'); }

    document.getElementById('delete-modal-close').addEventListener('click', closeDeleteModal);
    document.getElementById('delete-cancel').addEventListener('click',      closeDeleteModal);
    document.getElementById('modal-delete').addEventListener('click', e => { if (e.target === document.getElementById('modal-delete')) closeDeleteModal(); });

    document.getElementById('btn-confirm-delete').addEventListener('click', async () => {
      const btn = document.getElementById('btn-confirm-delete');
      btn.disabled = true; btn.textContent = 'Deleting…';
      const coverPath = deleteTargetCard?.dataset.campaignStoragePath || '';
      try {
        await remove(ref(db, `campaigns/${deleteTargetId}`));
        // Delete the cover object too; the trigger releases its bytes. (Other
        // images in this campaign are cleaned up by their own delete flows.)
        if (coverPath) deleteStorageObject(coverPath);
        if (deleteTargetCard) deleteTargetCard.remove();
        updateCount();
        if (grid.children.length === 0) { stateCampaigns.style.display = 'none'; stateEmpty.style.display = 'block'; }
        closeDeleteModal();
      } catch (e) { btn.disabled = false; btn.textContent = 'Delete Campaign'; }
    });

    // ── Utilities ────────────────────────────────────────────────
    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function escAttr(str) {
      return String(str).replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function bindShimmer() {
      grid.querySelectorAll('.campaign-card').forEach(card => {
        if (card._shimmer) return;
        card._shimmer = true;
        card.addEventListener('mousemove', e => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--shine-x', ((e.clientX - r.left) / r.width  * 100) + '%');
          card.style.setProperty('--shine-y', ((e.clientY - r.top)  / r.height * 100) + '%');
        });
      });
    }

    onAuthStateChanged(auth, user => {
      if (user) {
        loadCampaigns();
        setupInviteListener();
      } else {
        clearSession();
        window.location.href = "login";
      }
    });
  </script>
</Layout>
