---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Interactive Map" showCampaignTabs={true} activePage="map" extraCSS={['/assets/css/map.css']} bodyClass="map-page">

  <div id="map-container">
    <div id="map-wrapper">
      <img id="map-image" src="" alt="Map" style="display:none">
      <div id="marker-layer"></div>
    </div>

    <!-- Map empty state (shown when no maps have been uploaded yet) -->
    <div id="map-empty-state" class="map-empty-state" style="display:none">
      <div id="map-empty-dm">
        <iconify-icon icon="lucide:image-plus" class="map-empty-icon"></iconify-icon>
        <h2 class="map-empty-title">No Map Yet</h2>
        <p class="map-empty-sub">Upload a map image to get this campaign started</p>
        <label id="map-empty-upload-btn" class="dm-btn" style="position:relative;overflow:hidden;cursor:pointer">
          <iconify-icon icon="lucide:upload" style="margin-right:6px"></iconify-icon>Upload Map
          <input type="file" id="maps-file-input-empty" accept="image/*"
                 style="position:absolute;inset:0;opacity:0;width:100%;height:100%;cursor:pointer">
        </label>
      </div>
      <div id="map-empty-player">
        <iconify-icon icon="lucide:map" class="map-empty-icon map-empty-icon-dim"></iconify-icon>
        <h2 class="map-empty-title map-empty-title-dim">No Map Yet</h2>
        <p class="map-empty-sub map-empty-sub-dim">Your DM hasn't uploaded a map for this campaign yet.</p>
      </div>
    </div>

    <!-- DM Toolbar -->
    <div id="dm-toolbar">
      <span class="dm-label">DM Tools</span>
      <button id="btn-place-marker" class="dm-btn">Place Marker</button>
      <label id="btn-upload-map" class="dm-btn" style="position:relative;overflow:hidden;cursor:pointer">
        <iconify-icon icon="lucide:image-up" style="font-size:14px;margin-right:5px"></iconify-icon>Upload Map
        <input type="file" id="maps-file-input-toolbar" accept="image/*"
               style="position:absolute;inset:0;opacity:0;width:100%;height:100%;cursor:pointer">
      </label>
    </div>

    <!-- Location panel open button -->
    <button id="lp-open-btn" class="lp-open-btn">
      <iconify-icon icon="lucide:map-pin"></iconify-icon> Locations
    </button>

    <!-- Maps gallery button (all users) -->
    <button id="maps-btn" class="maps-open-btn">
      <iconify-icon icon="lucide:image"></iconify-icon> Maps
    </button>

    <!-- Location panel -->
    <div id="location-panel" class="location-panel">
      <div class="lp-resize-handle" id="lp-resize-handle"></div>
      <div class="lp-header">
        <span class="lp-title">Locations</span>
        <div class="lp-header-actions">
          <button id="lp-add-country-btn" class="lp-hdr-btn" style="display:none">+ Region</button>
          <button id="lp-close-btn" class="lp-hdr-btn lp-hdr-close">✕</button>
        </div>
      </div>
      <div class="lp-search-row">
        <input id="lp-search" class="lp-search-input" type="text" placeholder="Search locations…">
      </div>
      <div id="lp-body" class="lp-body"></div>
    </div>
  </div>

  <!-- Marker Form Modal -->
  <div id="marker-modal" class="modal-overlay">
    <div class="modal-box">
      <h2 id="modal-title">Place Marker</h2>
      <div class="form-row">
        <label>Name <span class="required">*</span>
          <input type="text" id="m-name" placeholder="e.g. Frostholm" />
        </label>
      </div>
      <div class="form-row">
        <label>Type
          <select id="m-type">
            <option value="City">City</option>
            <option value="Town">Town</option>
            <option value="Village">Village</option>
            <option value="Dungeon">Dungeon</option>
            <option value="Landmark">Landmark</option>
            <option value="Cave">Cave</option>
            <option value="Ruin">Ruin</option>
            <option value="Other">Other</option>
          </select>
        </label>
      </div>
      <div class="form-row two-col">
        <label>Population
          <input type="text" id="m-population" placeholder="e.g. 5.7K" />
        </label>
        <label>Wealth
          <input type="text" id="m-wealth" placeholder="e.g. High" />
        </label>
      </div>
      <div class="form-row two-col">
        <label>Main Race
          <select id="m-main-race">
            <option value="">— Mixed —</option>
            <option value="Human">Human</option>
            <option value="Elf">Elf</option>
            <option value="Dwarf">Dwarf</option>
            <option value="Halfling">Halfling</option>
            <option value="Gnome">Gnome</option>
            <option value="Half-Orc">Half-Orc</option>
            <option value="Tiefling">Tiefling</option>
            <option value="Dragonborn">Dragonborn</option>
            <option value="Half-Elf">Half-Elf</option>
          </select>
        </label>
        <label>Religion
          <input type="text" id="m-religion" placeholder="e.g. Pelor" />
        </label>
      </div>
      <div class="form-row">
        <label class="checkbox-label">
          <input type="checkbox" id="m-explored" />
          <span class="checkbox-box"></span>
          Explored
          <span class="checkbox-hint">(yellow = explored, red = unexplored)</span>
        </label>
      </div>
      <div class="form-row">
        <label>DM Notes <span class="dm-only">(only you see this)</span>
          <textarea id="m-notes" placeholder="Secret notes, plot hooks, etc."></textarea>
        </label>
      </div>
      <div id="m-country-row" class="form-row">
        <label>Region
          <select id="m-country"></select>
        </label>
      </div>
      <div id="modal-error" class="modal-error"></div>
      <div class="modal-actions">
        <button id="m-save" class="dm-btn">Save Marker</button>
        <button id="m-cancel" class="dm-btn dm-btn-secondary">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Country Modal -->
  <div id="country-modal" class="modal-overlay">
    <div class="modal-box">
      <h2 id="cm-modal-title">Add Region</h2>
      <div class="form-row">
        <label>Name <span class="required">*</span>
          <input type="text" id="cm-name" placeholder="e.g. Arcadia" />
        </label>
      </div>
      <div class="form-row">
        <label>Description
          <textarea id="cm-desc" placeholder="Short description (optional)…"></textarea>
        </label>
      </div>
      <div class="form-row">
        <label>Colour</label>
        <div id="cm-color-swatches" class="country-color-row"></div>
      </div>
      <div id="cm-error" class="modal-error"></div>
      <div class="modal-actions">
        <button id="cm-save" class="dm-btn">Save</button>
        <button id="cm-cancel" class="dm-btn dm-btn-secondary">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Maps Gallery Modal -->
  <div id="maps-modal" class="modal-overlay">
    <div class="modal-box maps-modal-box">
      <div class="maps-hdr">
        <h2>Campaign Maps</h2>
        <button id="maps-close-btn" class="maps-close">&times;</button>
      </div>
      <div class="maps-upload-row" id="maps-upload-row">
        <label class="dm-btn" id="maps-upload-btn" style="position:relative;overflow:hidden;cursor:pointer">
          <iconify-icon icon="lucide:upload" style="margin-right:4px"></iconify-icon>Upload Map
          <input type="file" id="maps-file-input-modal" accept="image/*"
                 style="position:absolute;inset:0;opacity:0;width:100%;height:100%;cursor:pointer">
        </label>
        <div class="maps-progress" id="maps-upload-progress" style="display:none">
          <div class="maps-progress-track">
            <div class="maps-progress-fill" id="maps-progress-fill"></div>
          </div>
          <span id="maps-progress-text">Uploading…</span>
        </div>
      </div>
      <p class="maps-error" id="maps-upload-error"></p>
      <div class="maps-grid" id="maps-grid"></div>
    </div>
  </div>

  <script is:inline type="module" src="/assets/js/map.js"></script>
</Layout>
