---
import Layout from '../layouts/Layout.astro';
import StatBlockEditor from '../components/StatBlockEditor.astro';
---
<Layout title="Combat — Essolis" activePage="combat" extraCSS={['/assets/css/stat-block-editor.css', '/assets/css/combat.css']} pageContentStyle="overflow:hidden">

  <!-- Three-column layout: initiative | log | loot -->
  <div class="combat-layout">

    <aside class="overlay-panel overlay-left">
      <div class="overlay-header">
        <span class="overlay-title"><iconify-icon icon="game-icons:rank-3" style="font-size:14px;opacity:0.7"></iconify-icon> Initiative</span>
        <div class="list-actions">
          <button id="btn-enemy-list" class="ctrl-btn ctrl-btn-secondary"><iconify-icon icon="game-icons:skull"></iconify-icon> Enemies</button>
          <button id="btn-sort"  class="ctrl-btn ctrl-btn-secondary"><iconify-icon icon="lucide:arrow-up-down"></iconify-icon></button>
          <button id="btn-clear" class="ctrl-btn ctrl-btn-danger"><iconify-icon icon="lucide:x"></iconify-icon></button>
          <button id="btn-add"   class="ctrl-btn ctrl-btn-primary"><iconify-icon icon="lucide:plus"></iconify-icon> Add</button>
        </div>
      </div>
      <div id="combatant-list" class="combatant-list"></div>
    </aside>

    <!-- Combatant detail panel — slides in from the right of the initiative list -->
    <div id="combatant-info-panel" class="combatant-info-panel">
      <div class="cip-inner">
        <div class="cip-header">
          <span class="cip-name" id="cip-name">—</span>
          <button class="cip-close-btn" id="cip-close" title="Close">&times;</button>
        </div>
        <div class="cip-body" id="cip-body"></div>
      </div>
    </div>

    <aside class="overlay-panel overlay-right" style="display:none">
      <div class="overlay-header">
        <span class="overlay-title"><iconify-icon icon="lucide:scroll-text" style="font-size:14px;opacity:0.7"></iconify-icon> Combat Log</span>
        <button id="btn-clear-log" class="ctrl-btn ctrl-btn-secondary"><iconify-icon icon="lucide:trash-2"></iconify-icon></button>
      </div>
      <div id="combat-log" class="combat-log">
        <p class="log-empty">Combat log will appear here.</p>
      </div>
    </aside>

    <aside class="overlay-panel overlay-loot" style="display:none">
      <div class="overlay-header">
        <span class="overlay-title"><iconify-icon icon="game-icons:coins" style="font-size:14px;opacity:0.7"></iconify-icon> Loot</span>
        <button id="btn-clear-loot" class="ctrl-btn ctrl-btn-secondary"><iconify-icon icon="lucide:trash-2"></iconify-icon></button>
      </div>
      <div id="loot-panel" class="loot-panel">
        <p class="loot-panel-empty">Loot drops when enemies fall.</p>
      </div>
    </aside>

  </div>

  <!-- Hidden control bar — kept off-screen on every viewport. The round/turn
       controls live here and act as the backing model the glass dock mirrors;
       the dock also routes its button clicks back to these elements. -->
  <div class="combat-ctrl-wrap">

    <!-- Round / turn controls -->
    <div class="combat-ctrl-bar">
      <div class="round-counter">Round <span id="round-num">1</span></div>
      <div class="ccb-divider"></div>
      <div class="ccb-center" id="turn-banner">
        <span class="turn-label">&#8212; Not in combat &#8212;</span>
      </div>
      <div class="ccb-divider"></div>
      <button id="btn-prev"  class="hero-nav-btn" disabled title="Previous Turn"><iconify-icon icon="lucide:chevron-left"></iconify-icon></button>
      <button id="btn-next"  class="hero-nav-btn" disabled title="Next Turn (Space)"><iconify-icon icon="lucide:chevron-right"></iconify-icon></button>
      <div class="ccb-divider"></div>
      <button id="btn-toggle-log"  class="hero-nav-btn ccb-panel-btn" title="Combat Log"><iconify-icon icon="lucide:scroll-text"></iconify-icon></button>
      <button id="btn-toggle-loot" class="hero-nav-btn ccb-panel-btn" title="Loot"><iconify-icon icon="game-icons:coins"></iconify-icon></button>
      <div class="ccb-divider"></div>
      <button id="btn-start" class="hero-start-btn"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Start Combat</button>
      <button id="btn-end"   class="hero-end-btn" style="display:none"><iconify-icon icon="lucide:x"></iconify-icon> End Combat</button>
    </div>

  </div>

  <!-- Bottom UI — glass dock toolbar for every viewport, with the desktop attack
       bar or (on phones) the contextual action row docked above it -->
  <div id="combat-bottom" class="combat-bottom">

    <!-- Attack bar (desktop) — quick attacker → target damage / heal flow -->
    <div id="field-attack-bar" class="combat-ctrl-bar combat-attack-bar">
      <select id="attack-attacker-sel" class="atk-select" title="Attacker">
        <option value="">— Attacker —</option>
      </select>
      <iconify-icon icon="lucide:arrow-right" class="attack-bar-arrow"></iconify-icon>
      <select id="attack-target-sel" class="atk-select" title="Target">
        <option value="">— Target —</option>
      </select>
      <div class="ccb-divider"></div>
      <button id="attack-dmgtype-btn" class="atk-action-btn dmgtype-btn" title="Damage type: untyped"><iconify-icon icon="game-icons:drop"></iconify-icon></button>
      <input type="number" id="attack-dmg-input" class="attack-dmg-input" placeholder="" min="0" />
      <button id="attack-deal-btn" class="atk-action-btn atk-deal-btn" title="Deal Damage"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon></button>
      <button id="attack-heal-btn" class="atk-action-btn atk-heal-btn" title="Heal"><iconify-icon icon="lucide:heart"></iconify-icon></button>
      <div class="ccb-divider"></div>
      <button id="attack-cancel-btn" class="hero-nav-btn" title="Clear Selection"><iconify-icon icon="lucide:x"></iconify-icon></button>
    </div>

    <!-- Top row (phones): standalone Add (left) + contextual action toolbar + Order (right) -->
    <div class="combat-action-row">
      <button class="ctb-side-btn" data-act="add" title="Add Combatant"><iconify-icon icon="lucide:plus"></iconify-icon></button>

      <!-- Contextual action toolbar — heal / damage / condition for the tapped combatant -->
      <div id="combat-action-toolbar" class="combat-action-toolbar" style="display:none">
        <div class="cat-controls">
          <input type="number" id="cat-amt" class="cat-amt" min="0" placeholder="0" inputmode="numeric" />
          <button class="cat-btn cat-dmg"   id="cat-dmg"   title="Damage"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon></button>
          <button class="cat-btn cat-heal"  id="cat-heal"  title="Heal"><iconify-icon icon="lucide:heart"></iconify-icon></button>
          <button class="cat-btn cat-cond"  id="cat-cond"  title="Condition"><iconify-icon icon="lucide:zap"></iconify-icon></button>
          <button class="cat-btn dmgtype-btn" id="cat-dmgtype" title="Damage type: untyped"><iconify-icon icon="game-icons:drop"></iconify-icon></button>
        </div>
      </div>

      <button class="ctb-side-btn" data-act="sort" title="Sort by Initiative"><iconify-icon icon="lucide:arrow-up-down"></iconify-icon></button>
    </div>

    <!-- Main navbar — liquid-glass dock with the start/end toggle centred -->
    <div id="combat-toolbar" class="combat-toolbar">
      <div class="ctb-status">
        <span class="ctb-round">Round <span id="ctb-round-num">1</span></span>
        <span class="ctb-turn" id="ctb-turn">&#8212; Not in combat &#8212;</span>
      </div>
      <div class="ctb-dock">
        <div class="ctb-group ctb-left">
          <!-- List-management buttons relocated from the initiative panel header (desktop) -->
          <button class="ctb-btn ctb-mgmt" data-act="enemies" title="Enemy Templates"><iconify-icon icon="game-icons:death-skull"></iconify-icon></button>
          <button class="ctb-btn ctb-mgmt" data-act="add" title="Add Combatant"><iconify-icon icon="lucide:plus"></iconify-icon></button>
          <button class="ctb-btn ctb-mgmt" data-act="sort" title="Sort by Initiative"><iconify-icon icon="lucide:arrow-up-down"></iconify-icon></button>
          <button class="ctb-btn" data-act="initiative" title="Initiative"><iconify-icon icon="game-icons:rank-3"></iconify-icon></button>
        </div>
        <!-- Turn controls flank the start/end toggle so prev/next sit right beside it -->
        <div class="ctb-center">
          <button class="ctb-btn" data-act="prev" title="Previous Turn" disabled><iconify-icon icon="lucide:chevron-left"></iconify-icon></button>
          <button class="ctb-btn ctb-toggle" data-act="toggle" title="Start Combat"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon></button>
          <button class="ctb-btn" data-act="next" title="Next Turn" disabled><iconify-icon icon="lucide:chevron-right"></iconify-icon></button>
        </div>
        <div class="ctb-group ctb-right">
          <button class="ctb-btn" data-act="log" title="Combat Log"><iconify-icon icon="lucide:scroll-text"></iconify-icon></button>
          <button class="ctb-btn" data-act="loot" title="Loot"><iconify-icon icon="game-icons:coins"></iconify-icon></button>
        </div>
      </div>
    </div>

  </div>


  <!-- Add / Edit Combatant Modal -->
  <div id="combatant-modal" class="modal-overlay">
    <div class="modal-box">
      <h2 id="cm-title">Add Combatant</h2>
      <div class="modal-body">
        <div class="form-row" id="cm-name-row">
          <label>Name <span class="req">*</span>
            <input type="text" id="cm-name" placeholder="e.g. Gandalf" />
          </label>
        </div>
        <div class="form-row" id="cm-player-pick-row" style="display:none">
          <span class="field-label">Select Player <span class="req">*</span></span>
          <div id="cm-player-list" class="cm-player-list"></div>
        </div>
        <div class="form-row">
          <span class="field-label">Type</span>
          <div class="type-selector" id="cm-type-btns">
            <button type="button" class="type-btn active" data-type="player">Player</button>
            <button type="button" class="type-btn"        data-type="enemy">Enemy</button>
            <button type="button" class="type-btn"        data-type="ally">Ally</button>
            <button type="button" class="type-btn"        data-type="npc">NPC</button>
          </div>
        </div>
        <div class="form-row" id="cm-enemy-tmpl-row" style="display:none">
          <span class="field-label">Enemy Template <span class="req">*</span></span>
          <input type="text" id="cm-enemy-tmpl-search" placeholder="Search your enemy templates…" autocomplete="off" />
          <div id="cm-enemy-tmpl-list" class="preset-list"></div>
          <div id="cm-enemy-tmpl-badge" class="preset-selected-badge" style="display:none"></div>
        </div>
        <div class="form-row" id="cm-enemy-count-row" style="display:none">
          <label>Count <span class="field-hint">adds 1, 2, 3…</span>
            <input type="number" id="cm-enemy-count" value="1" min="1" max="26" />
          </label>
        </div>
        <div class="form-row" id="cm-preset-row">
          <span class="field-label">Monster Preset <span class="field-hint">optional — auto-fills stats</span></span>
          <input type="text" id="cm-preset-search" placeholder="Search monsters… e.g. Goblin" autocomplete="off" />
          <div id="cm-preset-list" class="preset-list"></div>
          <div id="cm-preset-selected" class="preset-selected-badge" style="display:none"></div>
        </div>
        <div class="form-row">
          <label id="cm-init-label">Initiative rolled
            <div class="init-group">
              <input type="number" id="cm-initiative" placeholder="e.g. 14" min="-5" max="50" />
              <button type="button" id="cm-roll-init" class="roll-btn">d20</button>
            </div>
          </label>
        </div>
        <div id="cm-non-player-rows">
          <div class="form-row two-col">
            <label>Current HP
              <input type="number" id="cm-hp" placeholder="e.g. 10" min="0" max="9999" />
            </label>
            <label>Max HP <span class="req">*</span>
              <input type="number" id="cm-maxhp" placeholder="e.g. 10" min="1" max="9999" />
            </label>
          </div>
          <div class="form-row two-col">
            <label>Armor Class
              <input type="number" id="cm-ac" placeholder="10" min="0" max="30" />
            </label>
            <label>Count <span class="field-hint">1, 2, 3…</span>
              <input type="number" id="cm-count" value="1" min="1" max="26" />
            </label>
          </div>
          <div class="form-row">
            <label>Notes <span class="field-hint">optional</span>
              <textarea id="cm-notes" placeholder="e.g. Fire resist, flying, rage…" rows="2"></textarea>
            </label>
          </div>

          <div id="cm-loot-rows" style="display:none">
            <div class="loot-section-divider"><iconify-icon icon="game-icons:coins"></iconify-icon> Loot Table</div>
            <div class="form-row two-col">
              <label>Min Gold (gp)
                <input type="number" id="cm-loot-gp-min" value="0" min="0" max="9999" />
              </label>
              <label>Max Gold (gp)
                <input type="number" id="cm-loot-gp-max" value="0" min="0" max="9999" />
              </label>
            </div>
            <div class="form-row two-col">
              <label>Min Items
                <input type="number" id="cm-loot-items-min" value="0" min="0" max="10" />
              </label>
              <label>Max Items
                <input type="number" id="cm-loot-items-max" value="0" min="0" max="10" />
              </label>
            </div>
            <div class="form-row">
              <span class="field-label">Item Tags <span class="field-hint">click to toggle — pulls from your Items tab</span></span>
              <div class="loot-tag-grid" id="cm-loot-tags">
                <button type="button" class="loot-tag-btn" data-tag="weapon"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Weapon</button>
                <button type="button" class="loot-tag-btn" data-tag="armor"><iconify-icon icon="game-icons:shield"></iconify-icon> Armor</button>
                <button type="button" class="loot-tag-btn" data-tag="potion"><iconify-icon icon="game-icons:round-potion"></iconify-icon> Potion</button>
                <button type="button" class="loot-tag-btn" data-tag="magic"><iconify-icon icon="lucide:sparkles"></iconify-icon> Magic</button>
                <button type="button" class="loot-tag-btn" data-tag="tool"><iconify-icon icon="lucide:hammer"></iconify-icon> Tool</button>
                <button type="button" class="loot-tag-btn" data-tag="food"><iconify-icon icon="lucide:utensils"></iconify-icon> Food</button>
                <button type="button" class="loot-tag-btn" data-tag="book"><iconify-icon icon="game-icons:bookshelf"></iconify-icon> Book</button>
                <button type="button" class="loot-tag-btn" data-tag="misc"><iconify-icon icon="lucide:package"></iconify-icon> Misc</button>
              </div>
            </div>
          </div>

        </div>
        <div id="cm-error" class="modal-error"></div>
      </div>
      <div class="modal-actions">
        <button id="cm-cancel" class="dm-btn dm-btn-secondary">Cancel</button>
        <button id="cm-save"   class="dm-btn">Add</button>
      </div>
    </div>
  </div>

  <!-- HP Adjust -->
  <div id="hp-adjust-overlay" class="hp-adjust-overlay" style="display:none">
    <input type="number" id="hp-adjust-input" placeholder="Amount" min="0" />
    <button id="hp-damage-btn" class="hp-adj-btn dmg"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Damage</button>
    <button id="hp-heal-btn"   class="hp-adj-btn heal"><iconify-icon icon="lucide:heart"></iconify-icon> Heal</button>
    <button id="hp-close-btn"  class="hp-adj-close"><iconify-icon icon="lucide:x"></iconify-icon></button>
  </div>

  <!-- Condition Picker -->
  <div id="condition-picker" class="condition-picker" style="display:none">
    <div class="cond-picker-header">
      <span class="cond-picker-title">Conditions</span>
      <label class="cond-rounds-label">
        <span>Rounds:</span>
        <input type="number" id="cond-rounds-input" placeholder="&#8734;" min="1" max="99" class="cond-rounds-input" />
      </label>
    </div>
    <div id="condition-grid" class="condition-grid"></div>
  </div>

  <!-- Damage-type picker -->
  <div id="dmg-type-picker" class="condition-picker" style="display:none">
    <div class="cond-picker-header">
      <span class="cond-picker-title">Damage Type</span>
    </div>
    <div id="dmg-type-grid" class="condition-grid"></div>
  </div>

  <!-- Enemy Templates Modal -->
  <div id="enemy-templates-modal" class="modal-overlay enemy-modal-overlay">
    <div class="enemy-modal-box">

      <div class="enemy-modal-header">
        <span class="enemy-modal-title"><iconify-icon icon="game-icons:skull"></iconify-icon> Enemy Templates</span>
        <button id="enemy-modal-close" class="enemy-close-btn">&times;</button>
      </div>

      <div class="enemy-modal-body">

        <div class="enemy-list-panel">
          <div class="enemy-list-toolbar">
            <input type="text" id="enemy-search" class="enemy-search-input" placeholder="Search…" />
            <button id="btn-import-dnd5e-creatures" class="ctrl-btn ctrl-btn-secondary" style="display:none" title="Import all D&amp;D 5e monsters as templates"><iconify-icon icon="lucide:download"></iconify-icon></button>
            <button id="btn-new-enemy" class="ctrl-btn ctrl-btn-primary"><iconify-icon icon="lucide:plus"></iconify-icon> New</button>
          </div>
          <div id="creature-import-progress" class="creature-import-progress" style="display:none">
            <div class="creature-progress-track"><div id="creature-progress-fill" class="creature-progress-fill"></div></div>
            <div id="creature-progress-label" class="creature-progress-label">Importing…</div>
          </div>
          <div id="enemy-template-list" class="enemy-template-list"></div>
        </div>

        <div class="enemy-editor-panel" id="enemy-editor-panel">
          <div class="enemy-editor-empty" id="enemy-editor-empty">
            <div class="empty-icon"><iconify-icon icon="game-icons:skull"></iconify-icon></div>
            <p>Select a template or create a new one.</p>
          </div>

          <div id="enemy-editor-form" style="display:none">

            <StatBlockEditor showName={true} />

            <div class="editor-footer">
              <div class="editor-footer-left">
                <button id="et-delete-btn" class="ctrl-btn ctrl-btn-danger"><iconify-icon icon="lucide:trash-2"></iconify-icon> Delete</button>
              </div>
              <div class="editor-footer-right">
                <button id="et-save-btn" class="ctrl-btn ctrl-btn-primary"><iconify-icon icon="lucide:check"></iconify-icon> Save Template</button>
                <div class="add-to-combat-group">
                  <input type="number" id="et-spawn-count" value="1" min="1" max="20" class="spawn-count-input" title="Count" />
                  <button id="et-spawn-btn" class="ctrl-btn ctrl-btn-spawn"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Add to Combat</button>
                </div>
              </div>
            </div>

            <div id="et-error" class="modal-error" style="text-align:left;margin-top:6px"></div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Firebase bridge -->
  <script is:inline type="module">
    import { db } from "/assets/js/firebase.js";
    import { ref, set, remove, push, onValue } from "https://www.gstatic.com/firebasejs/10.14.1/firebase-database.js";

    window._combatItems = [];
    window._saveItem = item => set(ref(db, "items/" + item.id), item);
    onValue(ref(db, "items"), snap => {
      window._combatItems = snap.val() ? Object.values(snap.val()) : [];
    });

    window._allUsers = {};
    onValue(ref(db, "users"), snap => {
      window._allUsers = snap.val() || {};
      window._onUsersLoaded?.();
    });

    window._giveItemToPlayer = async (playerId, itemData) => {
      const session = JSON.parse(localStorage.getItem("playerSession") || "{}");
      const cid = session.campaignId;
      if (!cid) throw new Error("No campaign selected");
      const newRef = push(ref(db, `campaigns/${cid}/inventory/${playerId}`));
      await set(newRef, {
        id:          newRef.key,
        name:        itemData.name        || "Item",
        type:        itemData.type        || "misc",
        description: itemData.description || null,
        quantity:    itemData.quantity    || 1,
        value:       itemData.value != null ? itemData.value + " gp" : null,
        rarity:      itemData.rarity      || null,
        content:     null,
        givenBy:     session.id           || "admin",
        timestamp:   Date.now(),
      });
    };

    window._systemFlags = undefined;
    window._setSystemFlag = (key, val) => set(ref(db, "system/" + key), val);
    onValue(ref(db, "system"), snap => {
      window._systemFlags = snap.val() || {};
      window._onSystemFlagsLoaded?.();
    });

    window._enemyTemplates       = [];
    window._enemyTemplatesLoaded = false;

    const _etSession = (() => { try { return JSON.parse(localStorage.getItem('playerSession')); } catch { return null; } })();
    const _etCid = _etSession?.campaignId;

    if (_etCid) {
      window._campaignMembers      = {};
      window._campaignDisplayNames = {};
      onValue(ref(db, `campaigns/${_etCid}/members`), snap => {
        window._campaignMembers = snap.val() || {};
        window._onCampaignPlayersLoaded?.();
      });
      onValue(ref(db, `campaigns/${_etCid}/displayNames`), snap => {
        window._campaignDisplayNames = snap.val() || {};
        window._onCampaignPlayersLoaded?.();
      });

      window._saveEnemyTemplate = tmpl =>
        set(ref(db, `campaigns/${_etCid}/enemyTemplates/` + tmpl.id), tmpl);

      window._deleteEnemyTemplate = id =>
        remove(ref(db, `campaigns/${_etCid}/enemyTemplates/` + id));

      onValue(ref(db, `campaigns/${_etCid}/enemyTemplates`), snap => {
        const data = snap.val();
        window._enemyTemplates = data ? Object.values(data) : [];
        window._enemyTemplatesLoaded = true;
        window._onEnemyTemplatesUpdate?.();
      });

      // Codex characters carrying a combat stat block are spawnable too (authored
      // once in the Characters tab) — surface them in the enemy-template picker.
      onValue(ref(db, `campaigns/${_etCid}/characters`), snap => {
        const data = snap.val();
        window._codexCreatures = data ? Object.values(data).filter(c => c && c.statBlock) : [];
        window._onEnemyTemplatesUpdate?.();
      });
    } else {
      window._enemyTemplatesLoaded = true;
      window._onEnemyTemplatesUpdate?.();
    }
  </script>
  <script is:inline src="/assets/js/stat-block-editor.js"></script>
  <script is:inline src="/assets/js/combat.js"></script>

  <!-- Framer Motion: staggered card entry + HP change animation -->
  <script>
    import { animate } from 'framer-motion/dom';

    const listEl = document.getElementById('combatant-list');
    if (listEl) {
      let batch: HTMLElement[] = [];
      let timer: ReturnType<typeof setTimeout> | null = null;

      const observer = new MutationObserver(mutations => {
        for (const m of mutations) {
          for (const node of m.addedNodes) {
            if (
              node.nodeType === 1 &&
              (node as HTMLElement).classList?.contains('combatant-card')
            ) {
              const card = node as HTMLElement;
              card.style.animation = 'none';
              card.style.opacity = '0';
              card.style.transform = 'translateY(8px) scale(0.97)';
              batch.push(card);
            }
          }
        }

        if (timer) clearTimeout(timer);
        timer = setTimeout(() => {
          const cards = batch.splice(0);
          if (!cards.length) return;

          cards.forEach((card, i) => {
            const delay = cards.length > 1 ? i * 0.05 : 0;
            animate(card, { opacity: 1, y: 0, scale: 1 }, {
              duration: 0.28,
              delay,
              ease: [0.16, 1, 0.3, 1],
            });
            setTimeout(() => {
              card.style.removeProperty('animation');
            }, (0.28 + delay) * 1000 + 40);
          });
        }, 16);
      });

      observer.observe(listEl, { childList: true });
    }
  </script>
</Layout>
