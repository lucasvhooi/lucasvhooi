---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import headerImg from '../../Images/Headers/CampaignsPageHeader.png';
---
<Layout title="Items — Essolis" activePage="items" extraCSS={['/assets/css/items.css']}>

  <Header
    title="Items"
    description="Create and manage all items in your world."
    icon="lucide:package"
    image={headerImg}
  >
    <!-- Search, Add Item and tags all on one row at the bottom of the header -->
    <div slot="tabs" class="hdr-tabs-row">
      <div class="hdr-search-wrap">
        <iconify-icon icon="lucide:search" class="hdr-search-icon"></iconify-icon>
        <input type="text" id="items-search" class="items-search" placeholder="Search…" />
        <button type="button" id="items-search-clear" class="search-clear-btn" aria-label="Clear search">
          <iconify-icon icon="lucide:x"></iconify-icon>
        </button>
      </div>
      <div id="tag-filter" class="tag-filter"></div>
    </div>
  </Header>

  <main class="items-main">

    <!-- Sort & Rarity filter bar -->
    <div class="items-filter-bar">
      <div class="items-sort-group">
        <span class="filter-label">Sort</span>
        <button class="sort-btn" data-sort="name" id="sort-name">
          Name <iconify-icon icon="lucide:chevrons-up-down" style="font-size:13px;vertical-align:-2px"></iconify-icon>
        </button>
        <button class="sort-btn" data-sort="rarity" id="sort-rarity">
          Rarity <iconify-icon icon="lucide:chevrons-up-down" style="font-size:13px;vertical-align:-2px"></iconify-icon>
        </button>
        <button class="sort-btn" data-sort="price" id="sort-price">
          Price <iconify-icon icon="lucide:chevrons-up-down" style="font-size:13px;vertical-align:-2px"></iconify-icon>
        </button>
      </div>
      <div class="items-rarity-filter">
        <span class="filter-label">Rarity</span>
        <button class="rarity-filter-btn rfb-all active" data-rarity="">All</button>
        <button class="rarity-filter-btn rfb-common"    data-rarity="common">Common</button>
        <button class="rarity-filter-btn rfb-uncommon"  data-rarity="uncommon">Uncommon</button>
        <button class="rarity-filter-btn rfb-rare"      data-rarity="rare">Rare</button>
        <button class="rarity-filter-btn rfb-vrare"     data-rarity="very rare">Very Rare</button>
        <button class="rarity-filter-btn rfb-legendary" data-rarity="legendary">Legendary</button>
      </div>
      <div class="items-filter-actions">
        <button id="add-item-btn" class="items-btn-add" style="display:none">
          <iconify-icon icon="lucide:plus"></iconify-icon>
          Add Item
        </button>
        <button id="btn-import-dnd5e" class="items-btn-import" style="display:none" title="Replace base items with D&D 5e API data">
          <iconify-icon icon="lucide:download"></iconify-icon>
          Import D&D 5e
        </button>
      </div>
    </div>

    <!-- List + detail panel side by side -->
    <div class="items-content">

      <div class="items-list-section">
        <!-- Column headers -->
        <div class="items-col-header">
          <span class="col-h-name">Name</span>
          <span class="col-h-type">Type</span>
          <span class="col-h-rarity">Rarity</span>
          <span class="col-h-price">Price</span>
          <span></span>
        </div>

        <!-- Items list -->
        <div id="items-grid" class="items-list"></div>
        <div id="items-pagination" class="items-pagination"></div>
      </div>

      <!-- Right: slide-out detail panel -->
      <div id="item-detail-panel" class="item-detail-panel">
        <div class="item-detail-inner">
          <div class="idp-header">
            <h2 id="idp-title" class="idp-title"></h2>
            <button id="idp-close" class="idp-close" title="Close">&times;</button>
          </div>
          <div class="idp-body">
            <div id="idp-meta" class="idp-meta"></div>
            <div id="idp-stats"></div>
            <hr class="idp-divider" />
            <div id="idp-description"></div>
            <div id="idp-abilities"></div>
          </div>
        </div>
      </div>

    </div>

  </main>

  <!-- Item modal -->
  <div id="item-modal" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="im-title">Add Item</h2>
        <button class="modal-close-x" id="im-close-btn">&times;</button>
      </div>
      <div class="modal-body">
        <!-- Name: full width -->
        <div class="form-row im-name-row">
          <label>Name <span class="req">*</span>
            <input type="text" id="im-name" placeholder="e.g. Health Potion" />
          </label>
        </div>
        <!-- Two-column body -->
        <div class="im-form-grid">
          <div class="im-col-left">
            <div class="form-row">
              <label>Description
                <textarea id="im-desc" rows="7" placeholder="What does this item do or look like?"></textarea>
              </label>
            </div>
            <div class="form-row">
              <label>Abilities</label>
              <div id="im-abilities-list" class="im-abilities-list"></div>
              <button type="button" id="im-ability-add-btn" class="im-ability-add-btn">+ Add Ability</button>
            </div>
          </div>
          <div class="im-col-right">
            <div class="form-row two-col">
              <label>Base Price (gp) <span class="req">*</span>
                <input type="number" id="im-price" placeholder="e.g. 50" min="0" step="0.01" />
              </label>
              <label>Weight (lb)
                <input type="number" id="im-weight" placeholder="e.g. 1" min="0" step="0.1" />
              </label>
            </div>
            <div class="form-row">
              <label>Tags</label>
              <div class="im-tag-picker-row">
                <div class="im-tag-chips" id="im-tag-chips"></div>
                <button type="button" id="im-tag-add-btn" class="im-tag-add-btn">+ New Tag</button>
              </div>
              <input type="text" id="im-tag-new-input" class="im-tag-new-input" placeholder="New tag name…" style="display:none" />
            </div>
            <div class="form-row">
              <label>Rarity</label>
              <div class="rarity-selector" id="im-rarity-selector">
                <button type="button" class="rarity-sel-btn" data-rarity="common">Common</button>
                <button type="button" class="rarity-sel-btn" data-rarity="uncommon">Uncommon</button>
                <button type="button" class="rarity-sel-btn" data-rarity="rare">Rare</button>
                <button type="button" class="rarity-sel-btn" data-rarity="very rare">Very Rare</button>
                <button type="button" class="rarity-sel-btn" data-rarity="legendary">Legendary</button>
              </div>
            </div>
            <div class="form-row">
              <label class="checkbox-label">
                <input type="checkbox" id="im-shop-available" checked />
                <span class="checkbox-box"></span>
                Available in shop
              </label>
            </div>
            <div class="form-row">
              <label class="checkbox-label">
                <input type="checkbox" id="im-requires-attunement" />
                <span class="checkbox-box"></span>
                Requires Attunement
              </label>
            </div>
          </div>
        </div>
        <div id="im-error" class="modal-error"></div>
      </div>
      <div class="modal-actions">
        <button id="im-save" class="dm-btn">Save Item</button>
        <button id="im-cancel" class="dm-btn dm-btn-secondary">Cancel</button>
      </div>
    </div>
  </div>

  <!-- D&D 5e Import Progress Overlay -->
  <div id="dnd5e-import-overlay" class="dnd5e-import-overlay" style="display:none">
    <div class="dnd5e-import-box">
      <h3 class="dnd5e-import-title">
        <iconify-icon icon="lucide:download"></iconify-icon>
        Importing from D&D 5e API
      </h3>
      <div class="dnd5e-progress-track">
        <div id="dnd5e-progress-bar" class="dnd5e-progress-fill"></div>
      </div>
      <div id="dnd5e-progress-text" class="dnd5e-progress-text">0 / 0 (0%)</div>
      <div id="dnd5e-progress-status" class="dnd5e-progress-status">Starting…</div>
    </div>
  </div>

  <script is:inline type="module" src="/assets/js/items.js"></script>

  <!-- Framer Motion: staggered row entry on filter/search rebuild -->
  <script>
    import { animate } from 'framer-motion/dom';

    const grid = document.getElementById('items-grid');
    if (grid) {
      let batch: HTMLElement[] = [];
      let rebuilding = false;
      let timer: ReturnType<typeof setTimeout> | null = null;

      const observer = new MutationObserver(mutations => {
        for (const m of mutations) {
          if (m.removedNodes.length > 2) {
            rebuilding = true;
            batch = [];
          }

          for (const node of m.addedNodes) {
            const el = node as HTMLElement;
            if (node.nodeType === 1 && el.classList?.contains('item-row')) {
              if (rebuilding) {
                el.style.animation = 'none';
                el.style.opacity = '0';
                el.style.transform = 'translateY(6px)';
                batch.push(el);
              }
            }
          }
        }

        if (!rebuilding) return;

        if (timer) clearTimeout(timer);
        timer = setTimeout(() => {
          const rows = batch.splice(0);
          rebuilding = false;
          if (!rows.length) return;

          rows.forEach((row, i) => {
            const delay = Math.min(i * 0.035, 0.35);
            animate(row, { opacity: 1, y: 0 }, {
              duration: 0.24,
              delay,
              ease: [0.16, 1, 0.3, 1],
            });
            setTimeout(() => {
              row.style.removeProperty('animation');
            }, (0.24 + delay) * 1000 + 40);
          });
        }, 20);
      });

      observer.observe(grid, { childList: true });
    }
  </script>
</Layout>
