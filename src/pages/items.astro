---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Items — DnD Campaign" showCampaignTabs={true} activePage="items" extraCSS={['/assets/css/items.css']}>

  <header class="items-hero page-hero">
    <button id="add-item-btn" class="dm-btn items-add-btn page-hero__add-btn" style="display:none">+ Add Item</button>
    <h1 class="items-title page-hero__title">Items</h1>
    <p class="items-subtitle page-hero__sub">Global item database for shops &amp; merchants</p>
  </header>

  <main class="items-main">
    <div class="items-toolbar">
      <input type="text" id="items-search" class="items-search" placeholder="Search items…" />
      <div id="tag-filter" class="tag-filter"></div>
    </div>
    <div id="items-grid" class="items-grid"></div>
  </main>

  <!-- Item modal -->
  <div id="item-modal" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="im-title">Add Item</h2>
        <button class="modal-close-x" id="im-close-btn">&times;</button>
      </div>
      <div class="modal-body">
        <div class="form-row">
          <label>Name <span class="req">*</span>
            <input type="text" id="im-name" placeholder="e.g. Health Potion" />
          </label>
        </div>
        <div class="form-row">
          <label>Description
            <textarea id="im-desc" rows="3" placeholder="What does this item do or look like?"></textarea>
          </label>
        </div>
        <div class="form-row">
          <label>Base Price (gp) <span class="req">*</span>
            <input type="number" id="im-price" placeholder="e.g. 50" min="0" step="0.01" />
          </label>
        </div>
        <div class="form-row">
          <label>Tags</label>
          <div class="im-tag-picker-row">
            <div class="im-tag-chips" id="im-tag-chips"></div>
            <button type="button" id="im-tag-add-btn" class="im-tag-add-btn">+ New Tag</button>
          </div>
          <input type="text" id="im-tag-new-input" class="im-tag-new-input" placeholder="New tag name…" style="display:none" />
        </div>
        <div class="form-row">
          <label>Rarity</label>
          <div class="rarity-selector" id="im-rarity-selector">
            <button type="button" class="rarity-sel-btn" data-rarity="common">Common</button>
            <button type="button" class="rarity-sel-btn" data-rarity="uncommon">Uncommon</button>
            <button type="button" class="rarity-sel-btn" data-rarity="rare">Rare</button>
            <button type="button" class="rarity-sel-btn" data-rarity="very rare">Very Rare</button>
            <button type="button" class="rarity-sel-btn" data-rarity="legendary">Legendary</button>
          </div>
        </div>
        <div class="form-row">
          <label class="checkbox-label">
            <input type="checkbox" id="im-shop-available" checked />
            <span class="checkbox-box"></span>
            Available in shop (players can buy this item)
          </label>
        </div>
        <div class="form-row">
          <label class="checkbox-label">
            <input type="checkbox" id="im-requires-attunement" />
            <span class="checkbox-box"></span>
            Requires Attunement
          </label>
        </div>
        <div class="form-row">
          <label>Abilities</label>
          <div id="im-abilities-list" class="im-abilities-list"></div>
          <button type="button" id="im-ability-add-btn" class="im-ability-add-btn">+ Add Ability</button>
        </div>
        <div id="im-error" class="modal-error"></div>
      </div>
      <div class="modal-actions">
        <button id="im-save" class="dm-btn">Save Item</button>
        <button id="im-cancel" class="dm-btn dm-btn-secondary">Cancel</button>
      </div>
    </div>
  </div>

  <script is:inline type="module" src="/assets/js/items.js"></script>
</Layout>
