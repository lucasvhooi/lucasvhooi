---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Inventory — DnD Campaign" showCampaignTabs={true} activePage="inventory" extraCSS={['/assets/css/lore.css', '/assets/css/spells.css', '/assets/css/items.css', '/assets/css/inventory.css']}>

  <header class="inv-hero page-hero">
    <button class="manage-btn" id="manage-btn" style="display:none"><iconify-icon icon="lucide:settings"></iconify-icon> Players</button>
    <button class="dm-btn inv-add-btn" id="add-btn" style="display:none">+ Add Item</button>

    <h1 class="inv-hero-title page-hero__title" id="inv-hero-title">Inventory</h1>
    <p class="inv-hero-sub page-hero__sub" id="inv-hero-sub">Loading…</p>

    <div class="inv-attunement-bar" id="inv-attunement-bar" style="display:none">
      <span class="inv-attunement-slots" id="inv-attunement-slots">0 / 3 Attunement Slots</span>
    </div>

    <div class="inv-player-selector" id="player-selector" style="display:none">
      <label for="player-select">Viewing:</label>
      <select class="inv-player-select" id="player-select"></select>
    </div>

    <div class="inv-filter-tabs" id="filter-tabs">
      <button class="inv-tab active" data-filter="all">All</button>
      <button class="inv-tab" data-filter="weapon"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Weapons</button>
      <button class="inv-tab" data-filter="armor"><iconify-icon icon="game-icons:shield"></iconify-icon> Armor</button>
      <button class="inv-tab" data-filter="potion"><iconify-icon icon="game-icons:potion"></iconify-icon> Potions</button>
      <button class="inv-tab" data-filter="misc"><iconify-icon icon="lucide:gem"></iconify-icon> Misc</button>
      <button class="inv-tab inv-tab-lore" data-filter="books-scrolls"><iconify-icon icon="game-icons:bookshelf"></iconify-icon> Books &amp; Scrolls</button>
      <button class="inv-tab inv-tab-spells" data-filter="spells"><iconify-icon icon="lucide:sparkles"></iconify-icon> Spells</button>
    </div>
  </header>

  <main class="inv-main">
    <div class="inv-grid-toolbar">
      <button class="inv-view-toggle" id="inv-view-toggle" title="Toggle compact view" aria-label="Toggle compact view">
        <span class="toggle-icon-grid">⊞</span>
        <iconify-icon icon="lucide:list" class="toggle-icon-list"></iconify-icon>
      </button>
    </div>
    <div class="inv-grid" id="inv-grid"></div>
  </main>

  <!-- Add Item Modal -->
  <div class="inv-overlay" id="add-modal">
    <div class="inv-modal inv-modal-lg">
      <div class="inv-modal-header">
        <h2 class="inv-modal-title">Add Item to Inventory</h2>
        <button class="inv-modal-close" data-close="add-modal"><iconify-icon icon="lucide:x"></iconify-icon></button>
      </div>
      <div class="inv-modal-body">
        <div class="inv-form-row ai-search-wrap">
          <label class="inv-form-label">Search Item <span style="color:#e05050">*</span></label>
          <input class="inv-form-input" id="ai-search" placeholder="Type to search items from the shop…" autocomplete="off" />
          <div class="ai-drop" id="ai-drop"></div>
        </div>
        <div class="ai-selected-preview" id="ai-selected-preview" style="display:none"></div>
        <div class="inv-form-row-2">
          <div class="inv-form-row" style="margin:0">
            <label class="inv-form-label">Type</label>
            <select class="inv-form-select" id="ai-type">
              <option value="weapon">Weapon</option>
              <option value="armor">Armor</option>
              <option value="potion">Potion</option>
              <option value="book">Book</option>
              <option value="scroll">Scroll</option>
              <option value="misc" selected>Misc</option>
            </select>
          </div>
          <div class="inv-form-row" style="margin:0">
            <label class="inv-form-label">Quantity</label>
            <input class="inv-form-input" id="ai-qty" type="number" min="1" value="1" />
          </div>
        </div>
        <div class="inv-form-row" id="ai-target-row">
          <label class="inv-form-label">Give to Player</label>
          <select class="inv-form-select" id="ai-target"></select>
        </div>
        <div class="inv-form-error" id="ai-error"></div>
      </div>
      <div class="inv-modal-footer">
        <button class="btn-ghost" data-close="add-modal">Cancel</button>
        <button class="btn-primary" id="ai-save">Add Item</button>
      </div>
    </div>
  </div>

  <!-- Reader modal -->
  <div id="inv-reader" class="modal-overlay">
    <div class="modal-box reader-box" id="inv-reader-box">
      <button id="inv-reader-close" class="reader-close-btn">&times;</button>

      <div id="inv-reader-book" style="display:none">
        <div class="reader-book-cover" id="inv-reader-cover">
          <div class="reader-cover-spine"  id="inv-reader-spine"></div>
          <div class="reader-cover-front">
            <div class="reader-cover-title"  id="inv-reader-cover-title"></div>
            <div class="reader-cover-writer" id="inv-reader-cover-writer"></div>
          </div>
        </div>
        <div class="reader-page-area">
          <div class="reader-page" id="inv-reader-page">
            <h3  class="reader-page-title"   id="inv-reader-page-title"></h3>
            <div class="reader-page-content" id="inv-reader-page-content"></div>
          </div>
          <div class="reader-page-nav">
            <button id="inv-reader-prev" class="reader-nav-btn"><iconify-icon icon="lucide:arrow-left"></iconify-icon> Prev</button>
            <span   id="inv-reader-page-num" class="reader-page-num"></span>
            <button id="inv-reader-next" class="reader-nav-btn">Next <iconify-icon icon="lucide:arrow-right"></iconify-icon></button>
          </div>
        </div>
      </div>

      <div id="inv-reader-scroll" style="display:none">
        <div class="reader-scroll-wrap">
          <div class="reader-scroll-roll top"></div>
          <div class="reader-scroll-body">
            <div class="reader-scroll-title"   id="inv-reader-scroll-title"></div>
            <div class="reader-scroll-writer"  id="inv-reader-scroll-writer"></div>
            <div class="reader-scroll-content" id="inv-reader-scroll-content"></div>
          </div>
          <div class="reader-scroll-roll bottom"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Remove Item Modal -->
  <div class="inv-overlay" id="remove-modal">
    <div class="inv-modal">
      <div class="inv-modal-header">
        <h2 class="inv-modal-title">Remove Item</h2>
        <button class="inv-modal-close" data-close="remove-modal"><iconify-icon icon="lucide:x"></iconify-icon></button>
      </div>
      <div class="inv-modal-body">
        <p id="remove-item-label" style="color:#aaa;font-size:14px;margin:0 0 16px"></p>
        <div id="remove-qty-row" style="display:none">
          <label class="inv-form-label">How many to remove?</label>
          <div class="remove-qty-stepper">
            <button class="remove-qty-btn" id="remove-qty-minus"><iconify-icon icon="lucide:minus"></iconify-icon></button>
            <input class="remove-qty-input" id="remove-qty-input" type="number" min="1" value="1" />
            <button class="remove-qty-btn" id="remove-qty-plus">+</button>
            <button class="remove-qty-all" id="remove-qty-all">All</button>
          </div>
        </div>
      </div>
      <div class="inv-modal-footer">
        <button class="btn-ghost" data-close="remove-modal">Cancel</button>
        <button class="btn-danger" id="remove-confirm">Remove</button>
      </div>
    </div>
  </div>

  <!-- Send Modal -->
  <div class="inv-overlay" id="send-modal">
    <div class="inv-modal">
      <div class="inv-modal-header">
        <h2 class="inv-modal-title">Send Item</h2>
        <button class="inv-modal-close" data-close="send-modal"><iconify-icon icon="lucide:x"></iconify-icon></button>
      </div>
      <div class="inv-modal-body">
        <p style="color:#aaa;font-size:13px;margin:0 0 14px">
          Sending: <strong id="send-item-name" style="color:var(--text)"></strong>
        </p>
        <p style="font-size:12px;color:#666;margin:0 0 10px;text-transform:uppercase;letter-spacing:.06em">Choose recipient:</p>
        <div class="inv-player-list" id="send-player-list"></div>
        <div class="inv-form-error" id="send-error"></div>
      </div>
      <div class="inv-modal-footer">
        <button class="btn-ghost" data-close="send-modal">Cancel</button>
        <button class="btn-primary" id="send-confirm">Send</button>
      </div>
    </div>
  </div>

  <!-- Manage Players Modal -->
  <div class="inv-overlay" id="manage-modal">
    <div class="inv-modal inv-modal-lg">
      <div class="inv-modal-header">
        <h2 class="inv-modal-title"><iconify-icon icon="lucide:settings"></iconify-icon> Manage Players</h2>
        <button class="inv-modal-close" data-close="manage-modal"><iconify-icon icon="lucide:x"></iconify-icon></button>
      </div>
      <div class="inv-modal-body">
        <div id="player-list-el"></div>
      </div>
      <div class="inv-modal-footer">
        <button class="btn-ghost" data-close="manage-modal">Close</button>
      </div>
    </div>
  </div>

  <!-- Quick-Edit Item Modal -->
  <div id="qe-modal" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-header">
        <h2>Edit Item</h2>
        <button class="modal-close-x" id="qe-close-btn">&times;</button>
      </div>
      <div class="modal-body">
        <div class="qe-layout">
          <!-- Left column: identity -->
          <div class="qe-col">
            <div class="form-row">
              <label>Name <span class="req">*</span>
                <input type="text" id="qe-name" placeholder="e.g. Health Potion" />
              </label>
            </div>
            <div class="form-row qe-desc-row">
              <label>Description
                <textarea id="qe-desc" rows="6" placeholder="What does this item do or look like?"></textarea>
              </label>
            </div>
            <div class="form-row">
              <label>Tags</label>
              <div class="im-tag-picker-row">
                <div class="im-tag-chips" id="qe-tag-chips"></div>
                <button type="button" id="qe-tag-add-btn" class="im-tag-add-btn">+ New Tag</button>
              </div>
              <input type="text" id="qe-tag-new-input" class="im-tag-new-input" placeholder="New tag name…" style="display:none" />
            </div>
          </div>

          <!-- Right column: mechanics -->
          <div class="qe-col">
            <div class="form-row">
              <label>Base Price (gp) <span class="req">*</span>
                <input type="number" id="qe-price" placeholder="e.g. 50" min="0" step="0.01" />
              </label>
            </div>
            <div class="form-row">
              <label>Rarity</label>
              <div class="rarity-selector" id="qe-rarity-selector">
                <button type="button" class="rarity-sel-btn" data-rarity="common">Common</button>
                <button type="button" class="rarity-sel-btn" data-rarity="uncommon">Uncommon</button>
                <button type="button" class="rarity-sel-btn" data-rarity="rare">Rare</button>
                <button type="button" class="rarity-sel-btn" data-rarity="very rare">Very Rare</button>
                <button type="button" class="rarity-sel-btn" data-rarity="legendary">Legendary</button>
              </div>
            </div>
            <div class="form-row">
              <label class="checkbox-label">
                <input type="checkbox" id="qe-shop-available" checked />
                <span class="checkbox-box"></span>
                Available in shop
              </label>
            </div>
            <div class="form-row">
              <label class="checkbox-label">
                <input type="checkbox" id="qe-requires-attunement" />
                <span class="checkbox-box"></span>
                Requires Attunement
              </label>
            </div>
          </div>
        </div>

        <!-- Full-width: abilities -->
        <div class="form-row">
          <label>Abilities</label>
          <div id="qe-abilities-list" class="im-abilities-list"></div>
          <button type="button" id="qe-ability-add-btn" class="im-ability-add-btn">+ Add Ability</button>
        </div>
        <div id="qe-error" class="modal-error"></div>
      </div>
      <div class="modal-actions">
        <button id="qe-save" class="dm-btn">Save Item</button>
        <button id="qe-cancel" class="dm-btn dm-btn-secondary">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Spell detail modal -->
  <div id="spell-modal" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="sm-title"></h2>
        <button class="modal-close-x" id="sm-close-btn">&times;</button>
      </div>
      <div class="modal-body">
        <div class="sm-meta" id="sm-meta"></div>
        <div class="sm-stats" id="sm-stats"></div>
        <div class="sm-components" id="sm-components"></div>
        <hr class="sm-divider" />
        <div class="sm-description" id="sm-description"></div>
      </div>
    </div>
  </div>

  <div id="condition-tooltip" class="condition-tooltip-box" style="display:none"></div>

  <script is:inline type="module" src="/assets/js/inventory.js"></script>

  <!-- Framer Motion: staggered card reveal on filter/render -->
  <script>
    import { animate } from 'framer-motion/dom';

    const grid = document.getElementById('inv-grid');
    if (grid) {
      let batch: HTMLElement[] = [];
      let rebuilding = false;
      let timer: ReturnType<typeof setTimeout> | null = null;

      const observer = new MutationObserver(mutations => {
        for (const m of mutations) {
          // Large removal signals a full grid rebuild
          if (m.removedNodes.length > 2) {
            rebuilding = true;
            batch = [];
          }

          for (const node of m.addedNodes) {
            const el = node as HTMLElement;
            if (
              node.nodeType === 1 &&
              (el.classList?.contains('inv-card') || el.classList?.contains('spell-card'))
            ) {
              if (rebuilding) {
                el.style.opacity = '0';
                el.style.transform = 'translateY(6px) scale(0.98)';
                batch.push(el);
              }
            }
          }
        }

        if (!rebuilding) return;

        if (timer) clearTimeout(timer);
        timer = setTimeout(() => {
          const cards = batch.splice(0);
          rebuilding = false;
          if (!cards.length) return;

          cards.forEach((card, i) => {
            animate(card, { opacity: 1, y: 0, scale: 1 }, {
              duration: 0.24,
              delay: Math.min(i * 0.04, 0.4),
              ease: [0.16, 1, 0.3, 1],
            });
          });
        }, 20);
      });

      observer.observe(grid, { childList: true });
    }
  </script>
</Layout>
