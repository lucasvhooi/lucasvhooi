---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import headerImg from '../../Images/Headers/CampaignsPageHeader.png';
---
<Layout title="Spells — Essolis" activePage="spells" extraCSS={['/assets/css/spells.css']}>

  <Header
    title="Spells"
    description="Complete D&D spell compendium with condition tooltips"
    icon="lucide:sparkles"
    image={headerImg}
  >
    <div slot="tabs" class="hdr-tabs-row">
      <div class="spell-search-dock">
        <div class="hdr-search-wrap">
          <iconify-icon icon="lucide:search" class="hdr-search-icon"></iconify-icon>
          <input type="text" id="spells-search" class="items-search" placeholder="Search spells…" />
          <button type="button" id="spells-search-clear" class="search-clear-btn" aria-label="Clear search">
            <iconify-icon icon="lucide:x"></iconify-icon>
          </button>
        </div>
        <button id="spell-add-btn" class="items-btn-add" style="display:none">
          <iconify-icon icon="lucide:plus"></iconify-icon>
          Add Spell
        </button>
      </div>
      <div id="level-filter" class="level-filter"></div>
    </div>
  </Header>

  <main class="spells-main">
    <div id="seed-status" class="seed-status" style="display:none"></div>

    <!-- Sort & filter bar -->
    <div class="items-filter-bar">
      <div class="items-sort-group">
        <span class="filter-label">Sort</span>
        <button class="sort-btn" data-sort="name" id="sort-name">
          Name <iconify-icon icon="lucide:chevrons-up-down" style="font-size:13px;vertical-align:-2px"></iconify-icon>
        </button>
        <button class="sort-btn" data-sort="level" id="sort-level">
          Level <iconify-icon icon="lucide:chevrons-up-down" style="font-size:13px;vertical-align:-2px"></iconify-icon>
        </button>
        <button class="sort-btn" data-sort="school" id="sort-school">
          School <iconify-icon icon="lucide:chevrons-up-down" style="font-size:13px;vertical-align:-2px"></iconify-icon>
        </button>
      </div>
      <div class="spells-filter-group">
        <span class="filter-label">School</span>
        <select id="school-filter" class="spells-select-sm">
          <option value="">All</option>
        </select>
      </div>
      <div class="spells-filter-group">
        <span class="filter-label">Class</span>
        <select id="class-filter" class="spells-select-sm">
          <option value="">All</option>
        </select>
      </div>
      <span class="spells-count" id="spell-count"></span>
    </div>

    <!-- List + detail panel side by side -->
    <div class="spells-content">

      <!-- Left: list section -->
      <div class="spells-list-section">
        <div class="spells-col-header">
          <span class="col-h-name">Name</span>
          <span>Level</span>
          <span>School</span>
          <span>Cast Time</span>
          <span>Duration</span>
          <span></span>
        </div>
        <div id="spells-grid" class="spells-list"></div>
        <div id="spells-pagination" class="spells-pagination"></div>
      </div>

      <!-- Right: slide-out detail panel -->
      <div id="spell-detail-panel" class="spell-detail-panel">
        <div class="spell-detail-inner">
          <div class="sdp-header">
            <h2 id="sdp-title" class="sdp-title"></h2>
            <button id="sdp-close" class="sdp-close" title="Close">&times;</button>
          </div>
          <div class="sdp-body">
            <div id="sdp-meta" class="sm-meta"></div>
            <div id="sdp-stats"></div>
            <div id="sdp-components"></div>
            <hr class="sm-divider" />
            <div id="sdp-description" class="sm-description"></div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <!-- Add / create spell modal (admin only) -->
  <div id="spell-modal" class="modal-overlay">
    <div class="modal-box spell-modal-box">
      <div class="modal-header">
        <h2 id="spell-modal-title">Add Spell</h2>
        <button class="modal-close-x" id="spell-modal-close">&times;</button>
      </div>
      <div class="modal-body">
        <div class="form-row">
          <label>Name <span class="req">*</span>
            <input type="text" id="sf-name" placeholder="e.g. Fireball" />
          </label>
        </div>
        <div class="form-row two-col">
          <label>Level
            <select id="sf-level">
              <option value="0">Cantrip</option>
              <option value="1">1st</option>
              <option value="2">2nd</option>
              <option value="3">3rd</option>
              <option value="4">4th</option>
              <option value="5">5th</option>
              <option value="6">6th</option>
              <option value="7">7th</option>
              <option value="8">8th</option>
              <option value="9">9th</option>
            </select>
          </label>
          <label>School
            <select id="sf-school">
              <option value="">—</option>
              <option value="Abjuration">Abjuration</option>
              <option value="Conjuration">Conjuration</option>
              <option value="Divination">Divination</option>
              <option value="Enchantment">Enchantment</option>
              <option value="Evocation">Evocation</option>
              <option value="Illusion">Illusion</option>
              <option value="Necromancy">Necromancy</option>
              <option value="Transmutation">Transmutation</option>
            </select>
          </label>
        </div>
        <div class="form-row">
          <label>Classes
            <input type="text" id="sf-classes" placeholder="Wizard, Sorcerer (comma-separated)" />
          </label>
        </div>
        <div class="form-row two-col">
          <label>Casting Time
            <input type="text" id="sf-casttime" placeholder="e.g. 1 Action" />
          </label>
          <label>Range
            <input type="text" id="sf-range" placeholder="e.g. 150 feet" />
          </label>
        </div>
        <div class="form-row">
          <label>Duration
            <input type="text" id="sf-duration" placeholder="e.g. Instantaneous / Concentration, up to 1 minute" />
          </label>
        </div>
        <div class="form-row">
          <label>Components</label>
          <div class="sf-comp-row">
            <label class="checkbox-label"><input type="checkbox" id="sf-verbal" /><span class="checkbox-box"></span>Verbal</label>
            <label class="checkbox-label"><input type="checkbox" id="sf-somatic" /><span class="checkbox-box"></span>Somatic</label>
            <label class="checkbox-label"><input type="checkbox" id="sf-material" /><span class="checkbox-box"></span>Material</label>
          </div>
        </div>
        <div class="form-row">
          <label>Material Cost
            <input type="text" id="sf-materialcost" placeholder="e.g. a tiny ball of bat guano and sulfur" />
          </label>
        </div>
        <div class="form-row">
          <label>Description
            <textarea id="sf-desc" rows="6" placeholder="What does the spell do?"></textarea>
          </label>
        </div>
        <div id="sf-error" class="modal-error"></div>
      </div>
      <div class="modal-actions">
        <button id="sf-save" class="dm-btn">Save Spell</button>
        <button id="sf-cancel" class="dm-btn dm-btn-secondary">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Condition tooltip -->
  <div id="condition-tooltip" class="condition-tooltip-box" style="display:none"></div>

  <script is:inline type="module" src="/assets/js/spells.js"></script>

  <!-- Framer Motion: staggered row entry on filter/search rebuild -->
  <script>
    import { animate } from 'framer-motion/dom';

    const grid = document.getElementById('spells-grid');
    if (grid) {
      let batch: HTMLElement[] = [];
      let rebuilding = false;
      let timer: ReturnType<typeof setTimeout> | null = null;

      const observer = new MutationObserver(mutations => {
        for (const m of mutations) {
          if (m.removedNodes.length > 2) {
            rebuilding = true;
            batch = [];
          }

          for (const node of m.addedNodes) {
            const el = node as HTMLElement;
            if (node.nodeType === 1 && el.classList?.contains('spell-row')) {
              if (rebuilding) {
                el.style.animation = 'none';
                el.style.opacity = '0';
                el.style.transform = 'translateY(6px)';
                batch.push(el);
              }
            }
          }
        }

        if (!rebuilding) return;

        if (timer) clearTimeout(timer);
        timer = setTimeout(() => {
          const rows = batch.splice(0);
          rebuilding = false;
          if (!rows.length) return;

          rows.forEach((row, i) => {
            const delay = Math.min(i * 0.035, 0.35);
            animate(row, { opacity: 1, y: 0 }, {
              duration: 0.24,
              delay,
              ease: [0.16, 1, 0.3, 1],
            });
            setTimeout(() => {
              row.style.removeProperty('animation');
            }, (0.24 + delay) * 1000 + 40);
          });
        }, 20);
      });

      observer.observe(grid, { childList: true });
    }
  </script>
</Layout>
