---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Spells — DnD Campaign" showCampaignTabs={true} activePage="spells" extraCSS={['/assets/css/spells.css']}>

  <header class="spells-hero page-hero">
    <h1 class="spells-title page-hero__title">Spells</h1>
    <p class="spells-subtitle page-hero__sub">Complete D&amp;D spell compendium with condition tooltips</p>
  </header>

  <main class="spells-main">
    <div id="seed-status" class="seed-status" style="display:none"></div>

    <div class="spells-toolbar">
      <input type="text" id="spells-search" class="spells-search" placeholder="Search spells…" />
      <div id="level-filter" class="level-filter"></div>
    </div>
    <div class="spells-toolbar spells-toolbar-row2">
      <select id="school-filter" class="spells-select">
        <option value="">All Schools</option>
      </select>
      <select id="class-filter" class="spells-select">
        <option value="">All Classes</option>
      </select>
      <span class="spells-count" id="spell-count"></span>
    </div>

    <div id="spells-grid" class="spells-grid"></div>
  </main>

  <!-- Spell detail modal -->
  <div id="spell-modal" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="sm-title"></h2>
        <button class="modal-close-x" id="sm-close-btn">&times;</button>
      </div>
      <div class="modal-body">
        <div class="sm-meta" id="sm-meta"></div>
        <div class="sm-stats" id="sm-stats"></div>
        <div class="sm-components" id="sm-components"></div>
        <hr class="sm-divider" />
        <div class="sm-description" id="sm-description"></div>
      </div>
    </div>
  </div>

  <!-- Condition tooltip -->
  <div id="condition-tooltip" class="condition-tooltip-box" style="display:none"></div>

  <script is:inline type="module" src="/assets/js/spells.js"></script>
</Layout>
