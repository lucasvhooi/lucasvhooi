---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Create Account — DnD Campaign" showNav={false} extraCSS={['/assets/css/base.css']}>
  <style is:inline>
    body { display: flex; flex-direction: column; min-height: 100vh; }

    .login-wrap {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
    }

    .login-card {
      background: linear-gradient(160deg, #221508 0%, #181008 100%);
      border: 1px solid #3a2510;
      border-radius: 16px;
      padding: 40px 36px 32px;
      width: 100%;
      max-width: 380px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.7);
      animation: cardIn 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes cardIn {
      from { opacity: 0; transform: translateY(24px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0)    scale(1);    }
    }

    .login-logo {
      display: block;
      width: 64px;
      height: 64px;
      margin: 0 auto 18px;
      filter: brightness(0) saturate(100%) invert(84%) sepia(63%) saturate(600%) hue-rotate(315deg) brightness(108%);
    }

    .login-title {
      font-family: 'IM Fell English', 'Garamond', serif;
      font-size: 1.7rem;
      color: var(--accent);
      text-align: center;
      margin: 0 0 6px;
      letter-spacing: 0.05em;
    }

    .login-sub {
      text-align: center;
      color: #888;
      font-size: 13px;
      font-style: italic;
      margin: 0 0 28px;
    }

    .login-field { margin-bottom: 16px; }

    .login-label {
      display: block;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 6px;
    }

    .login-input {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid #3a2510;
      border-radius: 8px;
      padding: 11px 14px;
      color: var(--text);
      font-size: 15px;
      font-family: var(--font);
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .login-input:focus { border-color: var(--accent); }

    .color-row { display: flex; align-items: center; gap: 8px; }
    .color-row input[type="color"] {
      width: 42px; height: 40px;
      padding: 2px 4px;
      border: 1px solid #3a2510;
      border-radius: 7px;
      background: rgba(255,255,255,0.04);
      cursor: pointer;
      flex-shrink: 0;
    }
    .color-row .login-input { flex: 1; }
    .btn-reroll {
      background: rgba(255,255,255,0.05);
      border: 1px solid #3a2510;
      border-radius: 7px;
      color: #888;
      font-size: 16px;
      width: 40px; height: 40px;
      cursor: pointer;
      flex-shrink: 0;
      transition: background 0.2s, color 0.2s;
      display: flex; align-items: center; justify-content: center;
    }
    .btn-reroll:hover { background: rgba(255,255,255,0.1); color: var(--accent); }

    .login-btn {
      width: 100%;
      margin-top: 8px;
      background: linear-gradient(135deg, #4a2c0a 0%, #6b3e10 100%);
      border: 1px solid #c8a45c;
      border-radius: 8px;
      color: var(--accent);
      font-family: 'IM Fell English', 'Garamond', serif;
      font-size: 16px;
      letter-spacing: 0.08em;
      padding: 13px;
      cursor: pointer;
      transition: background 0.2s, box-shadow 0.2s, transform 0.2s;
    }
    .login-btn:hover {
      background: linear-gradient(135deg, #5a380f 0%, #7a4a18 100%);
      box-shadow: 0 0 16px rgba(200,164,92,0.25);
      transform: translateY(-1px);
    }
    .login-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .divider {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 20px 0;
      color: #444;
      font-size: 12px;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      border-top: 1px solid #2e1c0a;
    }

    .btn-google {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: rgba(255,255,255,0.05);
      border: 1px solid #3a2510;
      border-radius: 8px;
      color: #ccc;
      font-size: 14px;
      font-family: var(--font);
      padding: 11px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
    }
    .btn-google:hover { background: rgba(255,255,255,0.09); border-color: #555; }
    .btn-google:disabled { opacity: 0.5; cursor: not-allowed; }

    .login-error {
      background: rgba(200,50,50,0.12);
      border: 1px solid rgba(200,50,50,0.3);
      border-radius: 6px;
      color: #e07070;
      font-size: 13px;
      padding: 9px 12px;
      margin-top: 14px;
      display: none;
    }
    .login-error.show { display: block; }

    .login-footer {
      text-align: center;
      margin-top: 22px;
      font-size: 13px;
      color: #555;
    }
    .login-footer a { color: #c8a45c; text-decoration: none; }
    .login-footer a:hover { text-decoration: underline; }
  </style>

  <div class="login-wrap">
    <div class="login-card">
      <img src="/Images/EssolisLogo.webp" alt="Essolis" class="login-logo">
      <h1 class="login-title">Join the Realm</h1>
      <p class="login-sub">Create your adventurer account</p>

      <div class="login-field">
        <label class="login-label" for="r-name">Your Name</label>
        <input class="login-input" id="r-name" type="text" placeholder="Aragorn" autocomplete="off" />
      </div>
      <div class="login-field">
        <label class="login-label" for="r-email">Email</label>
        <input class="login-input" id="r-email" type="email" placeholder="your@email.com" autocomplete="email" />
      </div>
      <div class="login-field">
        <label class="login-label" for="r-pass">Password</label>
        <input class="login-input" id="r-pass" type="password" placeholder="At least 6 characters" autocomplete="new-password" />
      </div>
      <div class="login-field">
        <label class="login-label" for="r-pass2">Confirm Password</label>
        <input class="login-input" id="r-pass2" type="password" placeholder="Repeat password" autocomplete="new-password" />
      </div>
      <div class="login-field">
        <label class="login-label">Your Colour</label>
        <div class="color-row">
          <input id="r-color-pick" type="color" value="#c8a45c" />
          <input class="login-input" id="r-color-text" type="text" maxlength="7" placeholder="#c8a45c" />
          <button class="btn-reroll" id="btn-reroll" title="Random colour">↺</button>
        </div>
      </div>

      <button class="login-btn" id="btn-register">Create Account</button>

      <div class="divider">or</div>

      <button class="btn-google" id="btn-google">
        <svg width="18" height="18" viewBox="0 0 48 48">
          <path fill="#FFC107" d="M43.6 20H24v8h11.3C33.6 33.1 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20c11 0 19.7-8 19.7-20 0-1.3-.1-2.7-.1-4z"/>
          <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.5 16 19 13 24 13c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4c-7.7 0-14.4 4.2-17.7 10.7z"/>
          <path fill="#4CAF50" d="M24 44c5.2 0 9.9-1.9 13.5-5l-6.2-5.2C29.5 35.5 26.9 36.5 24 36.5c-5.2 0-9.6-3.5-11.2-8.2l-6.5 5C9.7 39.7 16.3 44 24 44z"/>
          <path fill="#1976D2" d="M43.6 20H24v8h11.3c-.8 2.3-2.3 4.3-4.3 5.8l6.2 5.2C41.2 35.8 44 30.3 44 24c0-1.3-.1-2.7-.4-4z"/>
        </svg>
        Continue with Google
      </button>

      <div class="login-error" id="login-error"></div>

      <p class="login-footer">Already have an account? <a href="login.html">Sign in</a></p>
    </div>
  </div>

  <script is:inline type="module">
    import { auth, db }                                          from "/assets/js/firebase.js";
    import { createUserWithEmailAndPassword, GoogleAuthProvider,
             signInWithPopup }                                   from "https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js";
    import { ref, get, set }                                     from "https://www.gstatic.com/firebasejs/10.14.1/firebase-database.js";
    import { saveSession, getSession }                           from "/assets/js/auth.js";

    if (getSession()) window.location.href = "inventory.html";

    function randomColor() {
      const h = Math.floor(Math.random() * 360);
      const s = 55 + Math.floor(Math.random() * 25);
      const l = 55 + Math.floor(Math.random() * 15);
      return hslToHex(h, s, l);
    }
    function hslToHex(h, s, l) {
      s /= 100; l /= 100;
      const a = s * Math.min(l, 1 - l);
      const f = n => { const k = (n + h / 30) % 12; return Math.round(255 * (l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1))).toString(16).padStart(2, '0'); };
      return `#${f(0)}${f(8)}${f(4)}`;
    }

    function setColor(hex) {
      document.getElementById('r-color-pick').value = hex;
      document.getElementById('r-color-text').value = hex;
    }

    setColor(randomColor());

    document.getElementById('r-color-pick').addEventListener('input', e => { document.getElementById('r-color-text').value = e.target.value; });
    document.getElementById('r-color-text').addEventListener('input', e => {
      if (/^#[0-9a-fA-F]{6}$/.test(e.target.value)) document.getElementById('r-color-pick').value = e.target.value;
    });
    document.getElementById('btn-reroll').addEventListener('click', () => setColor(randomColor()));

    const err = document.getElementById('login-error');
    function showErr(msg) { err.textContent = msg; err.classList.add('show'); }

    document.getElementById('btn-register').addEventListener('click', async () => {
      err.classList.remove('show');

      const name  = document.getElementById('r-name').value.trim();
      const email = document.getElementById('r-email').value.trim();
      const pass  = document.getElementById('r-pass').value;
      const pass2 = document.getElementById('r-pass2').value;
      const color = document.getElementById('r-color-text').value || randomColor();

      if (!name || !email || !pass) { showErr('Please fill in all fields.'); return; }
      if (pass.length < 6)          { showErr('Password must be at least 6 characters.'); return; }
      if (pass !== pass2)            { showErr('Passwords do not match.'); return; }

      const btn = document.getElementById('btn-register');
      btn.disabled = true; btn.textContent = 'Creating…';

      try {
        const cred = await createUserWithEmailAndPassword(auth, email, pass);
        const uid  = cred.user.uid;
        const profile = { username: name, role: 'player', color };
        await set(ref(db, `users/${uid}`), profile);
        saveSession({ id: uid, username: name, role: 'player', color });
        window.location.href = 'campaigns.html';
      } catch (e) {
        if (e.code === 'auth/email-already-in-use') {
          showErr('That email already has an account. Try signing in.');
        } else if (e.code === 'auth/invalid-email') {
          showErr('Please enter a valid email address.');
        } else {
          showErr('Something went wrong. Please try again.');
        }
        btn.disabled = false; btn.textContent = 'Create Account';
      }
    });

    document.getElementById('btn-google').addEventListener('click', async () => {
      err.classList.remove('show');
      const btnG = document.getElementById('btn-google');
      btnG.disabled = true; btnG.textContent = 'Signing in…';

      try {
        const cred = await signInWithPopup(auth, new GoogleAuthProvider());
        const uid  = cred.user.uid;
        const snap = await get(ref(db, `users/${uid}`));
        let profile = snap.val();

        if (!profile) {
          profile = { username: cred.user.displayName || 'Adventurer', role: 'player', color: randomColor() };
          await set(ref(db, `users/${uid}`), profile);
        }

        saveSession({ id: uid, username: profile.username, role: profile.role || 'player', color: profile.color || '#c8a45c' });
        window.location.href = 'campaigns.html';
      } catch (e) {
        if (e.code !== 'auth/popup-closed-by-user') showErr('Google sign-in failed. Please try again.');
        btnG.disabled = false;
        btnG.innerHTML = `<svg width="18" height="18" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.6 20H24v8h11.3C33.6 33.1 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20c11 0 19.7-8 19.7-20 0-1.3-.1-2.7-.1-4z"/><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.5 16 19 13 24 13c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4c-7.7 0-14.4 4.2-17.7 10.7z"/><path fill="#4CAF50" d="M24 44c5.2 0 9.9-1.9 13.5-5l-6.2-5.2C29.5 35.5 26.9 36.5 24 36.5c-5.2 0-9.6-3.5-11.2-8.2l-6.5 5C9.7 39.7 16.3 44 24 44z"/><path fill="#1976D2" d="M43.6 20H24v8h11.3c-.8 2.3-2.3 4.3-4.3 5.8l6.2 5.2C41.2 35.8 44 30.3 44 24c0-1.3-.1-2.7-.4-4z"/></svg> Continue with Google`;
      }
    });
  </script>
</Layout>
