---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import headerImg from '../../Images/Headers/CampaignsPageHeader.png';
---
<Layout title="Quests — Essolis" activePage="missions" extraCSS={['/assets/css/missions.css']}>

  <Header
    title="Quests"
    description="Missions and adventures across Enora"
    icon="game-icons:crossed-swords"
    image={headerImg}
  >
    <div slot="tabs" class="hdr-tabs-row">
      <div class="hdr-search-wrap">
        <iconify-icon icon="lucide:search" class="hdr-search-icon"></iconify-icon>
        <input type="text" id="quest-search" class="items-search" placeholder="Search quests, NPCs, items, places…" />
        <button type="button" id="quest-search-clear" class="search-clear-btn" aria-label="Clear search">
          <iconify-icon icon="lucide:x"></iconify-icon>
        </button>
      </div>
      <div class="quest-filter-tabs">
        <button class="quest-tab active" data-filter="all">All</button>
        <button class="quest-tab" data-filter="main">
          <iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Main
        </button>
        <button class="quest-tab" data-filter="side">
          <iconify-icon icon="lucide:sparkles"></iconify-icon> Side
        </button>
        <button class="quest-tab" data-filter="active">Active</button>
        <button class="quest-tab" data-filter="completed">Completed</button>
      </div>
      <button id="quest-add-btn" class="items-btn-add" style="display:none">
        <iconify-icon icon="lucide:plus"></iconify-icon>
        New Quest
      </button>
    </div>
  </Header>

  <main class="quest-page-main">
    <div class="items-filter-bar quest-filter-bar">
      <div class="quest-stats-row">
        <div class="quest-stat-item">
          <span id="qs-completed" class="quest-stat-count">0</span>
          <span class="quest-stat-label">Completed</span>
        </div>
        <div class="quest-stat-divider"></div>
        <div class="quest-stat-item">
          <span id="qs-main" class="quest-stat-count">0</span>
          <span class="quest-stat-label">Main<span class="qs-suffix"> Quests</span></span>
        </div>
        <div class="quest-stat-divider"></div>
        <div class="quest-stat-item">
          <span id="qs-side" class="quest-stat-count">0</span>
          <span class="quest-stat-label">Side<span class="qs-suffix"> Quests</span></span>
        </div>
      </div>
      <select id="quest-filter-select" class="quest-filter-select" aria-label="Filter quests">
        <option value="all">All Quests</option>
        <option value="main">Main</option>
        <option value="side">Side</option>
        <option value="active">Active</option>
        <option value="completed">Completed</option>
      </select>
    </div>
    <div id="quest-grid" class="quest-grid"></div>
    <p id="quest-empty" class="quest-empty" style="display:none">No quests found.</p>
  </main>

  <!-- Quest Editor Modal — OneNote-style sidebar layout -->
  <div id="quest-modal" class="modal-overlay">
    <div class="modal-box quest-edit-box">

      <!-- Top bar -->
      <div class="qm-topbar">
        <div class="qm-topbar-left">
          <iconify-icon icon="game-icons:crossed-swords" class="qm-topbar-icon"></iconify-icon>
          <span id="qm-title" style="display:none"></span>
          <input type="text" id="qm-name" class="qm-input qm-topbar-name" placeholder="Quest title…" />
          <div class="qm-location-wrap">
            <input type="text" id="qm-location" class="qm-input qm-topbar-loc" placeholder="Location…" autocomplete="off" />
            <div id="qm-location-drop" class="loc-dropdown" style="display:none"></div>
          </div>
          <div class="quest-type-selector" id="qm-type-selector">
            <button type="button" class="quest-type-btn active" data-type="main"><iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Main</button>
            <button type="button" class="quest-type-btn" data-type="side"><iconify-icon icon="lucide:sparkles"></iconify-icon> Side</button>
          </div>
          <select id="qm-status" class="qm-select qm-topbar-status">
            <option value="not_started">Not Started</option>
            <option value="active">Active</option>
            <option value="completed">Completed</option>
          </select>
          <label class="qm-toggle-label qm-topbar-vis">
            <input type="checkbox" id="qm-discovered" class="qm-toggle-input" />
            <span class="qm-toggle-track"><span class="qm-toggle-thumb"></span></span>
            <span class="qm-toggle-text">Visible</span>
          </label>
        </div>
        <div class="qm-topbar-center">
          <button id="qm-undo-btn" class="qm-topbar-btn" title="Undo (Ctrl+Z)" disabled>
            <iconify-icon icon="lucide:undo-2" class="qm-topbar-btn-icon"></iconify-icon>
            <span class="qm-topbar-btn-label">Undo</span>
          </button>
          <button id="qm-redo-btn" class="qm-topbar-btn" title="Redo (Ctrl+Y)" disabled>
            <iconify-icon icon="lucide:redo-2" class="qm-topbar-btn-icon"></iconify-icon>
            <span class="qm-topbar-btn-label">Redo</span>
          </button>
          <div class="qm-topbar-divider"></div>
          <span id="qm-autosave-status" class="qm-autosave-status" title="Draft is saved locally">
            <span class="qm-autosave-dot"></span>
            <span class="qm-autosave-text">All changes saved</span>
          </span>
        </div>
        <div class="qm-topbar-right">
          <button id="qm-zoom-reset-btn" class="qm-topbar-btn" title="Reset zoom/pan">
            <iconify-icon icon="lucide:maximize" class="qm-topbar-btn-icon"></iconify-icon>
            <span class="qm-topbar-btn-label">Reset view</span>
          </button>
          <button id="qm-preview-toggle" class="qm-topbar-btn qm-preview-btn" title="Preview as players see it">
            <iconify-icon icon="lucide:eye" class="qm-topbar-btn-icon"></iconify-icon>
            <span class="qm-topbar-btn-label">Preview</span>
          </button>
          <button class="qm-close-btn" id="qm-cancel" title="Close (Esc)"><iconify-icon icon="lucide:x"></iconify-icon></button>
        </div>
      </div>

      <!-- Draft restore banner -->
      <div id="qm-draft-banner" class="qm-draft-banner" style="display:none">
        <iconify-icon icon="lucide:save" class="qm-draft-banner-icon"></iconify-icon>
        <span class="qm-draft-banner-text">Unsaved draft found from <span id="qm-draft-time">earlier</span>.</span>
        <button type="button" id="qm-draft-restore" class="qm-draft-banner-btn qm-draft-banner-primary">Restore</button>
        <button type="button" id="qm-draft-discard" class="qm-draft-banner-btn">Discard</button>
      </div>

      <!-- Two-column body: sidebar + canvas -->
      <div class="qm-body">

        <!-- Left sidebar -->
        <aside class="qm-sidebar">
          <div class="qm-sidebar-tabs">
            <button type="button" class="qm-sidebar-tab active" data-tab="content"><iconify-icon icon="lucide:layout-grid"></iconify-icon> Content</button>
            <button type="button" class="qm-sidebar-tab" data-tab="outline"><iconify-icon icon="lucide:list-tree"></iconify-icon> Outline</button>
            <button type="button" class="qm-sidebar-tab" data-tab="details"><iconify-icon icon="lucide:scroll-text"></iconify-icon> Details</button>
          </div>

          <div class="qm-sidebar-pane" data-pane="content">
          <div class="qm-sidebar-section">
            <div class="qm-sidebar-label">Add content</div>
            <button type="button" class="qm-add-block-btn" data-block-type="text"      title="Paragraph of text"><iconify-icon icon="lucide:type" class="qm-ab-icon"></iconify-icon><span class="qm-ab-text">Text</span></button>
            <button type="button" class="qm-add-block-btn" data-block-type="phase"     title="Quest phase / step"><iconify-icon icon="lucide:chevron-right" class="qm-ab-icon qm-ab-phase"></iconify-icon><span class="qm-ab-text">Phase</span></button>
            <button type="button" class="qm-add-block-btn" data-block-type="loot"      title="Loot / rewards"><iconify-icon icon="game-icons:open-treasure-chest" class="qm-ab-icon qm-ab-loot"></iconify-icon><span class="qm-ab-text">Loot</span></button>
            <button type="button" class="qm-add-block-btn" data-block-type="boss"      title="Enemy list (reference only)"><iconify-icon icon="game-icons:death-skull" class="qm-ab-icon qm-ab-boss"></iconify-icon><span class="qm-ab-text">Enemy</span></button>
            <button type="button" class="qm-add-block-btn" data-block-type="encounter" title="Encounter — launch directly to combat"><iconify-icon icon="game-icons:crossed-swords" class="qm-ab-icon qm-ab-encounter"></iconify-icon><span class="qm-ab-text">Encounter</span></button>
            <button type="button" class="qm-add-block-btn" data-block-type="puzzle"    title="Puzzle / riddle"><iconify-icon icon="game-icons:puzzle" class="qm-ab-icon qm-ab-puzzle"></iconify-icon><span class="qm-ab-text">Puzzle</span></button>
            <button type="button" class="qm-add-block-btn" data-block-type="character" title="Character / NPC"><iconify-icon icon="lucide:user" class="qm-ab-icon qm-ab-char"></iconify-icon><span class="qm-ab-text">Character</span></button>
            <button type="button" class="qm-add-block-btn" data-block-type="loreref"   title="Lore reference"><iconify-icon icon="game-icons:bookshelf" class="qm-ab-icon qm-ab-lore"></iconify-icon><span class="qm-ab-text">Lore</span></button>
            <button type="button" class="qm-add-block-btn" data-block-type="note"      title="DM-only note"><iconify-icon icon="lucide:file-text" class="qm-ab-icon qm-ab-note"></iconify-icon><span class="qm-ab-text">DM Note</span></button>
          </div>

          <div class="qm-sidebar-section qm-sidebar-templates">
            <div class="qm-sidebar-label">Templates</div>
            <button type="button" class="qm-template-btn" data-template="boss-fight" title="Enemy + Loot + Phase">
              <iconify-icon icon="game-icons:crossed-swords" class="qm-ab-icon"></iconify-icon>
              <span class="qm-ab-text">Boss Fight</span>
            </button>
            <button type="button" class="qm-template-btn" data-template="investigation" title="Character + Puzzle + Lore">
              <iconify-icon icon="lucide:search" class="qm-ab-icon"></iconify-icon>
              <span class="qm-ab-text">Investigation</span>
            </button>
            <button type="button" class="qm-template-btn" data-template="dungeon-room" title="Phase + Enemy + Loot">
              <iconify-icon icon="lucide:building-2" class="qm-ab-icon"></iconify-icon>
              <span class="qm-ab-text">Dungeon Room</span>
            </button>
            <button type="button" class="qm-template-btn" data-template="social-scene" title="Character + Text + DM Note">
              <iconify-icon icon="lucide:message-circle" class="qm-ab-icon"></iconify-icon>
              <span class="qm-ab-text">Social Scene</span>
            </button>
            <button type="button" class="qm-template-btn" data-template="travel-encounter" title="Phase + Enemy">
              <iconify-icon icon="lucide:map" class="qm-ab-icon"></iconify-icon>
              <span class="qm-ab-text">Travel</span>
            </button>
          </div>

          <div class="qm-sidebar-help">
            <div class="qm-sidebar-help-title">Tips</div>
            <ul>
              <li>Click a block above to add it.</li>
              <li>Drag the header to move blocks.</li>
              <li>Left-drag empty space to select blocks.</li>
              <li>Middle-drag to pan the canvas.</li>
              <li><span class="qm-kbd">Ctrl+G</span> group selected blocks.</li>
              <li><span class="qm-kbd">Ctrl+C</span> copy, <span class="qm-kbd">Ctrl+V</span> paste.</li>
              <li><span class="qm-kbd">Del</span> delete selected blocks.</li>
              <li><span class="qm-kbd">@</span> mentions a character.</li>
              <li><span class="qm-kbd">#</span> links another quest.</li>
              <li><span class="qm-kbd">Ctrl+Z</span> undo, <span class="qm-kbd">Ctrl+Y</span> redo.</li>
            </ul>
          </div>
          </div><!-- /content pane -->

          <div class="qm-sidebar-pane" data-pane="outline" hidden>
            <div class="qm-sidebar-label">Quest outline</div>
            <p class="qm-outline-hint">Click an item to focus it on the canvas. Use the arrows to reorder.</p>
            <div id="qm-outline" class="qm-outline"></div>
          </div><!-- /outline pane -->

          <div class="qm-sidebar-pane" data-pane="details" hidden>
            <!-- Quest giver -->
            <div class="qm-detail-section">
              <div class="qm-sidebar-label">Quest giver</div>
              <div id="qm-giver-selected" class="qm-giver-selected" style="display:none"></div>
              <div class="qm-detail-search-wrap">
                <input type="text" id="qm-giver-search" class="qm-input qm-detail-input" placeholder="Search characters…" autocomplete="off" />
                <div id="qm-giver-drop" class="loc-dropdown" style="display:none"></div>
              </div>
            </div>

            <!-- Rewards -->
            <div class="qm-detail-section">
              <div class="qm-sidebar-label">Rewards</div>
              <div class="qm-reward-row">
                <label class="qm-reward-field">
                  <span class="qm-reward-icon"><iconify-icon icon="game-icons:sparkles"></iconify-icon> XP</span>
                  <input type="number" id="qm-reward-xp" class="qm-input qm-detail-input" min="0" placeholder="0" />
                </label>
                <label class="qm-reward-field">
                  <span class="qm-reward-icon"><iconify-icon icon="game-icons:two-coins"></iconify-icon> Gold</span>
                  <input type="number" id="qm-reward-gold" class="qm-input qm-detail-input" min="0" placeholder="0" />
                </label>
              </div>
              <div class="qm-detail-search-wrap">
                <input type="text" id="qm-reward-item-search" class="qm-input qm-detail-input" placeholder="Add item reward…" autocomplete="off" />
                <div id="qm-reward-item-drop" class="loc-dropdown" style="display:none"></div>
              </div>
              <div id="qm-reward-items" class="qm-reward-items"></div>
            </div>

            <!-- Recommended level -->
            <div class="qm-detail-section">
              <div class="qm-sidebar-label">Recommended level</div>
              <input type="text" id="qm-reclevel" class="qm-input qm-detail-input" placeholder="e.g. 3–5" />
            </div>

            <!-- Objectives -->
            <div class="qm-detail-section">
              <div class="qm-sidebar-label">Objectives</div>
              <div id="qm-obj-list" class="qm-obj-list"></div>
              <div class="qm-obj-add-row">
                <input type="text" id="qm-obj-input" class="qm-input qm-detail-input" placeholder="Add an objective…" />
                <button type="button" id="qm-obj-add" class="qm-detail-add-btn" title="Add objective"><iconify-icon icon="lucide:plus"></iconify-icon></button>
              </div>
            </div>

            <!-- Prerequisites -->
            <div class="qm-detail-section">
              <div class="qm-sidebar-label">Requires (prerequisite quests)</div>
              <div id="qm-prereq-list" class="qm-prereq-list"></div>
              <div class="qm-detail-search-wrap">
                <input type="text" id="qm-prereq-search" class="qm-input qm-detail-input" placeholder="Link a prerequisite quest…" autocomplete="off" />
                <div id="qm-prereq-drop" class="loc-dropdown" style="display:none"></div>
              </div>
            </div>
          </div><!-- /details pane -->
        </aside>

        <!-- Right: main canvas -->
        <section class="qm-canvas-wrap">
          <div id="qm-block-canvas" class="qm-block-canvas"></div>
          <div id="qm-error" class="modal-error"></div>
        </section>
      </div>

      <!-- Sticky footer -->
      <div class="qm-footer">
        <button id="qm-cancel-footer" class="qm-cancel-btn" type="button">Cancel</button>
        <button id="qm-save" class="dm-btn qm-save-btn">Save Quest</button>
      </div>

    </div>
  </div>

  <!-- Quest View Overlay -->
  <div id="quest-view" class="qview-overlay">
    <header class="qview-header">
      <button id="qview-back" class="qview-back-btn"><iconify-icon icon="lucide:arrow-left"></iconify-icon> Back</button>
      <div id="qview-title-area" class="qview-title-area"></div>
      <div id="qview-admin-btns" class="qview-admin-btns"></div>
    </header>
    <div id="qview-session-bar" class="qview-session-bar" style="display:none"></div>
    <div id="qview-canvas-wrap" class="qview-canvas-wrap"></div>
  </div>

  <script is:inline type="module" src="/assets/js/missions.js"></script>
</Layout>
