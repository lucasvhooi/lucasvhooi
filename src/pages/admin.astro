---
import Layout from '../layouts/Layout.astro';
---
<Layout title="User Management — DM Panel" showNav={false} extraCSS={['/assets/css/base.css']}>
  <style is:inline>
    body { max-width: 680px; margin: 0 auto; padding: 40px 20px 80px; }

    .admin-title {
      font-family: 'IM Fell English', 'Garamond', serif;
      font-size: 1.8rem;
      color: var(--accent);
      margin: 0 0 4px;
    }
    .admin-sub { color: #666; font-size: 13px; margin: 0 0 36px; }

    .section-label {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #888;
      margin: 0 0 14px;
    }

    .create-card {
      background: linear-gradient(160deg, #1c1006 0%, #150d05 100%);
      border: 1px solid #3a2510;
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 36px;
    }
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    .form-grid .full { grid-column: 1 / -1; }
    .field label {
      display: block;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 5px;
    }
    .field input, .field select {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid #3a2510;
      border-radius: 7px;
      padding: 10px 12px;
      color: var(--text);
      font-size: 14px;
      font-family: var(--font);
      outline: none;
      box-sizing: border-box;
      transition: border-color 0.2s;
    }
    .field input:focus, .field select:focus { border-color: var(--accent); }
    .field select option { background: #1c1006; }

    .color-row { display: flex; align-items: center; gap: 10px; }
    .color-row input[type="color"] {
      width: 40px; height: 36px;
      padding: 2px 4px;
      border-radius: 6px;
      flex-shrink: 0;
      cursor: pointer;
    }
    .color-row input[type="text"] { flex: 1; }

    .btn-create {
      margin-top: 18px;
      width: 100%;
      background: linear-gradient(135deg, #4a2c0a 0%, #6b3e10 100%);
      border: 1px solid var(--accent);
      border-radius: 8px;
      color: var(--accent);
      font-family: 'IM Fell English', 'Garamond', serif;
      font-size: 15px;
      letter-spacing: 0.06em;
      padding: 12px;
      cursor: pointer;
      transition: background 0.2s, box-shadow 0.2s;
    }
    .btn-create:hover { background: linear-gradient(135deg, #5a380f 0%, #7a4a18 100%); box-shadow: 0 0 14px rgba(200,164,92,0.2); }
    .btn-create:disabled { opacity: 0.5; cursor: not-allowed; }

    .form-msg {
      margin-top: 12px;
      font-size: 13px;
      padding: 8px 12px;
      border-radius: 6px;
      display: none;
    }
    .form-msg.error   { background: rgba(200,50,50,0.12); border: 1px solid rgba(200,50,50,0.3); color: #e07070; display: block; }
    .form-msg.success { background: rgba(50,180,80,0.1);  border: 1px solid rgba(50,180,80,0.3);  color: #6dbf7a; display: block; }

    .cred-box {
      margin-top: 12px;
      background: rgba(255,255,255,0.04);
      border: 1px solid #3a2510;
      border-radius: 8px;
      padding: 14px 16px;
      display: none;
    }
    .cred-box.show { display: block; }
    .cred-box-title { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #888; margin: 0 0 10px; }
    .cred-row { display: flex; align-items: center; gap: 8px; margin-bottom: 7px; }
    .cred-row:last-child { margin-bottom: 0; }
    .cred-label { font-size: 11px; color: #666; width: 64px; flex-shrink: 0; }
    .cred-val {
      font-family: monospace;
      font-size: 13px;
      color: var(--accent);
      background: rgba(200,164,92,0.08);
      border: 1px solid rgba(200,164,92,0.2);
      border-radius: 5px;
      padding: 4px 10px;
      flex: 1;
      word-break: break-all;
    }
    .btn-copy {
      background: none;
      border: 1px solid #3a2510;
      border-radius: 5px;
      color: #888;
      font-size: 11px;
      padding: 4px 8px;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
    }
    .btn-copy:hover { color: var(--accent); border-color: var(--accent); }

    .user-list { display: flex; flex-direction: column; gap: 10px; }

    .user-row {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #1a0f06;
      border: 1px solid #2e1c0a;
      border-radius: 10px;
      padding: 14px 16px;
    }
    .user-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .user-info { flex: 1; min-width: 0; }
    .user-name { font-size: 15px; color: var(--text); }
    .user-meta { font-size: 12px; color: #666; margin-top: 2px; }
    .user-role {
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 4px;
      flex-shrink: 0;
    }
    .user-role.admin  { background: rgba(200,164,92,0.15); color: var(--accent); border: 1px solid rgba(200,164,92,0.3); }
    .user-role.player { background: rgba(255,255,255,0.05); color: #666; border: 1px solid #2e1c0a; }

    .btn-delete {
      background: none;
      border: 1px solid #3a1a1a;
      border-radius: 6px;
      color: #7a3030;
      font-size: 12px;
      padding: 5px 10px;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
      flex-shrink: 0;
    }
    .btn-delete:hover { border-color: #c05050; color: #e07070; }

    .empty-users { color: #555; font-size: 13px; font-style: italic; padding: 12px 0; }

    .loading { color: #555; font-size: 13px; padding: 12px 0; }

    .user-item { display: flex; flex-direction: column; }

    .btn-edit {
      background: none;
      border: 1px solid #3a2510;
      border-radius: 6px;
      color: #664;
      font-size: 12px;
      padding: 5px 8px;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
      flex-shrink: 0;
      line-height: 1;
    }
    .btn-edit:hover { border-color: var(--accent); color: var(--accent); }

    .user-edit-panel {
      display: none;
      background: rgba(255,255,255,0.02);
      border: 1px solid #3a2510;
      border-top: none;
      border-radius: 0 0 10px 10px;
      padding: 16px;
    }
    .user-edit-panel.open { display: block; }

    .edit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
      margin-bottom: 14px;
    }

    .edit-actions { display: flex; gap: 8px; align-items: center; }

    .btn-edit-save {
      background: linear-gradient(135deg, #2a1c06 0%, #3a2810 100%);
      border: 1px solid var(--accent);
      border-radius: 6px;
      color: var(--accent);
      font-size: 13px;
      padding: 7px 14px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-edit-save:hover { background: linear-gradient(135deg, #3a2810 0%, #4a3818 100%); }
    .btn-edit-save:disabled { opacity: 0.4; cursor: not-allowed; }

    .btn-edit-cancel {
      background: none;
      border: 1px solid #3a2510;
      border-radius: 6px;
      color: #666;
      font-size: 13px;
      padding: 7px 14px;
      cursor: pointer;
    }
    .btn-edit-cancel:hover { border-color: #666; color: #999; }

    .edit-msg { font-size: 12px; margin-left: 4px; }
    .edit-msg.ok  { color: #6dbf7a; }
    .edit-msg.err { color: #e07070; }

    .ep-divider { height: 1px; background: #2e1c0a; margin: 16px 0; }
    .ep-section-label {
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #666;
      margin: 0 0 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .ep-placeholder-badge {
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 4px;
      background: rgba(200,164,92,0.12);
      border: 1px solid rgba(200,164,92,0.25);
      color: var(--accent);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .ep-current-email {
      font-size: 11px;
      color: #555;
      font-family: monospace;
      margin: -6px 0 12px;
    }
    .ep-creds-note { font-size: 12px; color: #555; font-style: italic; }
    .btn-update-creds, .btn-set-creds {
      background: linear-gradient(135deg, #0d1a0e 0%, #122014 100%);
      border: 1px solid rgba(100,180,120,0.4);
      border-radius: 6px;
      color: #6dbf7a;
      font-size: 13px;
      padding: 7px 14px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-update-creds:hover, .btn-set-creds:hover { background: linear-gradient(135deg, #152314 0%, #1a2e1a 100%); }
    .btn-update-creds:disabled, .btn-set-creds:disabled { opacity: 0.4; cursor: not-allowed; }

    .invite-card {
      background: linear-gradient(160deg, #0e1a10 0%, #0a1209 100%);
      border: 1px solid rgba(100,180,120,0.25);
      border-radius: 12px;
      padding: 20px 24px;
      margin-bottom: 36px;
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .invite-label-block { flex: 1; min-width: 160px; }
    .invite-card-title { font-size: 13px; color: #6dbf7a; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
    .invite-code-display {
      font-family: monospace;
      font-size: 1.1rem;
      color: var(--text);
      letter-spacing: 0.1em;
      background: rgba(255,255,255,0.04);
      border: 1px solid #2e1c0a;
      border-radius: 6px;
      padding: 6px 12px;
      display: inline-block;
      min-width: 120px;
    }
    .invite-input-row { display: flex; gap: 8px; align-items: center; }
    .invite-input {
      background: rgba(255,255,255,0.04);
      border: 1px solid #3a2510;
      border-radius: 7px;
      padding: 8px 12px;
      color: var(--text);
      font-size: 14px;
      font-family: monospace;
      outline: none;
      width: 180px;
      transition: border-color 0.2s;
    }
    .invite-input:focus { border-color: #6dbf7a; }
    .btn-invite {
      background: rgba(100,180,120,0.1);
      border: 1px solid rgba(100,180,120,0.35);
      border-radius: 7px;
      color: #6dbf7a;
      font-size: 13px;
      padding: 8px 14px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .btn-invite:hover { background: rgba(100,180,120,0.18); border-color: rgba(100,180,120,0.6); }
    .btn-invite:disabled { opacity: 0.5; cursor: not-allowed; }
    .invite-msg { font-size: 12px; margin-top: 6px; }
    .invite-msg.ok  { color: #6dbf7a; }
    .invite-msg.err { color: #e07070; }

    .migrate-card {
      background: linear-gradient(160deg, #0e1215 0%, #090d10 100%);
      border: 1px solid rgba(90,140,200,0.25);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 36px;
    }
    .migrate-card-title { font-size: 13px; color: #7eb8ff; letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 4px; }
    .migrate-card-sub   { font-size: 12px; color: #555; margin: 0 0 18px; }
    .migrate-row        { display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 16px; }
    .migrate-row .field { flex: 1; min-width: 180px; }
    .migrate-nodes {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px 16px;
      margin-bottom: 16px;
    }
    .migrate-node-check { display: flex; align-items: center; gap: 7px; font-size: 13px; color: #aaa; cursor: pointer; }
    .migrate-node-check input[type="checkbox"] { accent-color: #7eb8ff; width: 14px; height: 14px; cursor: pointer; }
    .migrate-options { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #aaa; margin-bottom: 16px; }
    .migrate-options input[type="checkbox"] { accent-color: #e07070; cursor: pointer; }
    .btn-migrate {
      background: rgba(90,140,200,0.1);
      border: 1px solid rgba(90,140,200,0.35);
      border-radius: 8px;
      color: #7eb8ff;
      font-size: 14px;
      padding: 11px 20px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
    }
    .btn-migrate:hover { background: rgba(90,140,200,0.18); border-color: rgba(90,140,200,0.6); }
    .btn-migrate:disabled { opacity: 0.4; cursor: not-allowed; }
    .migrate-status {
      margin-top: 12px;
      font-size: 13px;
      padding: 8px 12px;
      border-radius: 6px;
      display: none;
      white-space: pre-wrap;
    }
    .migrate-status.running { background: rgba(90,140,200,0.1); border: 1px solid rgba(90,140,200,0.3); color: #7eb8ff; display: block; }
    .migrate-status.done    { background: rgba(50,180,80,0.1);  border: 1px solid rgba(50,180,80,0.3);  color: #6dbf7a; display: block; }
    .migrate-status.error   { background: rgba(200,50,50,0.12); border: 1px solid rgba(200,50,50,0.3);  color: #e07070; display: block; }
  </style>

  <h1 class="admin-title">User Management</h1>
  <p class="admin-sub">Create and remove player accounts. Only the DM can access this page.</p>

  <p class="section-label">Invite Code</p>
  <div class="invite-card">
    <div class="invite-label-block">
      <div class="invite-card-title">Current code</div>
      <span class="invite-code-display" id="invite-current">Loading…</span>
    </div>
    <div>
      <div class="invite-input-row">
        <input class="invite-input" id="invite-new" type="text" placeholder="New code…" maxlength="40" />
        <button class="btn-invite" id="btn-invite-save">Save</button>
        <button class="btn-invite" id="btn-invite-gen" title="Generate random code">↺</button>
      </div>
      <div class="invite-msg" id="invite-msg"></div>
    </div>
  </div>

  <p class="section-label">Add New User</p>
  <div class="create-card">
    <div class="form-grid">
      <div class="field full">
        <label for="f-email">Email <span style="color:#666;font-size:10px;text-transform:none;letter-spacing:0">(leave blank to auto-generate placeholder)</span></label>
        <input id="f-email" type="email" placeholder="player@example.com  —  optional" autocomplete="off" />
      </div>
      <div class="field">
        <label for="f-username">Display Name</label>
        <input id="f-username" type="text" placeholder="Aragorn" autocomplete="off" />
      </div>
      <div class="field">
        <label for="f-password">Temporary Password <span style="color:#666;font-size:10px;text-transform:none;letter-spacing:0">(auto-generated if blank)</span></label>
        <input id="f-password" type="password" placeholder="optional" autocomplete="new-password" />
      </div>
      <div class="field">
        <label for="f-role">Role</label>
        <select id="f-role">
          <option value="player">Player</option>
          <option value="admin">DM / Admin</option>
        </select>
      </div>
      <div class="field">
        <label>Player Colour</label>
        <div class="color-row">
          <input id="f-color-pick" type="color" value="#c8a45c" />
          <input id="f-color-text" type="text"  value="#c8a45c" maxlength="7" placeholder="#c8a45c" />
        </div>
      </div>
    </div>
    <button class="btn-create" id="btn-create">
      <iconify-icon icon="lucide:user-plus"></iconify-icon> Create Account
    </button>
    <div class="form-msg" id="form-msg"></div>
    <div class="cred-box" id="cred-box">
      <p class="cred-box-title">Share these login details with the player</p>
      <div class="cred-row">
        <span class="cred-label">Email</span>
        <span class="cred-val" id="cred-email"></span>
        <button class="btn-copy" data-target="cred-email">Copy</button>
      </div>
      <div class="cred-row">
        <span class="cred-label">Password</span>
        <span class="cred-val" id="cred-pw"></span>
        <button class="btn-copy" data-target="cred-pw">Copy</button>
      </div>
    </div>
  </div>

  <p class="section-label">Existing Users</p>
  <div class="user-list" id="user-list">
    <p class="loading">Loading…</p>
  </div>

  <p class="section-label" style="margin-top:40px">Migrate Legacy Data</p>
  <div class="migrate-card">
    <p class="migrate-card-title">Copy root data into a campaign</p>
    <p class="migrate-card-sub">Copies top-level Firebase nodes (lore, spells, items, etc.) into the selected campaign. Run this once after creating your first campaign to preserve existing data.</p>
    <div class="migrate-row">
      <div class="field">
        <label for="mg-campaign">Target Campaign</label>
        <select id="mg-campaign">
          <option value="">— select campaign —</option>
        </select>
      </div>
    </div>
    <p style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#666;margin:0 0 8px">Nodes to copy</p>
    <div class="migrate-nodes" id="mg-nodes">
      <label class="migrate-node-check"><input type="checkbox" value="quests" checked> quests</label>
      <label class="migrate-node-check"><input type="checkbox" value="markers" checked> markers</label>
      <label class="migrate-node-check"><input type="checkbox" value="countries" checked> countries</label>
      <label class="migrate-node-check"><input type="checkbox" value="items" checked> items</label>
      <label class="migrate-node-check"><input type="checkbox" value="inventory" checked> inventory</label>
      <label class="migrate-node-check"><input type="checkbox" value="lore" checked> lore</label>
      <label class="migrate-node-check"><input type="checkbox" value="spells" disabled style="opacity:0.4"> spells (global — not migrated)</label>
      <label class="migrate-node-check"><input type="checkbox" value="spellbook" checked> spellbook</label>
      <label class="migrate-node-check"><input type="checkbox" value="characters" checked> characters</label>
      <label class="migrate-node-check"><input type="checkbox" value="enemyTemplates" checked> enemyTemplates</label>
      <label class="migrate-node-check"><input type="checkbox" value="attunements" checked> attunements</label>
      <label class="migrate-node-check"><input type="checkbox" value="locations" checked> locations</label>
    </div>
    <div class="migrate-options">
      <input type="checkbox" id="mg-delete-after">
      <label for="mg-delete-after" style="cursor:pointer">Delete originals from root after copying</label>
    </div>
    <button class="btn-migrate" id="btn-migrate">Run Migration</button>
    <div class="migrate-status" id="mg-status"></div>
  </div>

  <p class="section-label" style="margin-top:40px">NPC Name Tables</p>
  <div class="migrate-card">
    <p class="migrate-card-title">Export name tables to Firebase</p>
    <p class="migrate-card-sub">Writes all NPC_NAMES to <code style="background:rgba(255,255,255,0.06);padding:1px 5px;border-radius:4px">campaigns/&lt;id&gt;/npcNames</code> in the database. Useful for external tooling or customisation.</p>
    <div class="migrate-row">
      <div class="field">
        <label for="npc-campaign">Target Campaign</label>
        <select id="npc-campaign">
          <option value="">— select campaign —</option>
        </select>
      </div>
    </div>
    <button class="btn-migrate" id="btn-export-names">Export NPC Names</button>
    <div class="migrate-status" id="npc-export-status"></div>
  </div>

  <script is:inline type="module">
    import { firebaseApp, auth, db }               from "/assets/js/firebase.js";
    import { getSession }                          from "/assets/js/auth.js";
    import { NPC_NAMES }                           from "/assets/js/npc-data.js";
    import { initializeApp, getApp }               from "https://www.gstatic.com/firebasejs/10.14.1/firebase-app.js";
    import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword,
             updateEmail, updatePassword, signOut as secondarySignOut }
                                                   from "https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js";
    import { ref, get, set, remove }               from "https://www.gstatic.com/firebasejs/10.14.1/firebase-database.js";

    const session = getSession();
    if (!session) { window.location.href = 'campaigns'; throw new Error(); }

    // Verify admin role against Firebase, not just localStorage
    const roleSnap = await get(ref(db, `users/${session.id}/role`));
    if (roleSnap.val() !== 'admin') {
      window.location.href = 'campaigns';
      throw new Error();
    }

    // ── Invite code management ─────────────────────────────────────────────
    const inviteDisplay = document.getElementById('invite-current');
    const inviteInput   = document.getElementById('invite-new');
    const inviteMsg     = document.getElementById('invite-msg');

    async function loadInviteCode() {
      const snap = await get(ref(db, 'settings/invite_code'));
      inviteDisplay.textContent = snap.val() || '(none set)';
    }
    loadInviteCode();

    function randomCode() {
      return Math.random().toString(36).slice(2, 8).toUpperCase() +
             Math.random().toString(36).slice(2, 6).toUpperCase();
    }

    document.getElementById('btn-invite-gen').addEventListener('click', () => {
      inviteInput.value = randomCode();
    });

    document.getElementById('btn-invite-save').addEventListener('click', async () => {
      const code = inviteInput.value.trim();
      if (!code) { inviteMsg.textContent = 'Enter a code first.'; inviteMsg.className = 'invite-msg err'; return; }
      const btn = document.getElementById('btn-invite-save');
      btn.disabled = true;
      try {
        await set(ref(db, 'settings/invite_code'), code);
        inviteDisplay.textContent = code;
        inviteInput.value = '';
        inviteMsg.textContent = 'Saved.';
        inviteMsg.className = 'invite-msg ok';
      } catch {
        inviteMsg.textContent = 'Failed to save.';
        inviteMsg.className = 'invite-msg err';
      }
      btn.disabled = false;
      setTimeout(() => { inviteMsg.textContent = ''; inviteMsg.className = 'invite-msg'; }, 3000);
    });

    let secondaryApp;
    try   { secondaryApp = getApp('dm-secondary'); }
    catch { secondaryApp = initializeApp(firebaseApp.options, 'dm-secondary'); }
    const secondaryAuth = getAuth(secondaryApp);

    const colorPick = document.getElementById('f-color-pick');
    const colorText = document.getElementById('f-color-text');
    colorPick.addEventListener('input', () => { colorText.value = colorPick.value; });
    colorText.addEventListener('input', () => {
      if (/^#[0-9a-fA-F]{6}$/.test(colorText.value)) colorPick.value = colorText.value;
    });

    const listEl = document.getElementById('user-list');

    async function loadUsers() {
      listEl.innerHTML = '<p class="loading">Loading…</p>';
      const snap = await get(ref(db, 'users'));
      const data = snap.val();
      listEl.innerHTML = '';

      if (!data) {
        listEl.innerHTML = '<p class="empty-users">No users yet. Create the first one above.</p>';
        return;
      }

      Object.entries(data).forEach(([uid, u]) => {
        const color         = u.color || '#c8a45c';
        const isPlaceholder = !!u._tempEmail;
        const item          = document.createElement('div');
        item.className = 'user-item';

        const credSection = isPlaceholder
          ? `<div class="ep-divider"></div>` +
            `<p class="ep-section-label">Login Credentials <span class="ep-placeholder-badge">placeholder</span></p>` +
            `<p class="ep-current-email">Current login: ${esc(u._tempEmail)}</p>` +
            `<div class="edit-grid" style="grid-template-columns:1fr 1fr">` +
              `<div class="field"><label>New Email</label><input class="ep-new-email" type="email" placeholder="player@example.com" autocomplete="off" /></div>` +
              `<div class="field"><label>New Password</label><input class="ep-new-pw" type="password" placeholder="min. 6 characters" autocomplete="new-password" /></div>` +
            `</div>` +
            `<div class="edit-actions" style="margin-top:10px">` +
              `<button class="btn-update-creds">Update Login</button>` +
              `<span class="edit-creds-msg edit-msg"></span>` +
            `</div>`
          : `<div class="ep-divider"></div>` +
            `<p class="ep-section-label">Login Credentials</p>` +
            `<p class="ep-creds-note" style="margin-bottom:12px">No login credentials set. Enter an email and password to create a Firebase Auth account — all inventory and campaign data will be migrated to the new account automatically.</p>` +
            `<div class="edit-grid" style="grid-template-columns:1fr 1fr">` +
              `<div class="field"><label>Email</label><input class="ep-new-email" type="email" placeholder="player@example.com" autocomplete="off" /></div>` +
              `<div class="field"><label>Password</label><input class="ep-new-pw" type="password" placeholder="min. 6 characters" autocomplete="new-password" /></div>` +
            `</div>` +
            `<div class="edit-actions" style="margin-top:10px">` +
              `<button class="btn-set-creds">Set Credentials</button>` +
              `<span class="edit-creds-msg edit-msg"></span>` +
            `</div>`;

        item.innerHTML =
          `<div class="user-row" style="border-radius:10px 10px var(--br,10px) var(--br,10px)">` +
            `<span class="user-dot" style="background:${esc(color)}"></span>` +
            `<div class="user-info">` +
              `<div class="user-name">${esc(u.username || '—')}</div>` +
              `<div class="user-meta">${esc(uid)}</div>` +
            `</div>` +
            `<span class="user-role ${u.role === 'admin' ? 'admin' : 'player'}">${u.role === 'admin' ? 'DM' : 'Player'}</span>` +
            `<button class="btn-edit" data-uid="${esc(uid)}" title="Edit"><iconify-icon icon="lucide:pencil" style="pointer-events:none"></iconify-icon></button>` +
            `<button class="btn-delete" data-uid="${esc(uid)}">Remove</button>` +
          `</div>` +
          `<div class="user-edit-panel" id="ep-${esc(uid)}">` +
            `<div class="edit-grid">` +
              `<div class="field">` +
                `<label>Display Name</label>` +
                `<input class="ep-name" type="text" value="${esc(u.username || '')}" />` +
              `</div>` +
              `<div class="field">` +
                `<label>Role</label>` +
                `<select class="ep-role">` +
                  `<option value="player"${u.role !== 'admin' ? ' selected' : ''}>Player</option>` +
                  `<option value="admin"${u.role === 'admin' ? ' selected' : ''}>DM / Admin</option>` +
                `</select>` +
              `</div>` +
              `<div class="field">` +
                `<label>Colour</label>` +
                `<div class="color-row">` +
                  `<input class="ep-color-pick" type="color" value="${esc(color)}" />` +
                  `<input class="ep-color-text" type="text" value="${esc(color)}" maxlength="7" />` +
                `</div>` +
              `</div>` +
            `</div>` +
            `<div class="edit-actions">` +
              `<button class="btn-edit-save" data-uid="${esc(uid)}">Save</button>` +
              `<button class="btn-edit-cancel" data-uid="${esc(uid)}">Cancel</button>` +
              `<span class="edit-msg"></span>` +
            `</div>` +
            credSection +
          `</div>`;
        listEl.appendChild(item);

        const panel = item.querySelector('.user-edit-panel');
        const row   = item.querySelector('.user-row');

        item.querySelector('.btn-edit').addEventListener('click', () => {
          const open = panel.classList.toggle('open');
          row.style.setProperty('--br', open ? '0px' : '10px');
        });

        item.querySelector('.btn-edit-cancel').addEventListener('click', () => {
          panel.classList.remove('open');
          row.style.setProperty('--br', '10px');
        });

        const pick = item.querySelector('.ep-color-pick');
        const text = item.querySelector('.ep-color-text');
        pick.addEventListener('input', () => { text.value = pick.value; });
        text.addEventListener('input', () => {
          if (/^#[0-9a-fA-F]{6}$/.test(text.value)) pick.value = text.value;
        });

        item.querySelector('.btn-edit-save').addEventListener('click', async () => {
          const saveBtn = item.querySelector('.btn-edit-save');
          const msgEl   = item.querySelector('.edit-msg');
          const name    = item.querySelector('.ep-name').value.trim();
          const role    = item.querySelector('.ep-role').value;
          const clr     = text.value || '#c8a45c';

          if (!name) { msgEl.textContent = 'Name required.'; msgEl.className = 'edit-msg err'; return; }

          saveBtn.disabled = true;
          saveBtn.textContent = 'Saving…';
          try {
            const existing = (await get(ref(db, `users/${uid}`))).val() || {};
            await set(ref(db, `users/${uid}`), { ...existing, username: name, role, color: clr });
            msgEl.textContent = 'Saved!';
            msgEl.className = 'edit-msg ok';
            setTimeout(loadUsers, 800);
          } catch(e) {
            msgEl.textContent = 'Error: ' + e.message;
            msgEl.className = 'edit-msg err';
            saveBtn.disabled = false;
            saveBtn.textContent = 'Save';
          }
        });

        item.querySelector('.btn-delete').addEventListener('click', () => deleteUser(uid));

        if (isPlaceholder) {
          item.querySelector('.btn-update-creds').addEventListener('click', async () => {
            const updateBtn = item.querySelector('.btn-update-creds');
            const credsMsg  = item.querySelector('.edit-creds-msg');
            const newEmail  = item.querySelector('.ep-new-email').value.trim();
            const newPw     = item.querySelector('.ep-new-pw').value;

            if (!newEmail || !newPw) { credsMsg.textContent = 'Enter both email and password.'; credsMsg.className = 'edit-creds-msg edit-msg err'; return; }
            if (newPw.length < 6)   { credsMsg.textContent = 'Password must be at least 6 characters.'; credsMsg.className = 'edit-creds-msg edit-msg err'; return; }

            updateBtn.disabled = true;
            updateBtn.textContent = 'Updating…';
            try {
              const signedIn = await signInWithEmailAndPassword(secondaryAuth, u._tempEmail, u._tempPw);
              await updateEmail(signedIn.user, newEmail);
              await updatePassword(signedIn.user, newPw);
              await secondarySignOut(secondaryAuth);

              const existing = (await get(ref(db, `users/${uid}`))).val() || {};
              delete existing._tempEmail;
              delete existing._tempPw;
              await set(ref(db, `users/${uid}`), existing);

              credsMsg.textContent = 'Login updated!';
              credsMsg.className = 'edit-creds-msg edit-msg ok';
              setTimeout(loadUsers, 900);
            } catch(e) {
              credsMsg.textContent = 'Error: ' + e.message;
              credsMsg.className = 'edit-creds-msg edit-msg err';
              updateBtn.disabled = false;
              updateBtn.textContent = 'Update Login';
            }
          });
        } else {
          item.querySelector('.btn-set-creds').addEventListener('click', async () => {
            const setBtn   = item.querySelector('.btn-set-creds');
            const credsMsg = item.querySelector('.edit-creds-msg');
            const newEmail = item.querySelector('.ep-new-email').value.trim();
            const newPw    = item.querySelector('.ep-new-pw').value;

            if (!newEmail || !newPw) { credsMsg.textContent = 'Enter both email and password.'; credsMsg.className = 'edit-creds-msg edit-msg err'; return; }
            if (newPw.length < 6)   { credsMsg.textContent = 'Password must be at least 6 characters.'; credsMsg.className = 'edit-creds-msg edit-msg err'; return; }

            setBtn.disabled = true;
            setBtn.textContent = 'Creating…';
            try {
              // Create the real Firebase Auth account
              const cred   = await createUserWithEmailAndPassword(secondaryAuth, newEmail, newPw);
              const newUid = cred.user.uid;
              await secondarySignOut(secondaryAuth);

              // Copy user profile to new UID
              const userData = (await get(ref(db, `users/${uid}`))).val() || {};
              delete userData._tempEmail;
              delete userData._tempPw;
              await set(ref(db, `users/${newUid}`), userData);

              // Migrate per-user campaign data
              const campsSnap = await get(ref(db, 'campaigns'));
              if (campsSnap.exists()) {
                for (const [campId, camp] of Object.entries(campsSnap.val())) {
                  for (const node of ['inventory', 'spellbook', 'members', 'displayNames']) {
                    if (camp[node] && camp[node][uid] !== undefined) {
                      await set(ref(db, `campaigns/${campId}/${node}/${newUid}`), camp[node][uid]);
                      await remove(ref(db, `campaigns/${campId}/${node}/${uid}`));
                    }
                  }
                }
              }

              // Delete old UID record
              await remove(ref(db, `users/${uid}`));

              credsMsg.textContent = 'Account created — data migrated to new UID.';
              credsMsg.className = 'edit-creds-msg edit-msg ok';
              setTimeout(loadUsers, 1200);
            } catch(e) {
              credsMsg.textContent = e.code === 'auth/email-already-in-use'
                ? 'That email already has an account.'
                : 'Error: ' + e.message;
              credsMsg.className = 'edit-creds-msg edit-msg err';
              setBtn.disabled = false;
              setBtn.textContent = 'Set Credentials';
            }
          });
        }
      });
    }

    async function deleteUser(uid) {
      if (!confirm('Remove this user? They will no longer be able to log in.')) return;
      try {
        const campaignsSnap = await get(ref(db, 'campaigns'));
        if (campaignsSnap.exists()) {
          const removals = [];
          for (const [campId, camp] of Object.entries(campaignsSnap.val())) {
            if (camp.members && camp.members[uid]) {
              removals.push(remove(ref(db, `campaigns/${campId}/members/${uid}`)));
            }
          }
          await Promise.all(removals);
        }
        await remove(ref(db, `users/${uid}`));
      } catch (e) {
        alert('Failed to remove user: ' + e.message);
        return;
      }
      loadUsers();
    }

    const msgEl = document.getElementById('form-msg');

    function showMsg(text, type) {
      msgEl.textContent = text;
      msgEl.className = 'form-msg ' + type;
    }

    const credBox   = document.getElementById('cred-box');
    const credEmail = document.getElementById('cred-email');
    const credPw    = document.getElementById('cred-pw');

    credBox.querySelectorAll('.btn-copy').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = document.getElementById(btn.dataset.target).textContent;
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
        });
      });
    });

    function randStr(len) {
      let s = '';
      while (s.length < len) s += Math.random().toString(36).slice(2);
      return s.slice(0, len);
    }

    document.getElementById('btn-create').addEventListener('click', async () => {
      msgEl.className = 'form-msg';
      credBox.classList.remove('show');

      let email    = document.getElementById('f-email').value.trim();
      const username = document.getElementById('f-username').value.trim();
      let password = document.getElementById('f-password').value;
      const role   = document.getElementById('f-role').value;
      const color  = colorText.value || '#c8a45c';

      if (!username) { showMsg('Display name is required.', 'error'); return; }

      // Require both or neither
      if (!!email !== !!password) {
        showMsg('Provide both email and password, or leave both blank for a placeholder account.', 'error');
        return;
      }
      if (password && password.length < 6) { showMsg('Password must be at least 6 characters.', 'error'); return; }

      let isPlaceholder = false;
      if (!email) {
        isPlaceholder = true;
        email    = `temp-${randStr(6)}@essolis.internal`;
        password = randStr(12);
      }

      const btn = document.getElementById('btn-create');
      btn.disabled = true;
      btn.textContent = 'Creating…';

      try {
        const cred = await createUserWithEmailAndPassword(secondaryAuth, email, password);
        const uid  = cred.user.uid;
        const userData = { username, role, color };
        if (isPlaceholder) { userData._tempEmail = email; userData._tempPw = password; }
        await set(ref(db, `users/${uid}`), userData);
        await secondarySignOut(secondaryAuth);

        if (isPlaceholder) {
          showMsg(`Placeholder account created for ${username}. Share the login details below.`, 'success');
          credEmail.textContent = email;
          credPw.textContent    = password;
          credBox.classList.add('show');
        } else {
          showMsg(`Account created for ${username}.`, 'success');
        }
        document.getElementById('f-email').value    = '';
        document.getElementById('f-username').value = '';
        document.getElementById('f-password').value = '';
        document.getElementById('f-role').value     = 'player';
        loadUsers();
      } catch (e) {
        if (e.code === 'auth/email-already-in-use') {
          showMsg('That email is already registered.', 'error');
        } else {
          showMsg('Error: ' + e.message, 'error');
        }
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<iconify-icon icon="lucide:user-plus"></iconify-icon> Create Account';
      }
    });

    function esc(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Migration tool ─────────────────────────────────────────────────────────
    const mgCampaign = document.getElementById('mg-campaign');
    const mgStatus   = document.getElementById('mg-status');
    const btnMigrate = document.getElementById('btn-migrate');

    async function loadCampaignsForMigration() {
      const snap = await get(ref(db, 'campaigns'));
      if (!snap.exists()) return;
      for (const [id, camp] of Object.entries(snap.val())) {
        const opt = document.createElement('option');
        opt.value = id;
        opt.textContent = camp.name || id;
        mgCampaign.appendChild(opt);
      }
    }
    loadCampaignsForMigration();

    btnMigrate.addEventListener('click', async () => {
      const targetId = mgCampaign.value;
      if (!targetId) { mgStatus.textContent = 'Select a campaign first.'; mgStatus.className = 'migrate-status error'; return; }

      const nodes = [...document.querySelectorAll('#mg-nodes input[type="checkbox"]:checked')].map(cb => cb.value);
      if (nodes.length === 0) { mgStatus.textContent = 'Select at least one node to copy.'; mgStatus.className = 'migrate-status error'; return; }

      const deleteAfter = document.getElementById('mg-delete-after').checked;
      if (deleteAfter && !confirm('This will permanently delete the selected nodes from the root after copying. Are you sure?')) return;

      btnMigrate.disabled = true;
      mgStatus.className = 'migrate-status running';
      mgStatus.textContent = 'Starting migration…\n';

      const lines = ['Starting migration…'];
      const setStatus = () => { mgStatus.textContent = lines.join('\n'); };

      try {
        for (const node of nodes) {
          lines.push(`Copying /${node}…`);
          setStatus();
          const snap = await get(ref(db, node));
          if (!snap.exists()) { lines[lines.length - 1] += ' (empty, skipped)'; setStatus(); continue; }
          await set(ref(db, `campaigns/${targetId}/${node}`), snap.val());
          lines[lines.length - 1] += ' done';
          setStatus();
        }

        if (deleteAfter) {
          lines.push('\nDeleting originals from root…');
          setStatus();
          for (const node of nodes) {
            const snap = await get(ref(db, node));
            if (!snap.exists()) continue;
            await remove(ref(db, node));
            lines.push(`  /${node} deleted`);
            setStatus();
          }
        }

        lines.push('\nMigration complete!');
        mgStatus.className = 'migrate-status done';
        setStatus();
      } catch (e) {
        lines.push('\nError: ' + e.message);
        mgStatus.className = 'migrate-status error';
        setStatus();
      } finally {
        btnMigrate.disabled = false;
      }
    });

    loadUsers();

    // ── NPC names export ───────────────────────────────────────────────────
    const btnExportNames  = document.getElementById('btn-export-names');
    const npcExportStatus = document.getElementById('npc-export-status');
    const npcCampaign     = document.getElementById('npc-campaign');

    async function loadCampaignsForNpc() {
      const snap = await get(ref(db, 'campaigns'));
      if (!snap.exists()) return;
      for (const [id, camp] of Object.entries(snap.val())) {
        const opt = document.createElement('option');
        opt.value = id;
        opt.textContent = camp.name || id;
        npcCampaign.appendChild(opt);
      }
    }
    loadCampaignsForNpc();

    btnExportNames.addEventListener('click', async () => {
      const targetId = npcCampaign.value;
      if (!targetId) { npcExportStatus.textContent = 'Select a campaign first.'; npcExportStatus.className = 'migrate-status error'; return; }
      btnExportNames.disabled = true;
      npcExportStatus.textContent = 'Exporting…';
      npcExportStatus.className = 'migrate-status running';
      try {
        await set(ref(db, `campaigns/${targetId}/npcNames`), NPC_NAMES);
        npcExportStatus.textContent = `✓ Exported to campaigns/${targetId}/npcNames`;
        npcExportStatus.className = 'migrate-status done';
      } catch (e) {
        npcExportStatus.textContent = 'Error: ' + e.message;
        npcExportStatus.className = 'migrate-status error';
      } finally {
        btnExportNames.disabled = false;
      }
    });
  </script>
</Layout>
