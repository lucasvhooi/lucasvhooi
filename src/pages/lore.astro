---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Lore — DnD Campaign" showCampaignTabs={true} activePage="lore" extraCSS={['/assets/css/lore.css']}>

  <header class="lore-hero page-hero">
    <button id="lore-add-btn" class="dm-btn lore-add-btn page-hero__add-btn" style="display:none">+ Add Lore</button>
    <h1 class="lore-title page-hero__title">Lore</h1>
    <p class="lore-subtitle page-hero__sub">Books and scrolls discovered on your journey</p>
    <div class="lore-filter-tabs">
      <button class="lore-tab active" data-filter="all">All</button>
      <button class="lore-tab" data-filter="book">Books</button>
      <button class="lore-tab" data-filter="scroll">Scrolls</button>
    </div>
  </header>

  <main class="lore-main">
    <div id="lore-grid" class="lore-grid"></div>
    <p id="lore-empty" class="lore-empty" style="display:none">No lore discovered yet.</p>
  </main>

  <!-- Add / Edit modal -->
  <div id="lore-modal" class="modal-overlay">
    <div class="modal-box lore-edit-box">
      <h2 id="lm-title">Add Lore</h2>

      <div class="form-row">
        <label>Type</label>
        <div class="lore-type-selector" id="lm-type-selector">
          <button type="button" class="lore-type-btn active" data-type="book"><iconify-icon icon="game-icons:open-book"></iconify-icon> Book</button>
          <button type="button" class="lore-type-btn" data-type="scroll"><iconify-icon icon="game-icons:scroll-unfurled"></iconify-icon> Scroll</button>
        </div>
      </div>

      <div class="form-row two-col">
        <label>Title <span class="req">*</span>
          <input type="text" id="lm-name" placeholder="e.g. The Age of Embers" />
        </label>
        <label>Author <span class="dm-hint">(optional)</span>
          <input type="text" id="lm-writer" placeholder="e.g. Aldric the Sage" />
        </label>
      </div>

      <!-- Book: cover color -->
      <div id="lm-color-row" class="form-row">
        <label>Cover Colour</label>
        <div class="color-swatch-row" id="lm-color-swatches"></div>
      </div>

      <!-- Book: pages editor -->
      <div id="lm-pages-section" class="lm-pages-section">
        <div class="pages-header-row">
          <span class="pages-section-label">Pages</span>
          <button type="button" id="lm-add-page-btn" class="dm-btn dm-btn-sm">+ Add Page</button>
        </div>
        <div id="lm-pages-list" class="lm-pages-list"></div>
      </div>

      <!-- Scroll: single content area -->
      <div id="lm-scroll-section" class="form-row" style="display:none">
        <label>Content
          <textarea id="lm-scroll-content" rows="6" placeholder="Write the scroll's text here…"></textarea>
        </label>
      </div>

      <!-- Available in library toggle -->
      <div class="form-row lm-library-row">
        <div class="lm-library-label-group">
          <span class="lm-library-label"><iconify-icon icon="game-icons:bookshelf"></iconify-icon> Available in Library</span>
          <span class="dm-hint">Players can browse and read this in library buildings</span>
        </div>
        <label class="toggle-switch">
          <input type="checkbox" id="lm-available-in-library" />
          <span class="toggle-slider"></span>
        </label>
      </div>

      <div id="lm-error" class="modal-error"></div>
      <div class="modal-actions">
        <button id="lm-save" class="dm-btn">Save</button>
        <button id="lm-cancel" class="dm-btn dm-btn-secondary">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Reader modal -->
  <div id="lore-reader" class="modal-overlay">
    <div class="modal-box reader-box" id="reader-box">
      <button id="reader-close" class="reader-close-btn">&times;</button>

      <!-- Book reader -->
      <div id="reader-book" style="display:none">
        <div class="reader-book-cover" id="reader-cover">
          <div class="reader-cover-spine" id="reader-spine"></div>
          <div class="reader-cover-front">
            <div class="reader-cover-title" id="reader-cover-title"></div>
            <div class="reader-cover-writer" id="reader-cover-writer"></div>
          </div>
        </div>
        <div class="reader-page-area" id="reader-page-area">
          <div class="reader-page" id="reader-page">
            <h3 class="reader-page-title" id="reader-page-title"></h3>
            <div class="reader-page-content" id="reader-page-content"></div>
          </div>
          <div class="reader-page-nav">
            <button id="reader-prev" class="reader-nav-btn"><iconify-icon icon="lucide:arrow-left"></iconify-icon> Prev</button>
            <span id="reader-page-num" class="reader-page-num"></span>
            <button id="reader-next" class="reader-nav-btn">Next <iconify-icon icon="lucide:arrow-right"></iconify-icon></button>
          </div>
        </div>
      </div>

      <!-- Scroll reader -->
      <div id="reader-scroll" style="display:none">
        <div class="reader-scroll-wrap">
          <div class="reader-scroll-roll top"></div>
          <div class="reader-scroll-body" id="reader-scroll-body">
            <div class="reader-scroll-title" id="reader-scroll-title"></div>
            <div class="reader-scroll-writer" id="reader-scroll-writer"></div>
            <div class="reader-scroll-content" id="reader-scroll-content"></div>
          </div>
          <div class="reader-scroll-roll bottom"></div>
        </div>
      </div>

    </div>
  </div>

  <script is:inline type="module" src="/assets/js/lore.js"></script>
</Layout>
