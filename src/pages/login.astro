---
import Layout from '../layouts/Layout.astro';
import bgImg from '../../Images/Headers/AccountPageBackground.png';
---
<Layout title="Login — DnD Campaign" showNav={false} extraCSS={['/assets/css/base.css']}>
  <style is:inline>
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      background-color: var(--bg);
    }

    .login-wrap {
      position: relative;
      flex: 1;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      background-position: center;
      background-size: cover;
      background-attachment: fixed;
    }
    /* Darkening + amber wash overlay so the card stays legible over the art */
    .login-wrap::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 0%, rgba(255,204,102,0.08), transparent 55%),
        linear-gradient(rgba(16,14,11,0.72), rgba(12,10,8,0.9));
      pointer-events: none;
    }
    .login-wrap > * { position: relative; z-index: 1; }

    .login-card {
      position: relative;
      background: linear-gradient(135deg, rgba(28,28,26,0.94) 0%, rgba(20,20,19,0.94) 100%);
      border: 1px solid rgba(200,164,92,0.22);
      border-radius: var(--rounded-xl);
      padding: 40px 36px 32px;
      width: 100%;
      max-width: 380px;
      backdrop-filter: blur(10px);
      box-shadow:
        var(--shadow-modal),
        0 0 40px rgba(255,204,102,0.08),
        inset 0 1px 0 rgba(255,204,102,0.08);
      animation: cardIn 0.55s var(--ease-out-expo) both;
    }
    /* Soft amber rim glow */
    .login-card::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      padding: 1px;
      background: linear-gradient(160deg, rgba(255,204,102,0.35), transparent 40%, transparent 70%, rgba(255,204,102,0.18));
      -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
      -webkit-mask-composite: xor;
              mask-composite: exclude;
      pointer-events: none;
    }
    @keyframes cardIn {
      from { opacity: 0; transform: translateY(24px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0)    scale(1);    }
    }

    .login-logo {
      display: block;
      width: 64px;
      height: 64px;
      margin: 0 auto 18px;
      filter: brightness(0) saturate(100%) invert(86%) sepia(38%) saturate(900%) hue-rotate(330deg) brightness(103%)
              drop-shadow(0 0 14px rgba(255,204,102,0.4));
    }

    .login-title {
      font-family: var(--title);
      font-size: 1.7rem;
      color: var(--accent);
      text-align: center;
      margin: 0 0 6px;
      letter-spacing: 0.05em;
      text-shadow: 0 0 22px rgba(255,204,102,0.3);
    }

    .login-sub {
      text-align: center;
      color: var(--smoke);
      font-size: 13px;
      font-style: italic;
      margin: 0 0 28px;
    }

    .login-field { margin-bottom: 16px; }

    .login-label {
      display: block;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--smoke);
      margin-bottom: 6px;
    }

    .login-input {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(200,164,92,0.14);
      border-radius: var(--rounded-md);
      padding: 11px 14px;
      color: var(--text);
      font-size: 15px;
      font-family: var(--font);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      box-sizing: border-box;
    }
    .login-input:focus {
      border-color: rgba(255,204,102,0.55);
      box-shadow: 0 0 0 3px rgba(255,204,102,0.1);
    }

    /* Golden textured primary button */
    .login-btn {
      width: 100%;
      margin-top: 8px;
      background: linear-gradient(135deg, #8a6010 0%, #c8922a 40%, #e0b040 60%, #b07820 100%);
      border: 1px solid rgba(220,170,60,0.6);
      border-radius: var(--rounded-md);
      color: #1a1000;
      font-family: var(--title);
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.08em;
      padding: 13px;
      cursor: pointer;
      transition: filter 0.22s, box-shadow 0.25s, transform 0.2s;
    }
    .login-btn:hover {
      filter: brightness(1.1);
      box-shadow: 0 0 20px rgba(255,204,102,0.4), 0 4px 16px rgba(0,0,0,0.4);
      transform: translateY(-1px);
    }
    .login-btn:active { transform: translateY(0) scale(0.98); }
    .login-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; filter: none; }

    .divider {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 20px 0;
      color: var(--deep-smoke);
      font-size: 12px;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      border-top: 1px solid rgba(200,164,92,0.14);
    }

    .btn-google {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(200,164,92,0.16);
      border-radius: var(--rounded-md);
      color: #ccc;
      font-size: 14px;
      font-family: var(--font);
      padding: 11px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
    }
    .btn-google:hover { background: rgba(255,255,255,0.09); border-color: rgba(200,164,92,0.4); }
    .btn-google:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-google svg { flex-shrink: 0; }

    .login-error {
      background: rgba(224,80,80,0.12);
      border: 1px solid rgba(224,80,80,0.3);
      border-radius: var(--rounded-sm);
      color: var(--hazard-red);
      font-size: 13px;
      padding: 9px 12px;
      margin-top: 14px;
      display: none;
    }
    .login-error.show { display: block; }

    .login-footer {
      text-align: center;
      margin-top: 22px;
      font-size: 13px;
      color: var(--deep-smoke);
    }
    .login-footer a { color: var(--accent); text-decoration: none; }
    .login-footer a:hover { text-decoration: underline; }
  </style>

  <div class="login-wrap" style={`background-image:url('${bgImg.src}')`}>
    <div class="login-card">
      <img src="/Images/EssolisLogo.webp" alt="Essolis" class="login-logo">
      <h1 class="login-title">Enter Essolis</h1>
      <p class="login-sub">Sign in to your account</p>

      <div class="login-field">
        <label class="login-label" for="login-user">Email</label>
        <input class="login-input" id="login-user" type="email" placeholder="your@email.com" autocomplete="email" />
      </div>
      <div class="login-field">
        <label class="login-label" for="login-pass">Password</label>
        <input class="login-input" id="login-pass" type="password" placeholder="Secret passphrase…" autocomplete="current-password" />
      </div>

      <button class="login-btn" id="login-btn">
        <iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Enter Essolis
      </button>

      <div class="divider">or</div>

      <button class="btn-google" id="btn-google">
        <svg width="18" height="18" viewBox="0 0 48 48">
          <path fill="#FFC107" d="M43.6 20H24v8h11.3C33.6 33.1 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20c11 0 19.7-8 19.7-20 0-1.3-.1-2.7-.1-4z"/>
          <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.5 16 19 13 24 13c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4c-7.7 0-14.4 4.2-17.7 10.7z"/>
          <path fill="#4CAF50" d="M24 44c5.2 0 9.9-1.9 13.5-5l-6.2-5.2C29.5 35.5 26.9 36.5 24 36.5c-5.2 0-9.6-3.5-11.2-8.2l-6.5 5C9.7 39.7 16.3 44 24 44z"/>
          <path fill="#1976D2" d="M43.6 20H24v8h11.3c-.8 2.3-2.3 4.3-4.3 5.8l6.2 5.2C41.2 35.8 44 30.3 44 24c0-1.3-.1-2.7-.4-4z"/>
        </svg>
        Continue with Google
      </button>

      <div class="login-error" id="login-error"></div>

      <p class="login-footer">No account? <a href="register">Create one</a></p>
    </div>
  </div>

  <script is:inline type="module">
    import { auth, db }                                          from "/assets/js/firebase.js";
    import { signInWithEmailAndPassword, GoogleAuthProvider,
             signInWithPopup }                                   from "https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js";
    import { ref, get, set }                                     from "https://www.gstatic.com/firebasejs/10.14.1/firebase-database.js";
    import { saveSession, getSession }                           from "/assets/js/auth.js";

    if (getSession()) window.location.href = "campaigns";

    const btn    = document.getElementById("login-btn");
    const btnG   = document.getElementById("btn-google");
    const err    = document.getElementById("login-error");
    const eInp   = document.getElementById("login-user");
    const pInp   = document.getElementById("login-pass");

    async function doLogin() {
      err.classList.remove("show");
      const email    = eInp.value.trim();
      const password = pInp.value;
      if (!email || !password) { showErr("Please enter your email and password."); return; }

      setLoading(true);
      try {
        const cred    = await signInWithEmailAndPassword(auth, email, password);
        const profile = await fetchProfile(cred.user.uid);
        if (!profile) { showErr("Account has no profile. Ask your DM."); return; }
        saveSession({ id: cred.user.uid, username: profile.username, role: profile.role || "player", color: profile.color || "#c8a45c" });
        window.location.href = "campaigns";
      } catch (e) {
        if (["auth/invalid-credential","auth/wrong-password","auth/user-not-found"].includes(e.code)) {
          showErr("Wrong email or password.");
        } else {
          showErr("Connection error. Please try again.");
        }
      } finally { setLoading(false); }
    }

    btnG.addEventListener("click", async () => {
      err.classList.remove("show");
      btnG.disabled = true;
      btnG.textContent = "Signing in…";
      try {
        const cred = await signInWithPopup(auth, new GoogleAuthProvider());
        const uid  = cred.user.uid;
        const profile = await fetchProfile(uid);

        if (!profile) {
          // No profile means this Google account was never registered via invite.
          // Sign them out and send to register so the invite code is checked.
          await import("https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js")
            .then(m => m.signOut(auth)).catch(() => {});
          window.location.href = "register";
          return;
        }

        saveSession({ id: uid, username: profile.username, role: profile.role || "player", color: profile.color || "#c8a45c" });
        window.location.href = "campaigns";
      } catch (e) {
        if (e.code !== "auth/popup-closed-by-user") showErr("Google sign-in failed. Please try again.");
      } finally {
        btnG.disabled = false;
        btnG.innerHTML = `<svg width="18" height="18" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.6 20H24v8h11.3C33.6 33.1 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20c11 0 19.7-8 19.7-20 0-1.3-.1-2.7-.1-4z"/><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.5 16 19 13 24 13c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4c-7.7 0-14.4 4.2-17.7 10.7z"/><path fill="#4CAF50" d="M24 44c5.2 0 9.9-1.9 13.5-5l-6.2-5.2C29.5 35.5 26.9 36.5 24 36.5c-5.2 0-9.6-3.5-11.2-8.2l-6.5 5C9.7 39.7 16.3 44 24 44z"/><path fill="#1976D2" d="M43.6 20H24v8h11.3c-.8 2.3-2.3 4.3-4.3 5.8l6.2 5.2C41.2 35.8 44 30.3 44 24c0-1.3-.1-2.7-.4-4z"/></svg> Continue with Google`;
      }
    });

    async function fetchProfile(uid) {
      const snap = await get(ref(db, `users/${uid}`));
      return snap.val();
    }

    function setLoading(on) {
      btn.disabled = on;
      btn.innerHTML = on
        ? "Checking…"
        : '<iconify-icon icon="game-icons:crossed-swords"></iconify-icon> Enter Essolis';
    }

    function showErr(msg) { err.textContent = msg; err.classList.add("show"); }

    function randomColor() {
      const h = Math.floor(Math.random() * 360);
      const s = 55 + Math.floor(Math.random() * 25);
      const l = 55 + Math.floor(Math.random() * 15);
      return hslToHex(h, s, l);
    }
    function hslToHex(h, s, l) {
      s /= 100; l /= 100;
      const a = s * Math.min(l, 1 - l);
      const f = n => { const k = (n + h / 30) % 12; return Math.round(255 * (l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1))).toString(16).padStart(2, '0'); };
      return `#${f(0)}${f(8)}${f(4)}`;
    }

    btn.addEventListener("click", doLogin);
    [eInp, pInp].forEach(el => el.addEventListener("keydown", e => { if (e.key === "Enter") doLogin(); }));
  </script>
</Layout>
