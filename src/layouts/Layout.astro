---
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  showNav?: boolean;
  activePage?: string;
  extraCSS?: string[];
  bodyClass?: string;
  pageContentStyle?: string;
}

const {
  title = 'Essolis — DnD Campaign',
  showNav = true,
  activePage = '',
  extraCSS = [],
  bodyClass = '',
  pageContentStyle = '',
} = Astro.props;

---
<!DOCTYPE html>
<html lang="en" class={showNav ? 'app-layout' : undefined}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/webp" href="/Images/EssolisLogoWeb.webp" />
  <meta property="og:image" content="/Images/EssolisLogoWeb.webp" />
  <link rel="stylesheet" href="/assets/css/base.css" />
  {extraCSS.map(css => <link rel="stylesheet" href={css} />)}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet" />
  <script is:inline src="https://code.iconify.design/iconify-icon/2.3.0/iconify-icon.min.js"></script>
</head>
<body class={bodyClass || undefined}>
  {showNav && (
    <div class="app-shell">
      <header class="mobile-topbar">
        <button class="mobile-nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <span class="mobile-topbar-title">Essolis</span>
        <a href="/campaigns" class="mobile-topbar-logo" aria-label="Essolis home">
          <img src="/Images/EssolisLogoGold.webp" alt="Essolis" />
        </a>
      </header>
      <div class="mobile-nav-backdrop"></div>
      <Sidebar activePage={activePage} />
      <div class="page-content" style={pageContentStyle || undefined}>
        <slot />
      </div>
    </div>
  )}
  {!showNav && <slot />}
  {showNav && <script is:inline src="/assets/js/base.js"></script>}
</body>
</html>
