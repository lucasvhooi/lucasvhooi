---
// Shared Add/Edit Item modal used by both the Items tab (#item-modal) and the
// Inventory tab (#qe-modal). Element ids are prefixed so each page's existing JS
// keeps working unchanged (items.js -> "im", inventory.js -> "qe"). Styling lives
// in base.css, scoped under `.item-edit-modal`.
interface Props {
  prefix?: string;
  modalId: string;
  title?: string;
}
const { prefix = 'im', modalId, title = 'Add Item' } = Astro.props;
const p = prefix;
---
<div id={modalId} class="modal-overlay item-edit-modal">
  <div class="modal-box">
    <div class="modal-header">
      <h2 id={`${p}-title`}>{title}</h2>
      <button class="modal-close-x" id={`${p}-close-btn`}>&times;</button>
    </div>
    <div class="modal-body">
      <!-- Name: full width -->
      <div class="form-row im-name-row">
        <label>Name <span class="req">*</span>
          <input type="text" id={`${p}-name`} placeholder="e.g. Health Potion" />
        </label>
      </div>
      <!-- Two-column body -->
      <div class="im-form-grid">
        <div class="im-col-left">
          <div class="form-row">
            <label>Description
              <textarea id={`${p}-desc`} rows="7" placeholder="What does this item do or look like?"></textarea>
            </label>
          </div>
          <div class="form-row">
            <label>Abilities</label>
            <div id={`${p}-abilities-list`} class="im-abilities-list"></div>
            <button type="button" id={`${p}-ability-add-btn`} class="im-ability-add-btn">+ Add Ability</button>
          </div>
        </div>
        <div class="im-col-right">
          <div class="form-row two-col">
            <label>Base Price (gp) <span class="req">*</span>
              <input type="number" id={`${p}-price`} placeholder="e.g. 50" min="0" step="0.01" />
            </label>
            <label>Weight (lb)
              <input type="number" id={`${p}-weight`} placeholder="e.g. 1" min="0" step="0.1" />
            </label>
          </div>
          <div class="form-row">
            <label>Tags</label>
            <div class="im-tag-picker-row">
              <div class="im-tag-chips" id={`${p}-tag-chips`}></div>
              <button type="button" id={`${p}-tag-add-btn`} class="im-tag-add-btn">+ New Tag</button>
            </div>
            <input type="text" id={`${p}-tag-new-input`} class="im-tag-new-input" placeholder="New tag name…" style="display:none" />
          </div>
          <div class="form-row">
            <label>Rarity</label>
            <div class="rarity-selector" id={`${p}-rarity-selector`}>
              <button type="button" class="rarity-sel-btn" data-rarity="common">Common</button>
              <button type="button" class="rarity-sel-btn" data-rarity="uncommon">Uncommon</button>
              <button type="button" class="rarity-sel-btn" data-rarity="rare">Rare</button>
              <button type="button" class="rarity-sel-btn" data-rarity="very rare">Very Rare</button>
              <button type="button" class="rarity-sel-btn" data-rarity="legendary">Legendary</button>
            </div>
          </div>
          <div class="form-row">
            <label class="checkbox-label">
              <input type="checkbox" id={`${p}-shop-available`} checked />
              <span class="checkbox-box"></span>
              Available in shop
            </label>
          </div>
          <div class="form-row">
            <label class="checkbox-label">
              <input type="checkbox" id={`${p}-requires-attunement`} />
              <span class="checkbox-box"></span>
              Requires Attunement
            </label>
          </div>
        </div>
      </div>
      <div id={`${p}-error`} class="modal-error"></div>
    </div>
    <div class="modal-actions">
      <button id={`${p}-save`} class="dm-btn">Save Item</button>
      <button id={`${p}-cancel`} class="dm-btn dm-btn-secondary">Cancel</button>
    </div>
  </div>
</div>
