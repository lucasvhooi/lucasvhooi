---
interface Props {
  showCampaignTabs?: boolean;
  activePage?: string;
}
const { showCampaignTabs = false, activePage = '' } = Astro.props;

const navLinks = [
  { href: '/missions',    label: 'Missions',    page: 'missions',    dmOnly: false },
  { href: '/exploration', label: 'Characters',  page: 'exploration', dmOnly: false },
  { href: '/items',       label: 'Items',       page: 'items',       dmOnly: true  },
  { href: '/map',         label: 'Map',         page: 'map',         dmOnly: false },
  { href: '/lore',        label: 'Lore',        page: 'lore',        dmOnly: false },
  { href: '/combat',      label: 'Combat',      page: 'combat',      dmOnly: true  },
  { href: '/inventory',   label: 'Inventory',   page: 'inventory',   dmOnly: false },
  { href: '/spells',      label: 'Spells',      page: 'spells',      dmOnly: false },
];
---
<nav>
  <a href="/campaigns" style="display:flex;align-items:center;flex-shrink:0;margin-right:8px">
    <img src="/Images/EssolisLogo.webp" alt="Essolis Logo" class="nav-logo" />
  </a>
  <ul>
    {showCampaignTabs && navLinks.map(link => (
      <li class={link.dmOnly ? 'nav-dm-only' : ''}>
        <a href={link.href} class={activePage === link.page ? 'active' : ''}>{link.label}</a>
      </li>
    ))}
  </ul>
</nav>
